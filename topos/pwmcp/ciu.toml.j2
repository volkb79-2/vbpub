# Topos UI/browser-test policy. Upstream image/version values remain pinned in
# ciu.defaults.toml.j2 and are tracked by UPSTREAM.toml.

[pwmcp.unified]
browser_mode = "per-session"
expose = false

[pwmcp.run_server]
default_lease_s = 900
max_lease_s = 3600
max_clients = 2
idle_recycle_s = 15

[pwmcp.consumer]
network = "$DOCKER_NETWORK_INTERNAL"

[pwmcp.external]
enabled = false

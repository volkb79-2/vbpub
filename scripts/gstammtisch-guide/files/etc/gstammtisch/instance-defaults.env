# gstammtisch — Soulmask per-instance defaults (2026-07-07, N-instance support)
#
# Sourced by every host script that needs per-instance cgroup/pak config —
# via soulmask-instance-lib.sh's soulmask_load_instance_env() — before an
# optional per-instance override:
#   /etc/gstammtisch/instances.d/<server-uuid>.env
# (the docker container name == the Pterodactyl server UUID; Wings names
# containers after the server they run — see SOULMASK.md "Multi-instance
# operations" and §9 for the cluster background).
#
# Applies to EVERY Soulmask instance that has no matching override file, and
# to every key an override file doesn't set.
#
# Values below match the single-instance production band calibrated in
# setup-cgroups.sh through 2026-07-06/07 (see MEASUREMENTS.md).

# memory.min — guaranteed uncompressed floor. 6G = measured 3-player hot set;
# 5G caused player-login failures under pressure (retries needed).
SOULMASK_MIN=6G

# memory.low — best-effort soft floor (global-pressure hint, not a hard guarantee).
SOULMASK_LOW=12G

# memory.high — soft ceiling. 7G = 1G transient headroom above the ~6G hot
# set + proactive cold-tail zswap compression during calm periods. 6G
# throttled logins; if login issues reappear at 7G, go back to 8G.
SOULMASK_HIGH=7G

# memory.zswap.writeback — 1: the game's genuinely-cold tail (~4G observed)
# may page to disk once zswap's LRU has nothing colder to evict; zswap's LRU
# means only the coldest-of-cold reaches disk. Revert to 0 if login latency
# regresses (MEASUREMENTS.md M4 is the revert gate).
SOULMASK_WRITEBACK=1

# Cluster role: standalone | main | client. Governs soulmask-shutdown.sh stop
# ordering (client and standalone instances stop first, main stops last —
# SOULMASK.md §9: the main instance owns account.db and must stay reachable
# for client instances to accept logins while everything is shutting down).
ROLE=standalone

# Whether this instance's WS/Content/Paks directory is bind-mounted from the
# shared tmpfs at /mnt/soulmask-paks (soulmask-pak-ramdisk.service).
#   0 = disk-backed (default)
#   1 = opt in — bind-mount the shared pak tmpfs into this instance's volume
# All Soulmask instances on this host run the same Linux dedicated-server
# depot (appid 3017300, depot 3017301) so one pak copy can be shared byte-
# identical across every opted-in instance (verified — see SOULMASK.md §9).
PAK_RAMDISK=0

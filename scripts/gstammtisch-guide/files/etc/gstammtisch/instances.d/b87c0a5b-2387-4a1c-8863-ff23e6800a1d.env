# DLC-map server ("DCHIVE Stammtisch DLC", DLC_Level01_Main) — the running
# production instance.
#
# Chosen as the cluster MAIN (SOULMASK.md §9): it already holds the
# established world/players in world.db/account.db; making the *new*
# base-map server the main would make the established DLC world's
# reachability depend on the new instance's uptime instead. Prefer keeping
# the existing DLC server as main; the new base-map server becomes the
# client (see the commented example in this same directory).
ROLE=main

# Opt into the shared pak tmpfs (soulmask-pak-ramdisk.service) — eliminates
# major page faults on pak reads (SOULMASK.md §2c).
PAK_RAMDISK=1

# SOULMASK_MIN / SOULMASK_LOW / SOULMASK_HIGH / SOULMASK_WRITEBACK: not
# overridden here — this instance uses the values from
# /etc/gstammtisch/instance-defaults.env (the production band they were
# calibrated for).

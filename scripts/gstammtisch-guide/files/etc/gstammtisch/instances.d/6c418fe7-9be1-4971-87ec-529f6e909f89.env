# Second server ("Soulmask Server") — stood up 2026-07-21, initially as a
# same-map KSM/memory-dedup measurement testbed (MEASUREMENTS.md M7), now
# being wired as the base-map (Level01_Main) cluster CLIENT of b87c0a5b
# (SOULMASK.md #9: b87c0a5b stays MAIN since it holds the established
# DLC-map world/account.db). Cluster wiring (-serverid=, -clientserverconnect=)
# lives on the Startup Command in the panel, not here.
ROLE=client

# Opt into the shared pak tmpfs (soulmask-pak-ramdisk.service). Still valid
# on the base map: all Soulmask instances on this host share one depot/pak
# file regardless of which map is loaded (SOULMASK.md #9).
PAK_RAMDISK=1

# Opt into the shared static read-only install content tmpfs
# (soulmask-static-ramdisk.service — Engine/Binaries/bundled Steam libs,
# 2026-07-21).
STATIC_RAMDISK=1

# SOULMASK_MIN/LOW/HIGH/WRITEBACK: not overridden, uses
# instance-defaults.env. Actual memory.min is clamped by config.yml
# per_server_slices.memory_min_budget (8G, shared with b87c0a5b).

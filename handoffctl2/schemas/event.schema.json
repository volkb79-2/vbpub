{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vbpub.invalid/handoffctl2/schemas/event.schema.json",
  "title": "handoffctl2 event",
  "description": "One line of the append-only per-project events.jsonl — the authoritative runtime record. Derived from draft 1's event schema with: per-project sequence scoping made explicit, wave correlation, and the draft-2 event types (SPEC_ATTENTION, PAUSE_*, WAVE_*, PROGRESS_RECORDED, NEEDS_OPERATOR).",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "sequence", "timestamp", "project", "actor", "type", "payload"],
  "properties": {
    "schema_version": {"const": 1},
    "sequence": {
      "type": "integer",
      "minimum": 1,
      "description": "Monotonic PER PROJECT (the file it lives in). Gaps allowed, reordering not."
    },
    "timestamp": {"type": "string", "format": "date-time", "description": "UTC"},
    "project": {"type": "string", "pattern": "^[a-z][a-z0-9-]{1,62}$"},
    "task_id": {"type": ["string", "null"], "default": null},
    "attempt_id": {"type": ["string", "null"], "default": null},
    "wave_id": {"type": ["string", "null"], "default": null},
    "decision_id": {"type": ["string", "null"], "default": null},
    "actor": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "id"],
      "properties": {
        "kind": {"enum": ["tick", "wrapper", "operator", "doctor", "gate", "notifier", "frontier-session"]},
        "id": {"type": "string", "minLength": 1}
      }
    },
    "type": {
      "enum": [
        "PROJECT_REGISTERED",
        "DOCTOR_FINDING",
        "TASK_CREATED",
        "TASK_TRANSITIONED",
        "TASK_BLOCKED",
        "TASK_SUPERSEDED",
        "TASK_CANCELLED",
        "CARVE_OUTCOME",
        "DECISION_OPENED",
        "DECISION_RESOLVED",
        "ATTEMPT_CREATED",
        "ATTEMPT_PREFLIGHTED",
        "ATTEMPT_STARTED",
        "ATTEMPT_STALLED",
        "ATTEMPT_INTERRUPTED",
        "ATTEMPT_RESUMED",
        "ATTEMPT_EXITED",
        "ATTEMPT_FAILED",
        "PROVIDER_STATE_CHANGED",
        "LEASE_ACQUIRED",
        "LEASE_RELEASED",
        "GATE_STARTED",
        "GATE_FINISHED",
        "EVIDENCE_RECORDED",
        "REVIEW_RECORDED",
        "MERGE_RECORDED",
        "PROGRESS_RECORDED",
        "WAVE_OPENED",
        "WAVE_CLOSED",
        "SPEC_ATTENTION",
        "PAUSE_SET",
        "PAUSE_CLEARED",
        "NEEDS_OPERATOR",
        "NOTIFICATION_REQUESTED",
        "NOTIFICATION_DELIVERED",
        "NOTIFICATION_FAILED",
        "BUDGET_WARNING",
        "BUDGET_EXHAUSTED",
        "ARTIFACT_REGISTERED",
        "TICK_ERROR"
      ]
    },
    "payload": {
      "type": "object",
      "description": "Type-specific, versioned via schema_version, bounded (large content stays a referenced artifact), redacted before write. Notification payload builders read ONLY typed fields from here — never raw agent/log text.",
      "additionalProperties": true
    }
  }
}

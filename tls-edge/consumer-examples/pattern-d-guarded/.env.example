# ─── pattern-d-guarded/.env — basicAuth guard credentials ────────────────────
# Copy to .env and fill in the real hash before starting the stack.
# The .env file is gitignored; treat it as a secret.
#
# Generate the hash:
#   tls-edge/scripts/gen-guard-secret.sh user mysecret
#
# IMPORTANT — dollar-sign escaping:
#   htpasswd and openssl output $ characters inside the hash.
#   In a docker-compose.yml label value, $ is a variable prefix that Compose
#   expands.  Each $ in the hash must be written as $$ in the label value.
#   HOWEVER: inside a .env file used via Compose variable substitution the
#   value is consumed verbatim — write single $ here (Compose doubles them
#   when it substitutes into the label string).
#
#   So:
#     .env file value  →  GUARD_HASH=user:$2y$12$abc...   (single $)
#     Compose label    →  ${GUARD_HASH}  (Compose handles the escaping for you)
#
#   If you paste the hash directly into docker-compose.yml (not via a variable),
#   you must double every $ yourself in that file.  See docker-compose.yml.

GUARD_HASH=user:$2y$12$REPLACEWITHREALHASHOUPUTFROMGENGUARDSECRETSH

# ─── GENERATED from ciu-stack/ciu.compose.yml.j2 — do not edit copies ─────────
# Edit the template, then re-render:
#   standalone : scripts/render.sh   (writes edge-proxy/docker-compose.yml)
#   ciu v2     : run `ciu` in the ciu-stack directory (renders ciu.compose.yml + overlay)
#
# Two containers:
#   dockerproxy – restricts Traefik to read-only Docker API calls (POST: 0).
#   traefik     – TLS terminator and label-driven service router.
#
# ciu SPEC S5.3: the service key `traefik` must not be renamed — the
# [tls_edge.traefik.configfile.*] mounts are keyed by it.
{% set acme = tls_edge.tls.mode in ['acme-tls', 'acme-http', 'acme-dns'] %}
{% if tls_edge.standalone %}
name: {{ tls_edge.stack_name }}
{% endif %}

services:

  # ── Docker socket proxy ────────────────────────────────────────────────────
  dockerproxy:
    image: {{ tls_edge.dockerproxy.image }}
    container_name: {{ tls_edge.container_prefix }}-dockerproxy
    restart: unless-stopped
    environment:
      CONTAINERS: 1   # read container inspect/list
      NETWORKS:   1   # read network info for service discovery
      SERVICES:   1   # read swarm service info (no-op on standalone Docker)
      TASKS:      1   # read swarm task info (no-op on standalone Docker)
      POST:       0   # DENY all mutating/write calls to the Docker API
    volumes:
      - /var/run/docker.sock:/var/run/docker.sock:ro
    networks:
      - internal
    read_only: true
    tmpfs:
      - /run            # haproxy pid/socket
      - /tmp            # entrypoint writes the generated haproxy.cfg here
    security_opt:
      - no-new-privileges:true
    healthcheck:
      test: ["CMD", "wget", "-qO-", "http://127.0.0.1:2375/version"]
      interval: {{ tls_edge.health.interval }}
      timeout: {{ tls_edge.health.timeout }}
      retries: {{ tls_edge.health.retries }}
      start_period: {{ tls_edge.health.start_period }}
    logging:
      driver: json-file
      options:
        max-size: "{{ tls_edge.logging.max_size }}"
        max-file: "{{ tls_edge.logging.max_file }}"

  # ── Traefik TLS edge proxy ─────────────────────────────────────────────────
  traefik:
    image: {{ tls_edge.traefik.image }}
    container_name: {{ tls_edge.container_prefix }}-traefik
    restart: unless-stopped
    depends_on:
      dockerproxy:
        condition: service_healthy
{% set bind = tls_edge.ports.bind_ip ~ ':' if tls_edge.ports.bind_ip else '' %}
    ports:
{% if tls_edge.ports.expose_http %}
      # HTTP: received and immediately redirected to HTTPS by Traefik.
      - "{{ bind }}{{ tls_edge.ports.http }}:80"
{% else %}
      # Port 80 is OFF (TLS-only edge; no HTTP->HTTPS redirect).  To enable it,
      # set [tls_edge.ports] expose_http = true in ciu.toml.j2 and re-render
      # (scripts/render.sh), or run scripts/install.sh --enable-port-80.
{% endif %}
      # Primary HTTPS: subdomain-based routing (preferred).
      - "{{ bind }}{{ tls_edge.ports.https }}:443"
      # Alternative HTTPS: port-based routing fallback.
      - "{{ bind }}{{ tls_edge.ports.https_alt }}:8443"
{% if tls_edge.tls.mode == 'acme-dns' %}
{% if tls_edge.standalone %}
    # lego DNS provider credentials live in the gitignored .env (chmod 600).
    env_file:
      - .env
{% endif %}
{% if tls_edge.acme.dns.environment %}
    environment:
{% for key, value in tls_edge.acme.dns.environment.items() %}
      {{ key }}: "{{ value }}"
{% endfor %}
{% endif %}
{% if not tls_edge.standalone and tls_edge.secrets %}
    secrets:
{% for name in tls_edge.secrets %}
      - {{ name }}
{% endfor %}
{% endif %}
{% endif %}
    volumes:
{% if tls_edge.standalone %}
      # Static Traefik config — re-render + restart container on change.
      - {{ tls_edge.base_dir }}/traefik.yml:/etc/traefik/traefik.yml:ro
      # Dynamic config — Traefik hot-reloads changes via inotify.  :ro blocks
      # writes from INSIDE the container only; host-side writes still propagate
      # and trigger the reload (this is how cert renewal works in static mode).
      - {{ tls_edge.base_dir }}/conf.d:/etc/traefik/conf.d:ro
{% endif %}
{% if acme %}
      # ACME account + issued certificates (acme.json, created 0600 by traefik).
      # NOTE: `docker compose down -v` / `ciu --reset` destroys this volume and
      # forces re-issuance on next start (mind Let's Encrypt rate limits).
      - acme-data:/etc/traefik/acme
{% elif tls_edge.static.source == 'volume' %}
      # Dev certificates from scripts/dev-certs.sh --target volume (DooD-safe).
      - certs-dev:/certs:ro
{% else %}
      # Host certificate tree.  BOTH live/ and archive/ parents are mounted so
      # certbot's RELATIVE symlinks (live/<d>/x.pem -> ../../archive/<d>/xN.pem)
      # resolve inside the container.  Never mount live/<domain> directly.
      - {{ tls_edge.static.cert_base }}/live:/certs/live:ro
      - {{ tls_edge.static.cert_base }}/archive:/certs/archive:ro
{% endif %}
    networks:
      - ingress
      - internal
{% if tls_edge.join_workspace_network %}
      - workspace
{% endif %}
    # ── Hardening ──────────────────────────────────────────────────────────
    read_only: true
    tmpfs:
      - /tmp            # Traefik scratch space; in-memory only
    security_opt:
      - no-new-privileges:true
    cap_drop:
      - ALL
    cap_add:
      - NET_BIND_SERVICE  # bind ports < 1024 (443, optionally 80)
    healthcheck:
      test: ["CMD", "traefik", "healthcheck", "--ping"]
      interval: {{ tls_edge.health.interval }}
      timeout: {{ tls_edge.health.timeout }}
      retries: {{ tls_edge.health.retries }}
      start_period: {{ tls_edge.health.start_period }}
    logging:
      driver: json-file
      options:
        max-size: "{{ tls_edge.logging.max_size }}"
        max-file: "{{ tls_edge.logging.max_file }}"

# ─── Networks ─────────────────────────────────────────────────────────────────
networks:
  # Shared public ingress network; consumer stacks join it as external: true.
  # Only containers with traefik.enable=true labels are routed.
  ingress:
    name: {{ tls_edge.ingress_network }}
    driver: bridge

  # Isolated bridge between traefik and dockerproxy only.  internal: no
  # outbound connectivity; no other container may join.
  internal:
    name: {{ tls_edge.internal_network }}
    driver: bridge
    internal: true
{% if tls_edge.join_workspace_network %}

  # ciu shared workspace network (app stacks routed without joining ingress).
  workspace:
    external: true
    name: {{ deploy.network_name }}
{% endif %}
{% if acme or tls_edge.static.source == 'volume' %}

# ─── Volumes ──────────────────────────────────────────────────────────────────
volumes:
{% if acme %}
  acme-data:
{% else %}
  certs-dev:
{% endif %}
{% endif %}

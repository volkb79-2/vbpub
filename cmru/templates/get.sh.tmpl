#!/usr/bin/env bash
# ─── get.sh — [[PROJECT_NAME]] bootstrap installer / updater ─────────────────
#
# Generated by ciu-forge get-sh. Template variables use [[VARNAME]] syntax;
# all [[…]] markers are replaced at emit time by getsh.py (S6).
#
# ┌─────────────────────────────────────────────────────────────────────────┐
# │  Fresh install (run once on a new host):                                │
# │    curl -fsSL https://raw.githubusercontent.com/[[REPO_OWNER]]/        │
# │      [[REPO_NAME]]/main/[[SUBDIR]]/get.sh | sudo bash                  │
# │                                                                         │
# │  Pin a specific release:                                                │
# │    [[ENV_PREFIX]]_VERSION=[[TAG_PREFIX]]0.1.0 \                        │
# │      curl -fsSL … | sudo bash                                           │
# │                                                                         │
# │  Update an existing install:                                            │
# │    [[PROJECT_NAME]] update                                              │
# │    — or directly: sudo bash [[INSTALL_DIR_DEFAULT]]/[[SUBDIR]]/get.sh --update │
# │                                                                         │
# │  Air-gapped / dev (git clone fallback):                                 │
# │    [[ENV_PREFIX]]_INSTALL_VIA=git \                                     │
# │      curl -fsSL … | sudo bash                                           │
# └─────────────────────────────────────────────────────────────────────────┘
#
# Environment controls:
#   [[ENV_PREFIX]]_VERSION      Pin a specific tag, e.g. [[TAG_PREFIX]]0.1.0
#   [[ENV_PREFIX]]_INSTALL_DIR  Override install root (default: [[INSTALL_DIR_DEFAULT]])
#   [[ENV_PREFIX]]_INSTALL_VIA  Set to "git" to force the git-clone fallback path
#   [[ADDITIONAL_ENV_DOCS]]
#
set -euo pipefail

REPO_OWNER="[[REPO_OWNER]]"
REPO_NAME="[[REPO_NAME]]"
REPO_URL="https://github.com/${REPO_OWNER}/${REPO_NAME}.git"
RELEASES_API="https://api.github.com/repos/${REPO_OWNER}/${REPO_NAME}/releases"

INSTALL_DIR="${[[ENV_PREFIX]]_INSTALL_DIR:-[[INSTALL_DIR_DEFAULT]]}"
SUBDIR="[[SUBDIR]]"
[[ENV_PREFIX]]_HOME="${INSTALL_DIR}/${SUBDIR}"
WRAPPER_BIN="[[WRAPPER_BIN]]"
TAG_PREFIX="[[TAG_PREFIX]]"

INSTALL_VIA="${[[ENV_PREFIX]]_INSTALL_VIA:-artifact}"  # "artifact" or "git"

MODE="install"
[[ "${1:-}" == "--update" || "${1:-}" == "update" ]] && MODE="update"

# ─── Colour helpers ──────────────────────────────────────────────────────────
RED='\033[0;31m'; YEL='\033[0;33m'; GRN='\033[0;32m'; CYN='\033[0;36m'
BLD='\033[1m'; RST='\033[0m'
info()  { echo -e "${CYN}==>${RST} $*"; }
ok()    { echo -e "${GRN}  ✓${RST} $*"; }
warn()  { echo -e "${YEL}  ⚠${RST}  $*"; }
err()   { echo -e "${RED}  ✗${RST}  $*" >&2; }
fatal() { err "$*"; exit 1; }
hr()    { echo "──────────────────────────────────────────────────────────────────────────────"; }

# ─── Root check ──────────────────────────────────────────────────────────────
[[ $EUID -eq 0 ]] || fatal "This script must be run as root.  Use: sudo bash get.sh"

# ─── OS check ────────────────────────────────────────────────────────────────
[[ "$(uname -s)" == "Linux" ]] || fatal "[[PROJECT_NAME]] requires Linux."

# ─── Dependency check ────────────────────────────────────────────────────────
for dep in curl [[REQUIRED_DEPS]]; do
    command -v "$dep" &>/dev/null \
        || fatal "Required tool not found: $dep.  Install it and re-run."
done

# sha256sum is required for artifact verification (S6.2 — non-optional)
command -v sha256sum &>/dev/null \
    || fatal "sha256sum not found (install coreutils).  Alternatively, use [[ENV_PREFIX]]_INSTALL_VIA=git."

# python3 is used for the semver resolver (one-liner, no deps needed)
command -v python3 &>/dev/null \
    || fatal "python3 not found.  Install it and re-run, or use [[ENV_PREFIX]]_INSTALL_VIA=git."

# ─── Resolve the target tag from GitHub Releases API ─────────────────────────
# Fetches the releases JSON and picks the highest-semver [[TAG_PREFIX]]* tag.
# Pure curl + python3 (no jq dependency).
resolve_latest_tag_api() {
    local json
    json="$(curl -fsSL --retry 3 --retry-delay 2 \
        -H "Accept: application/vnd.github+json" \
        "${RELEASES_API}?per_page=100" 2>/dev/null)" \
        || { warn "Could not reach GitHub API."; return 1; }
    python3 - "$json" <<'PYEOF'
import sys, json

data = json.loads(sys.argv[1])
prefix = "[[TAG_PREFIX]]"

def semver_key(tag):
    ver = tag[len(prefix):]
    parts = []
    for chunk in ver.replace("-", ".").split("."):
        parts.append((0, int(chunk)) if chunk.isdigit() else (1, chunk))
    return tuple(parts)

candidates = [
    r["tag_name"]
    for r in data
    if isinstance(r, dict)
       and r.get("tag_name", "").startswith(prefix)
       and not r.get("draft")
]

if not candidates:
    sys.exit(1)

print(max(candidates, key=semver_key))
PYEOF
}

# Fallback: resolve via git ls-remote (no API token needed, but requires git)
resolve_latest_tag_git() {
    command -v git &>/dev/null || return 1
    git ls-remote --tags --sort=-v:refname "$REPO_URL" \
            "refs/tags/${TAG_PREFIX}*" \
        2>/dev/null \
        | awk '{print $2}' \
        | grep -v '\^{}' \
        | head -1 \
        | sed 's|refs/tags/||'
}

resolve_latest_tag() {
    local tag
    tag="$(resolve_latest_tag_api 2>/dev/null)" && [[ -n "$tag" ]] && echo "$tag" && return 0
    warn "GitHub API unavailable; falling back to git ls-remote..."
    tag="$(resolve_latest_tag_git)" && [[ -n "$tag" ]] && echo "$tag" && return 0
    return 1
}

# ─── Download + verify artifact ──────────────────────────────────────────────
download_and_verify() {
    local tag="$1" workdir="$2"
    local asset_name="${tag}[[ASSET_SUFFIX]]"
    local sidecar_name="${asset_name}.sha256"
    local dl_base="https://github.com/${REPO_OWNER}/${REPO_NAME}/releases/download/${tag}"

    info "Downloading ${asset_name} ..."
    curl -fsSL --retry 3 --retry-delay 2 \
        -o "${workdir}/${asset_name}" \
        "${dl_base}/${asset_name}" \
        || fatal "Download failed: ${dl_base}/${asset_name}"

    info "Downloading ${sidecar_name} ..."
    curl -fsSL --retry 3 --retry-delay 2 \
        -o "${workdir}/${sidecar_name}" \
        "${dl_base}/${sidecar_name}" \
        || fatal "Download failed: ${dl_base}/${sidecar_name}"

    info "Verifying SHA256 checksum..."
    (cd "$workdir" && sha256sum -c "$sidecar_name") \
        || fatal "SHA256 mismatch on ${asset_name} — refusing to install.  Download may be corrupt or tampered."
    ok "Checksum verified."
}

# ─── Write the installed CLI wrapper ─────────────────────────────────────────
write_wrapper() {
    install -m 755 "${[[ENV_PREFIX]]_HOME}/[[WRAPPER_SCRIPT_REL]]" "$WRAPPER_BIN"
    sed -i "s|^[[ENV_PREFIX]]_HOME=.*|[[ENV_PREFIX]]_HOME=${[[ENV_PREFIX]]_HOME}|" "$WRAPPER_BIN"
    ok "CLI wrapper installed: $WRAPPER_BIN"
}

# ─── Git-clone install (fallback for air-gapped / dev installs) ──────────────
# Activated by: [[ENV_PREFIX]]_INSTALL_VIA=git
# No checksum verification — you are trusting the git transport.
git_install() {
    local tag="$1"
    command -v git &>/dev/null || fatal "git not found (required for git-clone fallback)."

    info "Git-clone install: ${tag}"
    if [[ -d "${INSTALL_DIR}/.git" ]]; then
        info "Updating existing clone..."
        git -C "$INSTALL_DIR" fetch --tags --quiet
        git -C "$INSTALL_DIR" checkout --quiet "$tag"
    else
        git clone \
            --filter=blob:none \
            --sparse \
            --quiet \
            "$REPO_URL" \
            "$INSTALL_DIR"
        git -C "$INSTALL_DIR" sparse-checkout set "$SUBDIR"
        git -C "$INSTALL_DIR" fetch --tags --quiet
        git -C "$INSTALL_DIR" checkout --quiet "$tag"
    fi
}

# ─── Artifact-based install ───────────────────────────────────────────────────
artifact_install() {
    local tag="$1"
    local workdir
    workdir="$(mktemp -d)"
    trap 'rm -rf "$workdir"' EXIT

    download_and_verify "$tag" "$workdir"

    info "Extracting to ${[[ENV_PREFIX]]_HOME} ..."
    mkdir -p "${[[ENV_PREFIX]]_HOME}"
    tar -xJf "${workdir}/${tag}[[ASSET_SUFFIX]]" \
        --strip-components=1 \
        -C "${[[ENV_PREFIX]]_HOME}"
    ok "Extracted."

    echo "${tag#${TAG_PREFIX}}" > "${[[ENV_PREFIX]]_HOME}/VERSION"
}

# ─── INSTALL ─────────────────────────────────────────────────────────────────
do_install() {
    hr
    echo -e "  ${BLD}[[PROJECT_NAME]]${RST}  ·  get.sh"
    hr

    if [[ -d "${[[ENV_PREFIX]]_HOME}" && -f "${[[ENV_PREFIX]]_HOME}/VERSION" ]]; then
        warn "Existing install found at ${[[ENV_PREFIX]]_HOME} — running update instead."
        do_update
        return
    fi

    local TARGET_TAG
    if [[ -n "${[[ENV_PREFIX]]_VERSION:-}" ]]; then
        if [[ "${[[ENV_PREFIX]]_VERSION}" == ${TAG_PREFIX}* ]]; then
            TARGET_TAG="${[[ENV_PREFIX]]_VERSION}"
        else
            TARGET_TAG="${TAG_PREFIX}${[[ENV_PREFIX]]_VERSION#v}"
        fi
        info "Pinned version: ${BLD}${TARGET_TAG}${RST}"
    else
        info "Resolving latest release..."
        TARGET_TAG="$(resolve_latest_tag)" \
            || fatal "Could not resolve latest [[PROJECT_NAME]] release.  Check network access or set [[ENV_PREFIX]]_VERSION."
        [[ -n "$TARGET_TAG" ]] \
            || fatal "No [[PROJECT_NAME]] releases found.  Publish a '${TAG_PREFIX}*' release first."
        info "Latest release: ${BLD}${TARGET_TAG}${RST}"
    fi

    mkdir -p "$INSTALL_DIR"

    if [[ "$INSTALL_VIA" == "git" ]]; then
        warn "Using git-clone fallback ([[ENV_PREFIX]]_INSTALL_VIA=git).  No checksum verification."
        git_install "$TARGET_TAG"
    else
        artifact_install "$TARGET_TAG"
    fi

    write_wrapper

    hr
    ok "[[PROJECT_NAME]] ${TARGET_TAG} installed."
    echo
    echo "  Next step:"
[[NEXT_STEPS_MSG]]
    echo
}

# ─── UPDATE ──────────────────────────────────────────────────────────────────
do_update() {
    [[ -d "${[[ENV_PREFIX]]_HOME}" && -f "${[[ENV_PREFIX]]_HOME}/VERSION" ]] \
        || fatal "No install found at ${[[ENV_PREFIX]]_HOME}.  Run the bootstrap installer first."

    local CURRENT_VERSION CURRENT_TAG LATEST_TAG
    CURRENT_VERSION="$(cat "${[[ENV_PREFIX]]_HOME}/VERSION" 2>/dev/null || echo "unknown")"
    CURRENT_TAG="${TAG_PREFIX}${CURRENT_VERSION}"

    if [[ -n "${[[ENV_PREFIX]]_VERSION:-}" ]]; then
        if [[ "${[[ENV_PREFIX]]_VERSION}" == ${TAG_PREFIX}* ]]; then
            LATEST_TAG="${[[ENV_PREFIX]]_VERSION}"
        else
            LATEST_TAG="${TAG_PREFIX}${[[ENV_PREFIX]]_VERSION#v}"
        fi
        info "Pinned version: ${BLD}${LATEST_TAG}${RST}"
    else
        info "Resolving latest release..."
        LATEST_TAG="$(resolve_latest_tag)" \
            || fatal "Could not resolve latest [[PROJECT_NAME]] release.  Check network access or set [[ENV_PREFIX]]_VERSION."
        [[ -n "$LATEST_TAG" ]] || fatal "No [[PROJECT_NAME]] releases found."
    fi

    if [[ "$LATEST_TAG" == "$CURRENT_TAG" ]]; then
        ok "Already up to date (${LATEST_TAG})."
        return
    fi

    info "Updating ${CURRENT_TAG} → ${LATEST_TAG} ..."

    local cfg bak
    local BACKED_UP=()
[[PRESERVE_FILES_BLOCK]]

    if [[ "$INSTALL_VIA" == "git" ]]; then
        warn "Using git-clone fallback ([[ENV_PREFIX]]_INSTALL_VIA=git).  No checksum verification."
        git_install "$LATEST_TAG"
    else
        artifact_install "$LATEST_TAG"
    fi

    for cfg in "${BACKED_UP[@]}"; do
        bak="${cfg}.pre-update"
        [[ -f "$bak" ]] || continue
        if [[ ! -f "$cfg" ]]; then
            mv "$bak" "$cfg"
            info "Restored: $cfg"
        else
            rm -f "$bak"
        fi
    done

    write_wrapper

    ok "Updated to ${LATEST_TAG}."

    local RELEASE_NOTES
    RELEASE_NOTES="$(curl -fsSL --retry 2 \
        -H "Accept: application/vnd.github+json" \
        "https://api.github.com/repos/${REPO_OWNER}/${REPO_NAME}/releases/tags/${LATEST_TAG}" \
        2>/dev/null \
        | python3 -c "
import sys, json
data = json.load(sys.stdin)
body = data.get('body', '').strip()
if body:
    lines = body.splitlines()
    for line in lines[:20]:
        print(line)
    if len(lines) > 20:
        print('...(see GitHub for full release notes)')
" 2>/dev/null || true)"
    if [[ -n "$RELEASE_NOTES" ]]; then
        info "Release notes for ${LATEST_TAG}:"
        echo "$RELEASE_NOTES" | sed 's/^/    /'
    fi
    echo
}

# ─── Dispatch ────────────────────────────────────────────────────────────────
case "$MODE" in
    install) do_install ;;
    update)  do_update ;;
esac

#!/usr/bin/env python3
"""[[PROJECT_NAME]] installer — get.py  (generated by cmru get-py)

Transactional installer: private-repo asset auth, atomic install/update/rollback
with a `current` symlink, system/user scope, bundled wheel install into a private
venv, SHA256 + minisign-signed-manifest verification before extraction.

Usage
-----
Install (system scope, requires root):
    sudo python3 get.py install --config HOST.toml

Install (user scope):
    python3 get.py install --config HOST.toml --scope user

Pin a specific version:
    sudo python3 get.py install --config HOST.toml --version [[TAG_PREFIX]]0.2.0

Select a variant (multi-variant releases — one asset per interpreter):
    sudo python3 get.py install --config HOST.toml --variant py311

Update:
    sudo python3 get.py update

Status:
    python3 get.py status

Rollback:
    sudo python3 get.py rollback

Requires: python3 (stdlib only); system tools: [[REQUIRED_COMMANDS_STR]]
"""
from __future__ import annotations

import argparse
import fcntl
import glob as _glob
import hashlib
import json
import os
import platform
import re
import shutil
import signal
import subprocess
import sys
import tarfile
import tempfile
import urllib.error
import urllib.parse
import urllib.request
from pathlib import Path
from typing import List, Optional, Tuple

# ─── Project constants (injected by cmru get-py) ─────────────────────────────
REPO_OWNER       = "[[REPO_OWNER]]"
REPO_NAME        = "[[REPO_NAME]]"
TAG_PREFIX       = "[[TAG_PREFIX]]"
ASSET_SUFFIX     = "[[ASSET_SUFFIX]]"
MANIFEST_NAME    = "[[MANIFEST_NAME]]"
SIGNATURE_NAME   = "[[SIGNATURE_NAME]]"
ENTRYPOINT       = "[[ENTRYPOINT]]"           # "" means no adapter
REQUIRED_COMMANDS: List[str] = [[REQUIRED_COMMANDS_LIST]]
PRESERVE_PATHS: List[str]    = [[PRESERVE_PATHS_LIST]]
WHEEL_SPECS: List[Tuple[str, str]] = [[WHEEL_SPECS_LIST]]  # [(glob, distribution), ...]
# Per-interpreter variants (S-REL.6). [] ⇒ single-asset release (legacy path, unchanged).
# When non-empty the release carries one asset per variant, named <tag>-<name><suffix>,
# and the operator MUST select one at install time with --variant NAME (no silent default).
VARIANTS: List[dict] = [[VARIANTS_LIST]]  # e.g. [{"name": "py39", "label": "Python 3.9"}, ...]

# Scope directories (injected)
INSTALL_DIR_SYSTEM = "[[INSTALL_DIR_SYSTEM]]"
INSTALL_DIR_USER   = "[[INSTALL_DIR_USER]]"   # leaf; expanded under XDG_DATA_HOME

RELEASES_API = f"https://api.github.com/repos/{REPO_OWNER}/{REPO_NAME}/releases"

# Allowed hosts for HTTPS downloads (transport hardening S5)
_ALLOWED_HOSTS = {
    "api.github.com",
    "github.com",
    "objects.githubusercontent.com",
    "uploads.github.com",
}

# ─── Exit codes (S8 / CIU S10.3) ─────────────────────────────────────────────
EXIT_OK     = 0
EXIT_FAIL   = 1   # download / verify / install / adapter failure
EXIT_CONFIG = 2   # configuration / schema failure
EXIT_PREREQ = 3   # missing prerequisite / required env absent


# ─── ANSI helpers (suppressed when not a TTY) ────────────────────────────────
_NO_COLOUR = not sys.stdout.isatty()
_C = {"RED": "\033[0;31m", "YEL": "\033[0;33m", "GRN": "\033[0;32m",
      "CYN": "\033[0;36m", "BLD": "\033[1m",    "RST": "\033[0m"}


def _c(code: str, text: str) -> str:
    return text if _NO_COLOUR else f"{_C[code]}{text}{_C['RST']}"


def info(msg: str)  -> None: print(f"{_c('CYN', '==>')} {msg}", flush=True)
def ok(msg: str)    -> None: print(f"{_c('GRN', '  ok')} {msg}", flush=True)
def warn(msg: str)  -> None: print(f"{_c('YEL', 'warn')} {msg}", file=sys.stderr, flush=True)
def err(msg: str)   -> None: print(f"{_c('RED', ' err')} {msg}", file=sys.stderr, flush=True)
def hr()            -> None: print("─" * 79)


def fatal(msg: str, code: int = EXIT_FAIL) -> None:
    err(msg)
    raise SystemExit(code)


# ─── Token / auth helpers (S5) ───────────────────────────────────────────────

def _validate_token_file(path: Path) -> None:
    """Reject token files with bad permissions or foreign owner."""
    if not path.exists():
        fatal(f"Token file not found: {path}", EXIT_CONFIG)
    if path.is_symlink():
        real = path.resolve()
        if not real.exists():
            fatal(f"Token file symlink broken: {path}", EXIT_CONFIG)
    st = path.stat()
    if st.st_mode & 0o077:
        fatal(
            f"Token file {path} has loose permissions ({oct(st.st_mode & 0o777)}); "
            "chmod 600 it.", EXIT_CONFIG
        )
    if st.st_uid != os.getuid():
        fatal(
            f"Token file {path} is owned by uid {st.st_uid}, "
            f"not current user {os.getuid()}.",
            EXIT_CONFIG,
        )


def _resolve_token(args: argparse.Namespace) -> Optional[str]:
    """Resolve GitHub token: CLI arg > file/stdin > env (S5).

    Warns when --github-token is used (leaks via ps/shell history).
    Token is never logged in full.
    """
    token: Optional[str] = None

    # Lowest priority: env
    for env_var in ("CMRU_GITHUB_TOKEN", "GITHUB_TOKEN"):
        v = os.environ.get(env_var, "").strip()
        if v:
            token = v
            break

    # stdin
    if getattr(args, "github_token_stdin", False):
        line = sys.stdin.readline().strip()
        if line:
            token = line

    # file
    tok_file = getattr(args, "github_token_file", None)
    if tok_file:
        fp = Path(tok_file).expanduser()
        _validate_token_file(fp)
        line = fp.read_text().strip()
        if line:
            token = line

    # CLI arg (highest priority — warn)
    tok_arg = getattr(args, "github_token", None)
    if tok_arg:
        warn("--github-token leaks via shell history/process list; "
             "prefer --github-token-file or CMRU_GITHUB_TOKEN env var.")
        token = tok_arg

    return token or None


# ─── Transport hardening (S5) ─────────────────────────────────────────────────

def _check_url(url: str) -> None:
    """Reject http:// and unknown hosts."""
    parsed = urllib.parse.urlparse(url)
    if parsed.scheme != "https":
        fatal(f"HTTPS-only: refusing {parsed.scheme}:// URL: {url}", EXIT_FAIL)
    host = parsed.hostname or ""
    allowed = (
        host in _ALLOWED_HOSTS
        or host.endswith(".githubusercontent.com")
        or host.endswith(".github.com")
    )
    if not allowed:
        fatal(f"Host not in allowlist: {host}", EXIT_FAIL)


class _NoRedirectAuth(urllib.request.HTTPRedirectHandler):
    """Strip Authorization header before following cross-origin redirects (S5)."""

    def redirect_request(self, req, fp, code, msg, headers, newurl):  # type: ignore[override]
        new_req = super().redirect_request(req, fp, code, msg, headers, newurl)
        if new_req is not None:
            new_req.remove_header("Authorization")
            new_req.remove_header("authorization")
        return new_req


def _gh_request(
    url: str,
    *,
    token: Optional[str] = None,
    accept: str = "application/vnd.github+json",
    stream_to: Optional[Path] = None,
    timeout: int = 30,
) -> Tuple[int, bytes]:
    """Low-level GitHub request.

    Per S5 / release.py invariant: only sends Authorization when token is present.
    An empty 'Bearer ' header causes GitHub to 401 even on public repos.
    """
    _check_url(url)
    headers: dict = {"Accept": accept, "User-Agent": "[[PROJECT_NAME]]/get.py"}
    if token:
        headers["Authorization"] = f"Bearer {token}"
    req = urllib.request.Request(url, headers=headers)
    opener = urllib.request.build_opener(_NoRedirectAuth)
    try:
        with opener.open(req, timeout=timeout) as resp:
            if stream_to:
                with open(stream_to, "wb") as fh:
                    shutil.copyfileobj(resp, fh)
                return resp.status, b""
            return resp.status, resp.read()
    except urllib.error.HTTPError as exc:
        body = exc.read() if exc.fp else b""
        return exc.code, body
    except urllib.error.URLError as exc:
        fatal(f"Network error fetching {url}: {exc}", EXIT_FAIL)
        return 0, b""  # unreachable


def _gh_json(url: str, token: Optional[str] = None) -> object:
    status, body = _gh_request(url, token=token)
    if status in (401, 403):
        hint = " (token may be missing or expired)" if not token else ""
        fatal(f"GitHub API {status}{hint}: {url}", EXIT_FAIL)
    if status >= 400:
        fatal(
            f"GitHub API {status}: {url}\n"
            f"  {body.decode('utf-8', errors='replace')}",
            EXIT_FAIL,
        )
    return json.loads(body)


# ─── Tag / release resolution ─────────────────────────────────────────────────

def _semver_key(tag: str) -> tuple:
    ver = tag[len(TAG_PREFIX):]
    tokens: list = []
    for chunk in ver.replace("-", ".").split("."):
        for run in re.findall(r"\d+|\D+", chunk):
            tokens.append((0, int(run), "") if run.isdigit() else (1, 0, run))
    return tuple(tokens)


def resolve_latest_tag(token: Optional[str] = None) -> str:
    """Return the highest-semver [[TAG_PREFIX]]* release tag."""
    releases = _gh_json(f"{RELEASES_API}?per_page=100", token=token)
    assert isinstance(releases, list)
    candidates = [
        r["tag_name"] for r in releases
        if isinstance(r, dict)
        and r.get("tag_name", "").startswith(TAG_PREFIX)
        and not r.get("draft")
        and not r.get("prerelease")
    ]
    if not candidates:
        fatal(
            f"No [[PROJECT_NAME]] releases found (prefix: {TAG_PREFIX!r}). "
            "Check network access or pass --version.",
            EXIT_FAIL,
        )
    return max(candidates, key=_semver_key)


def normalize_tag(version_arg: str) -> str:
    if version_arg.startswith(TAG_PREFIX):
        return version_arg
    # Drop a single leading "v" prefix only — NOT str.lstrip('v'), which strips a
    # whole leading run of 'v' chars (so "v1.0.0" is fine but a hypothetical multi-'v'
    # or 'v'-initial token would be corrupted). Prefix-strip, not charset-strip.
    bare = version_arg[1:] if version_arg.startswith("v") else version_arg
    return f"{TAG_PREFIX}{bare}"


def _find_asset_by_name(assets: list, name: str) -> Optional[dict]:
    for a in assets:
        if a.get("name") == name:
            return a
    return None


# ─── Variant selection (S-REL.6 / S6.12) ──────────────────────────────────────

def _variant_names() -> List[str]:
    return [v["name"] for v in VARIANTS]


def _format_variants() -> str:
    lines = []
    for v in VARIANTS:
        label = v.get("label")
        lines.append(f"  - {v['name']}" + (f"  ({label})" if label else ""))
    return "\n".join(lines)


def _variant_marker_path(root: Path) -> Path:
    """Where the selected variant is remembered so `update` keeps the host's choice."""
    return root / "shared" / ".variant"


def _persist_variant(root: Path, variant: Optional[str]) -> None:
    if not variant:
        return
    marker = _variant_marker_path(root)
    marker.parent.mkdir(parents=True, exist_ok=True)
    marker.write_text(variant + "\n", encoding="utf-8")


def _installed_variant(root: Path) -> Optional[str]:
    """The variant recorded by the last install/update (None if single-asset / unset)."""
    marker = _variant_marker_path(root)
    if marker.exists():
        return marker.read_text(encoding="utf-8").strip() or None
    return None


def _select_variant(args: argparse.Namespace, root: Path) -> Optional[str]:
    """Resolve which per-interpreter variant to install/update (S6.12).

    Returns None for a single-asset release (VARIANTS empty) — the byte-for-byte legacy
    path. Otherwise, in priority order: an explicit --variant (validated); a variant
    remembered from a prior install (so `update` stays on the same interpreter); an
    interactive prompt on a TTY; else a fatal error listing the choices. No silent default.
    """
    if not VARIANTS:
        return None
    names = _variant_names()
    chosen = getattr(args, "variant", None)
    if chosen:
        if chosen not in names:
            fatal(f"Unknown --variant {chosen!r}. Available:\n{_format_variants()}", EXIT_CONFIG)
        return chosen
    marker = _variant_marker_path(root)
    if marker.exists():
        prev = marker.read_text(encoding="utf-8").strip()
        if prev in names:
            info(f"Using previously selected variant: {_c('BLD', prev)}")
            return prev
    if sys.stdin.isatty():
        info("This release ships multiple variants — choose one:")
        for i, v in enumerate(VARIANTS, 1):
            label = v.get("label")
            print(f"  {i}) {v['name']}" + (f"  ({label})" if label else ""))
        raw = input("Variant [name or number]: ").strip()
        if raw.isdigit() and 1 <= int(raw) <= len(VARIANTS):
            return VARIANTS[int(raw) - 1]["name"]
        if raw in names:
            return raw
        fatal(f"Invalid selection {raw!r}. Available:\n{_format_variants()}", EXIT_CONFIG)
    fatal(
        "This release ships multiple per-interpreter variants; none was selected.\n"
        f"Re-run with --variant NAME. Available variants:\n{_format_variants()}",
        EXIT_CONFIG,
    )
    return None  # unreachable (fatal raises)


# ─── Download (public or private) (S5) ────────────────────────────────────────

def _download_asset(tag: str, asset_name: str, dest: Path, token: Optional[str]) -> None:
    """Download a release asset — private path if token present, public URL otherwise."""
    if token:
        # Private path: resolve release → list assets → find by name → download by ID
        status, body = _gh_request(
            f"{RELEASES_API}/tags/{tag}", token=token
        )
        if status >= 400:
            fatal(f"Could not fetch release {tag} (HTTP {status})", EXIT_FAIL)
        rel = json.loads(body)
        assets = rel.get("assets", [])
        asset = _find_asset_by_name(assets, asset_name)
        if asset is None:
            fatal(
                f"Asset {asset_name!r} not found in release {tag}. "
                f"Available: {[a.get('name') for a in assets]}",
                EXIT_FAIL,
            )
        # Download by asset ID — strip auth before the redirect (S5)
        asset_url = (
            f"https://api.github.com/repos/{REPO_OWNER}/{REPO_NAME}"
            f"/releases/assets/{asset['id']}"
        )
        _gh_request(asset_url, token=token, accept="application/octet-stream",
                    stream_to=dest, timeout=300)
    else:
        url = (
            f"https://github.com/{REPO_OWNER}/{REPO_NAME}"
            f"/releases/download/{tag}/{asset_name}"
        )
        _gh_request(url, token=None, accept="application/octet-stream",
                    stream_to=dest, timeout=300)
    if not dest.exists() or dest.stat().st_size == 0:
        fatal(f"Download produced empty file: {dest}", EXIT_FAIL)


# ─── SHA256 + minisign verification (S4) ─────────────────────────────────────

def _sha256(path: Path) -> str:
    h = hashlib.sha256()
    with open(path, "rb") as f:
        for chunk in iter(lambda: f.read(65536), b""):
            h.update(chunk)
    return h.hexdigest()


def _verify_sha256(asset: Path, sidecar: Path) -> None:
    expected = sidecar.read_text().split()[0]
    actual   = _sha256(asset)
    if actual != expected:
        fatal(
            f"SHA256 mismatch — refusing to extract.\n"
            f"  expected: {expected}\n"
            f"  got:      {actual}",
            EXIT_FAIL,
        )
    ok("SHA256 checksum verified.")


def _verify_minisign(manifest: Path, sig: Path, pubkey_arg: str) -> None:
    """Verify manifest.json.minisig with minisign (S4) before extraction."""
    if pubkey_arg.startswith("/") or pubkey_arg.startswith("./") or pubkey_arg.endswith(".pub"):
        cmd = ["minisign", "-Vm", str(manifest), "-p", pubkey_arg]
    else:
        cmd = ["minisign", "-Vm", str(manifest), "-P", pubkey_arg]
    result = subprocess.run(cmd, capture_output=True, text=True)
    if result.returncode != 0:
        fatal(
            f"minisign signature verification FAILED for {manifest.name}:\n"
            f"  {result.stderr.strip()}",
            EXIT_FAIL,
        )
    ok("Manifest signature verified (minisign).")


def _extract_manifest_for_verify(bundle: Path, workdir: Path) -> Tuple[Path, Path]:
    """Extract only manifest + sig from bundle for pre-extraction verification."""
    import copy as _copy
    manifest_out = workdir / MANIFEST_NAME
    sig_out = workdir / SIGNATURE_NAME
    with tarfile.open(bundle, "r:xz") as tf:
        for member in tf.getmembers():
            parts = Path(member.name).parts
            rel = str(Path(*parts[1:])) if len(parts) >= 2 else member.name
            if rel in (MANIFEST_NAME, SIGNATURE_NAME):
                m = _copy.copy(member)
                m.name = rel
                kw: dict = {}
                if sys.version_info >= (3, 12):
                    kw["filter"] = "data"
                tf.extract(m, path=workdir, **kw)
    if not manifest_out.exists():
        fatal(
            f"Bundle does not contain {MANIFEST_NAME}; cannot verify signature.",
            EXIT_FAIL,
        )
    if not sig_out.exists():
        fatal(
            f"Bundle does not contain {SIGNATURE_NAME}; cannot verify signature.",
            EXIT_FAIL,
        )
    return manifest_out, sig_out


def download_and_verify(
    tag: str,
    workdir: Path,
    token: Optional[str],
    pubkey_arg: Optional[str],
    variant: Optional[str] = None,
) -> Path:
    """Download the bundle + sidecar; verify SHA256 + minisign; return bundle path.

    ``variant`` (S-REL.6) selects the per-interpreter asset ``<tag>-<variant>{suffix}``;
    ``None`` keeps the single-asset name ``<tag>{suffix}`` (legacy path, unchanged)."""
    asset_name   = f"{tag}-{variant}{ASSET_SUFFIX}" if variant else f"{tag}{ASSET_SUFFIX}"
    sidecar_name = f"{asset_name}.sha256"
    asset   = workdir / asset_name
    sidecar = workdir / sidecar_name

    info(f"Downloading {asset_name} ...")
    _download_asset(tag, asset_name, asset, token)

    info(f"Downloading {sidecar_name} ...")
    _download_asset(tag, sidecar_name, sidecar, token)

    info("Verifying SHA256 checksum ...")
    _verify_sha256(asset, sidecar)

    if pubkey_arg and MANIFEST_NAME:
        info(f"Extracting {MANIFEST_NAME} for signature verification ...")
        manifest_path, sig_path = _extract_manifest_for_verify(asset, workdir)
        info(f"Verifying {MANIFEST_NAME} with minisign ...")
        _verify_minisign(manifest_path, sig_path, pubkey_arg)
    elif MANIFEST_NAME and not pubkey_arg:
        warn(
            "No --manifest-pubkey provided; skipping minisign verification. "
            "Supply --manifest-pubkey for full chain-of-trust."
        )

    return asset


# ─── Extraction safety (S6.3) ─────────────────────────────────────────────────

_UNSAFE_TYPES = {tarfile.BLKTYPE, tarfile.CHRTYPE, tarfile.FIFOTYPE}


def _safe_member(member: tarfile.TarInfo, dest: Path) -> bool:
    """Return False (and warn) if member should be rejected (S6.3 safety rules)."""
    parts = Path(member.name).parts
    if member.name.startswith("/"):
        warn(f"Skipping absolute path: {member.name}")
        return False
    if ".." in parts:
        warn(f"Skipping path traversal: {member.name}")
        return False
    try:
        resolved = (dest / member.name).resolve()
        resolved.relative_to(dest.resolve())
    except ValueError:
        warn(f"Skipping escape path: {member.name}")
        return False
    if member.type in _UNSAFE_TYPES:
        warn(f"Skipping device/fifo node: {member.name}")
        return False
    if member.issym() or member.islnk():
        link_target = member.linkname or ""
        if link_target.startswith("/"):
            warn(f"Skipping absolute symlink: {member.name} -> {link_target}")
            return False
        if ".." in Path(link_target).parts:
            warn(f"Skipping traversal symlink: {member.name} -> {link_target}")
            return False
    return True


def _pre_scan_members(tf: tarfile.TarFile, dest: Path) -> List[tarfile.TarInfo]:
    """Pre-scan members, strip top-level dir component, reject unsafe entries."""
    import copy as _copy
    members = []
    for member in tf.getmembers():
        parts = Path(member.name).parts
        if len(parts) < 2:
            continue  # skip the top-level dir itself
        m = _copy.copy(member)
        m.name = str(Path(*parts[1:]))
        if _safe_member(m, dest):
            members.append(m)
    return members


def _extract_bundle(bundle: Path, staging: Path) -> None:
    """Extract bundle into staging dir with safety pre-scan + filter='data' (py>=3.12)."""
    staging.mkdir(parents=True, exist_ok=True)
    info(f"Extracting to {staging} ...")
    with tarfile.open(bundle, "r:xz") as tf:
        members = _pre_scan_members(tf, staging)
        kw: dict = {}
        if sys.version_info >= (3, 12):
            kw["filter"] = "data"
        tf.extractall(staging, members=members, **kw)
    ok("Extraction complete.")


# ─── Wheel verification + venv install (S4, S6.3) ────────────────────────────

def _verify_wheel_sha256(wheel_path: Path, manifest: dict, distribution: str) -> None:
    """Check wheel sha256 against manifest (S4 step 3) before pip install.

    Reads sha256 from the per-distribution entry in the manifest
    (manifest[distribution]['sha256']), matching SPEC B's Seam-3 schema.
    Distribution is the canonical package name (e.g. 'cmru', 'ciu').
    """
    dist_entry = manifest.get(distribution) or {}
    expected = dist_entry.get("sha256")
    if not expected:
        warn(f"No sha256 for distribution {distribution!r} in manifest; skipping wheel hash check.")
        return
    actual = _sha256(wheel_path)
    if actual != expected:
        fatal(
            f"Wheel SHA256 mismatch for {wheel_path.name} (distribution: {distribution!r}):\n"
            f"  expected: {expected}\n"
            f"  got:      {actual}",
            EXIT_FAIL,
        )
    ok(f"Wheel {wheel_path.name} ({distribution}) sha256 verified.")


def _install_wheels(staging: Path, venv_dir: Path, manifest: dict) -> None:
    """Create/update private venv and install bundled wheels (no-index)."""
    if not WHEEL_SPECS:
        return
    info(f"Setting up private venv at {venv_dir} ...")
    subprocess.run([sys.executable, "-m", "venv", str(venv_dir)], check=True)
    pip = venv_dir / "bin" / "pip"
    for glob_pat, distribution in WHEEL_SPECS:
        matches = sorted(staging.glob(glob_pat))
        if not matches:
            fatal(
                f"No wheel found in bundle for {distribution!r} (glob: {glob_pat!r})",
                EXIT_FAIL,
            )
        wheel_path = matches[-1]
        _verify_wheel_sha256(wheel_path, manifest, distribution)
        info(f"Installing {wheel_path.name} into venv ...")
        subprocess.run([str(pip), "install", "--no-index", str(wheel_path)], check=True)
        ok(f"Installed {distribution} from {wheel_path.name}.")


# ─── Adapter invocation (Seam 1 — S3.3) ──────────────────────────────────────

def _invoke_adapter(
    action: str,
    release_dir: Path,
    root: Path,
    venv_dir: Path,
    token: Optional[str] = None,
) -> None:
    """Invoke project adapter; non-zero exit aborts before the current swap (S3.3)."""
    if not ENTRYPOINT:
        return  # no adapter (tls-edge minimal path)
    adapter = release_dir / ENTRYPOINT
    if not adapter.exists():
        fatal(f"Adapter entrypoint not found: {adapter}", EXIT_FAIL)
    venv_python = venv_dir / "bin" / "python"
    config_path = root / "shared" / "host.toml"
    manifest_path = release_dir / MANIFEST_NAME
    cmd = [
        str(venv_python), str(adapter), action,
        "--release-root", str(release_dir),
        "--config", str(config_path),
        "--manifest", str(manifest_path),
    ]
    info(f"Invoking adapter: {action} ...")
    # Strip GitHub token from child environment (S5)
    child_env = {
        k: v for k, v in os.environ.items()
        if k not in ("GITHUB_TOKEN", "CMRU_GITHUB_TOKEN", "GITHUB_PUSH_PAT")
    }
    result = subprocess.run(cmd, env=child_env)
    if result.returncode != 0:
        fatal(
            f"Adapter exited {result.returncode} (action={action!r}); "
            "transaction aborted — current release unchanged.",
            EXIT_FAIL,
        )
    ok(f"Adapter {action} succeeded.")


# ─── Preserve / shared config (S3.2) ─────────────────────────────────────────

def _copy_preserve_to_shared(root: Path, src_release: Optional[Path] = None) -> None:
    """Copy preserved paths from current release into <root>/shared/."""
    shared = root / "shared"
    current = root / "current"
    source = src_release or (current.resolve() if current.exists() else None)
    if source is None or not source.is_dir():
        return
    for rel in PRESERVE_PATHS:
        src = source / rel
        dest = shared / rel
        if src.exists() and not src.is_symlink():
            dest.parent.mkdir(parents=True, exist_ok=True)
            if src.is_dir():
                if dest.exists():
                    shutil.rmtree(dest)
                shutil.copytree(src, dest)
            else:
                shutil.copy2(src, dest)
            ok(f"Preserved: {rel}")


def _restore_preserve_from_shared(root: Path, release_dir: Path) -> None:
    """Symlink preserved paths from shared/ into the new release dir."""
    shared = root / "shared"
    for rel in PRESERVE_PATHS:
        src = shared / rel
        if src.exists():
            dest = release_dir / rel
            dest.parent.mkdir(parents=True, exist_ok=True)
            if dest.exists() or dest.is_symlink():
                if dest.is_dir() and not dest.is_symlink():
                    shutil.rmtree(dest)
                else:
                    dest.unlink()
            dest.symlink_to(src)
            ok(f"Linked shared/{rel} into release.")


# ─── Scope resolution (S3.2) ─────────────────────────────────────────────────

def _root_dir(scope: str) -> Path:
    if scope == "system":
        return Path(INSTALL_DIR_SYSTEM)
    xdg = os.environ.get("XDG_DATA_HOME", "").strip()
    base = Path(xdg) if xdg else Path.home() / ".local" / "share"
    return base / INSTALL_DIR_USER


# ─── Exclusive lock + SIGINT/SIGTERM handler ─────────────────────────────────

_active_staging: Optional[Path] = None
_lock_fd: Optional[int] = None


def _cleanup_on_signal(sig: int, _frame: object) -> None:
    global _active_staging, _lock_fd
    if _active_staging and _active_staging.exists():
        shutil.rmtree(_active_staging, ignore_errors=True)
    if _lock_fd is not None:
        try:
            fcntl.flock(_lock_fd, fcntl.LOCK_UN)
            os.close(_lock_fd)
        except OSError:
            pass
    sys.exit(EXIT_FAIL)


signal.signal(signal.SIGINT, _cleanup_on_signal)
signal.signal(signal.SIGTERM, _cleanup_on_signal)


class _Lock:
    def __init__(self, root: Path) -> None:
        self._path = root / ".lock"

    def __enter__(self) -> "_Lock":
        global _lock_fd
        self._path.parent.mkdir(parents=True, exist_ok=True)
        _lock_fd = os.open(str(self._path), os.O_CREAT | os.O_WRONLY, 0o600)
        try:
            fcntl.flock(_lock_fd, fcntl.LOCK_EX | fcntl.LOCK_NB)
        except BlockingIOError:
            info("Another installer is running; waiting for lock ...")
            fcntl.flock(_lock_fd, fcntl.LOCK_EX)
        return self

    def __exit__(self, *_: object) -> None:
        global _lock_fd
        if _lock_fd is not None:
            fcntl.flock(_lock_fd, fcntl.LOCK_UN)
            os.close(_lock_fd)
            _lock_fd = None


# ─── Release management helpers ───────────────────────────────────────────────

def _current_version(root: Path) -> Optional[str]:
    cur = root / "current"
    if cur.is_symlink() and cur.exists():
        return cur.resolve().name
    return None


def _prune_old_releases(releases_dir: Path, keep: int = 2) -> None:
    """Keep the N most-recent release dirs; prune older ones."""
    entries = sorted(
        [d for d in releases_dir.iterdir()
         if d.is_dir() and not d.name.endswith(".staging")],
        key=lambda d: d.stat().st_mtime,
    )
    for old in entries[:-keep]:
        info(f"Pruning old release: {old.name}")
        shutil.rmtree(old, ignore_errors=True)


def _atomic_swap_current(root: Path, new_release: Path) -> None:
    """Atomic current swap: tmp symlink + os.replace (S6.3)."""
    current = root / "current"
    tmp_link = root / ".current.tmp"
    if tmp_link.is_symlink():
        tmp_link.unlink()
    os.symlink(new_release, tmp_link)
    os.replace(tmp_link, current)
    ok(f"current -> {new_release.name}")


def _finalize_staging(staging: Path, releases_dir: Path, tag: str) -> Path:
    final = releases_dir / tag
    if final.exists():
        shutil.rmtree(final)
    staging.rename(final)
    return final


def _load_manifest(release_dir: Path) -> dict:
    mf = release_dir / MANIFEST_NAME
    if MANIFEST_NAME and mf.exists():
        try:
            return json.loads(mf.read_text())
        except Exception:
            pass
    return {}


# ─── Commands ────────────────────────────────────────────────────────────────

def do_install(args: argparse.Namespace, token: Optional[str]) -> None:
    global _active_staging
    scope = getattr(args, "scope", "system")
    root = _root_dir(scope)
    releases_dir = root / "releases"
    venv_dir = root / "venv"
    shared_dir = root / "shared"

    hr()
    print(f"  {_c('BLD', '[[PROJECT_NAME]]')}  install  scope={scope}  root={root}")
    hr()

    if scope == "system" and os.geteuid() != 0:
        fatal("system-scope install requires root (sudo).", EXIT_PREREQ)

    current_ver = _current_version(root)
    if current_ver:
        warn(f"Existing install found ({current_ver}). Running update instead.")
        do_update(args, token)
        return

    if args.version:
        tag = normalize_tag(args.version)
        info(f"Pinned version: {_c('BLD', tag)}")
    else:
        info("Resolving latest release ...")
        tag = resolve_latest_tag(token)
        info(f"Latest: {_c('BLD', tag)}")

    variant = _select_variant(args, root)
    if variant:
        info(f"Variant: {_c('BLD', variant)}")

    shared_dir.mkdir(parents=True, exist_ok=True)
    releases_dir.mkdir(parents=True, exist_ok=True)
    _persist_variant(root, variant)

    with _Lock(root):
        staging = releases_dir / f"{tag}.staging"
        _active_staging = staging

        with tempfile.TemporaryDirectory() as tmp:
            bundle = download_and_verify(
                tag, Path(tmp), token, getattr(args, "manifest_pubkey", None), variant
            )
            _extract_bundle(bundle, staging)

        manifest = _load_manifest(staging)
        _install_wheels(staging, venv_dir, manifest)
        _restore_preserve_from_shared(root, staging)

        if ENTRYPOINT:
            _invoke_adapter("bootstrap", staging, root, venv_dir, token)

        release_dir = _finalize_staging(staging, releases_dir, tag)
        _active_staging = None
        _atomic_swap_current(root, release_dir)
        _prune_old_releases(releases_dir)

    hr()
    ok(f"[[PROJECT_NAME]] {tag} installed at {root}")
    print()


def do_update(args: argparse.Namespace, token: Optional[str]) -> None:
    global _active_staging
    scope = getattr(args, "scope", "system")
    root = _root_dir(scope)
    releases_dir = root / "releases"
    venv_dir = root / "venv"

    if scope == "system" and os.geteuid() != 0:
        fatal("system-scope update requires root (sudo).", EXIT_PREREQ)

    current_ver = _current_version(root)
    if not current_ver:
        fatal(
            f"No install found at {root}. Run 'python3 get.py install' first.",
            EXIT_FAIL,
        )

    if args.version:
        tag = normalize_tag(args.version)
        info(f"Pinned version: {_c('BLD', tag)}")
    else:
        info("Resolving latest release ...")
        tag = resolve_latest_tag(token)
        info(f"Latest: {_c('BLD', tag)}")

    variant = _select_variant(args, root)
    if variant:
        info(f"Variant: {_c('BLD', variant)}")

    # Nothing to do only when BOTH the version AND the selected variant already match
    # what is installed — otherwise `update --variant OTHER` at the current version must
    # re-install the other variant (S6.12), not be silently short-circuited.
    if tag == current_ver and variant == _installed_variant(root):
        ok(f"Already at {tag}. Nothing to do.")
        return

    info(f"Updating {current_ver} -> {tag} ...")
    _copy_preserve_to_shared(root)

    releases_dir.mkdir(parents=True, exist_ok=True)
    _persist_variant(root, variant)

    with _Lock(root):
        staging = releases_dir / f"{tag}.staging"
        _active_staging = staging

        with tempfile.TemporaryDirectory() as tmp:
            bundle = download_and_verify(
                tag, Path(tmp), token, getattr(args, "manifest_pubkey", None), variant
            )
            _extract_bundle(bundle, staging)

        manifest = _load_manifest(staging)
        _install_wheels(staging, venv_dir, manifest)
        _restore_preserve_from_shared(root, staging)

        if ENTRYPOINT:
            _invoke_adapter("apply", staging, root, venv_dir, token)

        release_dir = _finalize_staging(staging, releases_dir, tag)
        _active_staging = None
        _atomic_swap_current(root, release_dir)
        _prune_old_releases(releases_dir)

    ok(f"Updated to {tag}.")
    print()


def do_rollback(args: argparse.Namespace, token: Optional[str]) -> None:
    scope = getattr(args, "scope", "system")
    root = _root_dir(scope)
    releases_dir = root / "releases"
    venv_dir = root / "venv"

    if scope == "system" and os.geteuid() != 0:
        fatal("system-scope rollback requires root (sudo).", EXIT_PREREQ)

    current_ver = _current_version(root)

    if getattr(args, "version", None):
        target_tag = normalize_tag(args.version)
    else:
        if not releases_dir.exists():
            fatal("No releases directory found.", EXIT_FAIL)
        entries = sorted(
            [d for d in releases_dir.iterdir()
             if d.is_dir() and not d.name.endswith(".staging")],
            key=lambda d: d.stat().st_mtime,
        )
        prev = next((e for e in reversed(entries) if e.name != current_ver), None)
        if prev is None:
            fatal("No previous release to roll back to.", EXIT_FAIL)
        target_tag = prev.name

    target_dir = releases_dir / target_tag
    if not target_dir.exists():
        fatal(f"Release {target_tag} not found at {target_dir}.", EXIT_FAIL)

    info(f"Rolling back to {target_tag} ...")

    if ENTRYPOINT:
        _invoke_adapter("rollback", target_dir, root, venv_dir, token)

    _atomic_swap_current(root, target_dir)
    ok(f"Rolled back to {target_tag}.")


def do_status(args: argparse.Namespace) -> None:
    scope = getattr(args, "scope", "system")
    root = _root_dir(scope)
    releases_dir = root / "releases"

    current_ver = _current_version(root)
    if not current_ver:
        print(f"[[PROJECT_NAME]]: not installed at {root}")
        return

    print(f"[[PROJECT_NAME]] status  scope={scope}  root={root}")
    print(f"  current:  {current_ver}")

    if releases_dir.exists():
        entries = sorted(
            [d for d in releases_dir.iterdir()
             if d.is_dir() and not d.name.endswith(".staging")],
            key=lambda d: d.stat().st_mtime,
            reverse=True,
        )
        previous = [e.name for e in entries if e.name != current_ver]
        if previous:
            print(f"  previous: {', '.join(previous[:3])}")

    if ENTRYPOINT:
        venv_python = root / "venv" / "bin" / "python"
        current_dir = root / "current"
        cmd = [
            str(venv_python), str(current_dir / ENTRYPOINT), "health",
            "--release-root", str(current_dir),
            "--config", str(root / "shared" / "host.toml"),
            "--manifest", str(current_dir / MANIFEST_NAME),
        ]
        result = subprocess.run(cmd)
        if result.returncode == 0:
            ok("health check passed.")
        else:
            warn(f"health check exited {result.returncode}.")


# ─── Pre-flight checks (S3.1) ────────────────────────────────────────────────

def check_prerequisites() -> None:
    """Check required commands before any network I/O (S3.1 / S6.5)."""
    missing = [cmd for cmd in REQUIRED_COMMANDS if not shutil.which(cmd)]
    if missing:
        fatal(
            f"Required tools not found: {', '.join(missing)}. "
            "Install them and re-run.",
            EXIT_PREREQ,
        )


# ─── Entry point ─────────────────────────────────────────────────────────────

def main() -> None:
    if platform.system() != "Linux":
        fatal("[[PROJECT_NAME]] requires Linux.", EXIT_PREREQ)

    # Check prerequisites BEFORE any network I/O (S3.1)
    check_prerequisites()

    parser = argparse.ArgumentParser(
        prog="get.py",
        description="[[PROJECT_NAME]] transactional installer",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog=(
            "Examples:\n"
            "  sudo python3 get.py install --config HOST.toml\n"
            "  python3 get.py install --config HOST.toml --scope user\n"
            "  sudo python3 get.py update\n"
            "  python3 get.py status\n"
            "  sudo python3 get.py rollback\n"
        ),
    )

    # Auth flags (S5)
    tok_ex = parser.add_mutually_exclusive_group()
    tok_ex.add_argument(
        "--github-token", metavar="TOKEN",
        help="GitHub token (WARN: leaks via shell history/ps; prefer file or env)",
    )
    tok_ex.add_argument("--github-token-file", metavar="FILE",
                        help="File containing the GitHub token (chmod 600)")
    tok_ex.add_argument("--github-token-stdin", action="store_true",
                        help="Read GitHub token from stdin (first line)")
    parser.add_argument(
        "--manifest-pubkey", metavar="KEY_OR_FILE",
        help="minisign public key (base64) or path to .pub file for manifest verification",
    )

    subparsers = parser.add_subparsers(dest="command", required=True)

    p_install = subparsers.add_parser("install", help="Fresh install")
    p_install.add_argument("--config", metavar="HOST.toml", help="Host config file")
    p_install.add_argument("--version", metavar="TAG", help="Pin a specific release")
    p_install.add_argument("--scope", choices=["system", "user"], default="system",
                           help="Install scope (default: system)")
    p_install.add_argument("--variant", metavar="NAME",
                           help="Select a per-interpreter variant (multi-variant releases)")

    p_update = subparsers.add_parser("update", help="Update to latest (or --version)")
    p_update.add_argument("--version", metavar="TAG")
    p_update.add_argument("--scope", choices=["system", "user"], default="system")
    p_update.add_argument("--variant", metavar="NAME",
                          help="Override the remembered variant (multi-variant releases)")

    p_status = subparsers.add_parser("status", help="Show current/previous versions + health")
    p_status.add_argument("--scope", choices=["system", "user"], default="system")

    p_rollback = subparsers.add_parser("rollback", help="Re-point current to a previous release")
    p_rollback.add_argument("--version", metavar="TAG", help="Roll back to specific version")
    p_rollback.add_argument("--scope", choices=["system", "user"], default="system")

    args = parser.parse_args()
    token = _resolve_token(args)

    if args.command == "install":
        do_install(args, token)
    elif args.command == "update":
        do_update(args, token)
    elif args.command == "status":
        do_status(args)
    elif args.command == "rollback":
        do_rollback(args, token)
    else:
        parser.print_help()
        raise SystemExit(EXIT_CONFIG)


if __name__ == "__main__":
    main()

diff --git a/config/config_docker.go b/config/config_docker.go
index 95501e7..bf521a0 100644
--- a/config/config_docker.go
+++ b/config/config_docker.go
@@ -7,6 +7,7 @@ import (
 	"sort"
 	"strings"
 
+	"emperror.dev/errors"
 	"github.com/distribution/reference"
 	"github.com/docker/docker/api/types/container"
 	"github.com/docker/docker/api/types/registry"
@@ -91,6 +92,29 @@ type DockerConfiguration struct {
 	// remapping disabled
 	UsernsMode string `default:"" json:"userns_mode" yaml:"userns_mode"`
 
+	// CgroupParent sets the parent cgroup that every server and installer
+	// container is created under (Docker HostConfig.CgroupParent). When the
+	// Docker daemon uses the systemd cgroup driver this is the name of a
+	// systemd slice unit, e.g. "wings.slice". Leave blank (default) to keep
+	// Docker's normal placement, which is typically system.slice with the
+	// systemd cgroup driver.
+	//
+	// Placing all Wings-created containers under a dedicated, admin-managed
+	// slice allows cgroup v2 resource policy (memory.min/memory.low protection
+	// floors, memory.high/max ceilings, cpu.weight, io.weight) to be scoped to
+	// the game workload as a whole instead of being applied to system.slice.
+	//
+	// Requirements that are NOT validated beyond the ".slice" suffix check:
+	//   - The Docker daemon should be running with the systemd cgroup driver
+	//     (daemon.json: "exec-opts": ["native.cgroupdriver=systemd"]).
+	//   - The named slice unit should already be installed and loaded on the
+	//     host. If it is not, systemd silently creates a transient slice with
+	//     no resource properties instead of failing loudly: the cgroup path
+	//     will look correct while the intended guarantees are absent.
+	//   - Existing containers are NOT moved when this value changes; it only
+	//     affects containers created after Wings picks up the new config.
+	CgroupParent string `default:"" json:"cgroup_parent" yaml:"cgroup_parent"`
+
 	LogConfig struct {
 		Type   string            `default:"local" json:"type" yaml:"type"`
 		Config map[string]string `default:"{\"max-size\":\"5m\",\"max-file\":\"1\",\"compress\":\"false\",\"mode\":\"non-blocking\"}" json:"config" yaml:"config"`
@@ -108,6 +132,36 @@ func (c DockerConfiguration) ContainerLogConfig() container.LogConfig {
 	}
 }
 
+// ValidateCgroupParent performs a best-effort sanity check on the configured
+// CgroupParent. Wings has no dependency on systemd and cannot confirm that the
+// referenced slice unit is actually loaded on the host -- Docker/runc surface
+// that class of error at container creation time when the cgroup driver is
+// systemd and the value is genuinely invalid. This only guards against
+// obviously wrong values (e.g. a cgroupfs-style path or an embedded control
+// character) being silently accepted.
+func (c DockerConfiguration) ValidateCgroupParent() error {
+	return ValidateCgroupParentValue(c.CgroupParent)
+}
+
+// ValidateCgroupParentValue is the standalone check used both for the
+// node-wide docker.cgroup_parent setting and for any per-server override
+// value. An empty value is valid and means "no parent configured".
+func ValidateCgroupParentValue(v string) error {
+	if v == "" {
+		return nil
+	}
+	if strings.ContainsAny(v, "\x00\n\r\t ") || strings.TrimSpace(v) != v {
+		return errors.New("cgroup parent must not contain whitespace or control characters: " + v)
+	}
+	if strings.Contains(v, "/") {
+		return errors.New("cgroup parent must be a systemd slice unit name, not a cgroupfs path: " + v)
+	}
+	if !strings.HasSuffix(v, ".slice") {
+		return errors.New("cgroup parent must end in \".slice\" (systemd cgroup driver naming convention): " + v)
+	}
+	return nil
+}
+
 // RegistryCredentialsForImage returns registry credentials for an image only
 // when the configured registry and image reference share the same registry
 // identity.
diff --git a/config/config_docker_cgroup_test.go b/config/config_docker_cgroup_test.go
new file mode 100644
index 0000000..98c933b
--- /dev/null
+++ b/config/config_docker_cgroup_test.go
@@ -0,0 +1,48 @@
+package config
+
+import "testing"
+
+func TestValidateCgroupParentValue(t *testing.T) {
+	tests := []struct {
+		name    string
+		value   string
+		wantErr bool
+	}{
+		{name: "empty is valid", value: "", wantErr: false},
+		{name: "simple slice", value: "wings.slice", wantErr: false},
+		{name: "custom slice", value: "gameservers.slice", wantErr: false},
+		{name: "dashed child slice", value: "wings-b87c0a5b.slice", wantErr: false},
+		{name: "missing suffix", value: "wings", wantErr: true},
+		{name: "wrong unit type", value: "wings.scope", wantErr: true},
+		{name: "cgroupfs absolute path", value: "/sys/fs/cgroup/wings.slice", wantErr: true},
+		{name: "nested path", value: "wings.slice/wings-a.slice", wantErr: true},
+		{name: "leading whitespace", value: " wings.slice", wantErr: true},
+		{name: "inner whitespace", value: "wings .slice", wantErr: true},
+		{name: "trailing newline", value: "wings.slice\n", wantErr: true},
+		{name: "embedded tab", value: "wings\t.slice", wantErr: true},
+	}
+
+	for _, tc := range tests {
+		t.Run(tc.name, func(t *testing.T) {
+			err := ValidateCgroupParentValue(tc.value)
+			if tc.wantErr && err == nil {
+				t.Errorf("expected an error for %q, got nil", tc.value)
+			}
+			if !tc.wantErr && err != nil {
+				t.Errorf("expected no error for %q, got: %v", tc.value, err)
+			}
+		})
+	}
+}
+
+func TestDockerConfigurationValidateCgroupParent(t *testing.T) {
+	if err := (DockerConfiguration{}).ValidateCgroupParent(); err != nil {
+		t.Errorf("empty CgroupParent should validate, got: %v", err)
+	}
+	if err := (DockerConfiguration{CgroupParent: "wings.slice"}).ValidateCgroupParent(); err != nil {
+		t.Errorf("wings.slice should validate, got: %v", err)
+	}
+	if err := (DockerConfiguration{CgroupParent: "not-a-slice"}).ValidateCgroupParent(); err == nil {
+		t.Error("expected an error for a value without the .slice suffix, got nil")
+	}
+}
diff --git a/environment/docker/container.go b/environment/docker/container.go
index f503af1..512d1a3 100644
--- a/environment/docker/container.go
+++ b/environment/docker/container.go
@@ -259,6 +259,12 @@ func (e *Environment) Create() error {
 		UsernsMode:  container.UsernsMode(cfg.Docker.UsernsMode),
 	}
 
+	// Place the container under the node-wide cgroup parent (systemd slice) if
+	// one is configured. See config.DockerConfiguration.CgroupParent.
+	if cfg.Docker.CgroupParent != "" {
+		hostConf.CgroupParent = cfg.Docker.CgroupParent
+	}
+
 	if _, err := e.client.ContainerCreate(ctx, conf, hostConf, nil, nil, e.Id); err != nil {
 		return errors.Wrap(err, "environment/docker: failed to create container")
 	}
diff --git a/server/install.go b/server/install.go
index 0d31d50..e513d71 100644
--- a/server/install.go
+++ b/server/install.go
@@ -450,6 +450,13 @@ func (ip *InstallationProcess) Execute() (string, error) {
 		UsernsMode:  container.UsernsMode(cfg.Docker.UsernsMode),
 	}
 
+	// Keep the installer container under the same cgroup parent as the server
+	// containers so that installation workloads are subject to the same
+	// slice-level resource policy. See config.DockerConfiguration.CgroupParent.
+	if cfg.Docker.CgroupParent != "" {
+		hostConf.CgroupParent = cfg.Docker.CgroupParent
+	}
+

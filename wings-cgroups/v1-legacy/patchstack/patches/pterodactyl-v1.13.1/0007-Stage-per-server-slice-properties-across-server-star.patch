+// With an explicit trigger the egg's early "done" must NOT end the phase.
+func TestExplicitTriggerOutranksTheDoneMatcher(t *testing.T) {
+	sliceTestConfig(t, true, "15m", "64G")
+	s := newSliceTestServer()
+	s.cfg.EnvVars = map[string]interface{}{
+		"WINGS_CG_STEADY_MATCH": `regex:registe server.*succeed`,
+	}
+	s.beginSlicePhase()
+	if !s.hasSliceMatcher() {
+		t.Fatal("an explicit trigger should be in effect")
+	}
+	// The Panel's running state arrives first and must be ignored.
+	s.onSliceStateChange("running")
+	if !s.hasSliceMatcher() || s.pinnedSlice() == "" {
+		t.Error("running state ended the phase despite an explicit trigger")
+	}
+	// A non-matching line changes nothing.
+	s.matchSliceSteady([]byte("Create Dungeon Successed"))
+	if s.pinnedSlice() == "" {
+		t.Error("a non-matching console line ended the phase")
+	}
+	// The trigger line ends it.
+	s.matchSliceSteady([]byte("[SERVER_LIST] try registe server ... succeed!"))
+	if s.pinnedSlice() != "" || s.hasSliceMatcher() {
+		t.Error("the trigger line did not end the startup phase")
+	}
+}

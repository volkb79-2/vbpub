+func TestCompileSliceMatch(t *testing.T) {
+	if m, err := compileSliceMatch(""); m != nil || err != nil {
+		t.Errorf("empty trigger = (%v, %v), want (nil, nil)", m, err)
+	}
+	// A bare string is a literal substring, so regex metacharacters in a game's
+	// log line cannot silently change what it matches.
+	m, err := compileSliceMatch("Create Dungeon (Successed)")
+	if err != nil {
+		t.Fatalf("literal: %v", err)
+	}
+	if !m.Match([]byte("xx Create Dungeon (Successed) yy")) {
+		t.Error("literal trigger should match as a substring")
+	}
+	if m.Match([]byte("Create Dungeon Successed")) {
+		t.Error("literal trigger must not be interpreted as a regex")
+	}
+	// regex: opts in, matching the Panel's own startup.done convention.
+	m, err = compileSliceMatch(`regex:SERVER_LIST.*registe server.*succeed`)
+	if err != nil {
+		t.Fatalf("regex: %v", err)
+	}
+	if !m.Match([]byte("[SERVER_LIST] try registe server ... succeed!")) {
+		t.Error("regex trigger should match the registration line")
+	}
+	if m.Match([]byte("Create Dungeon Successed")) {
+		t.Error("regex trigger must not match the earlier done line")
+	}
+	if _, err := compileSliceMatch("regex:[unterminated"); err == nil {
+		t.Error("a bad regex must report an error, not be silently ignored")
+	}
+}

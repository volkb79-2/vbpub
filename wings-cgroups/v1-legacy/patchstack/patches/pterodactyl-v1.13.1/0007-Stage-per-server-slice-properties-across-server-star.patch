+// Startup-phase overrides of the memory band. A game server's load-time peak
+// is routinely several times its steady working set — world generation and
+// asset streaming reach for everything at once — so a memory.high sized for
+// the steady state throttles exactly the phase that can least afford it.
+//
+// Worse, the damage is permanent. memory.min and memory.low only fend off
+// reclaim driven from OUTSIDE the cgroup, so reclaim a cgroup inflicts on
+// itself — by exceeding its own memory.high, or its own memory.max — ignores
+// them entirely. A ceiling below the load-time peak therefore evicts the
+// server straight through its own floor, and nothing pulls those pages back:
+// they return only when the workload faults them in again, one at a time.
+//
+// These variables state the band to apply while the server is still starting.
+// Wings replaces it with the steady band once the server reports ready, or
+// once the startup grace period expires. Only the memory band is staged:
+// cpu/io weights are work-conserving and cannot evict anything.
+const (
+	EnvStartupMemoryMin  = "WINGS_CG_STARTUP_MEMORY_MIN"
+	EnvStartupMemoryLow  = "WINGS_CG_STARTUP_MEMORY_LOW"
+	EnvStartupMemoryHigh = "WINGS_CG_STARTUP_MEMORY_HIGH"
+	EnvStartupMemoryMax  = "WINGS_CG_STARTUP_MEMORY_MAX"
+
+	// EnvSteadyMatch is a console line that ends the startup phase. Wings
+	// otherwise falls back to the egg's own startup "done" matcher, which marks
+	// the server "running" for the Panel — an event that for many games fires
+	// well before the world has finished loading. Where the two differ, this is
+	// the one that matters: applying the steady ceiling too early is what the
+	// startup band exists to prevent.
+	//
+	// A "regex:" prefix makes it a regular expression, matching the convention
+	// the Panel already uses for startup.done; anything else is a substring.
+	EnvSteadyMatch = "WINGS_CG_STEADY_MATCH"
+
+	// EnvStartupGrace overrides docker.per_server_slices.startup_grace for one
+	// server, because how long a world takes to load is a property of the game
+	// and its save, not of the node.
+	EnvStartupGrace = "WINGS_CG_STARTUP_GRACE"
+
+	// EnvPhaseEvents is an optional per-server list of console lines to record
+	// to the Panel activity log as they first appear, one "name=match" per
+	// line. name is a short slug; match is a substring, or a regular expression
+	// with a "regex:" prefix. It is purely informational — a way to surface a
+	// game's long, opaque startup ("steam update", "world load") to operators —
+	// and drives no cgroup behaviour. Empty = nothing recorded.
+	EnvPhaseEvents = "WINGS_CG_PHASE_EVENTS"
+)
+
+// Phase selects which property band a slice should carry.
+type Phase string
+
+const (
+	// PhaseStartup is applied before the container is created and holds until
+	// the server reports ready or the grace period expires.
+	PhaseStartup Phase = "startup"
+	// PhaseSteady is the normal operating band.
+	PhaseSteady Phase = "steady"
+)
+
 // BFQ weight bounds. BFQ keeps its own per-cgroup weight in io.bfq.weight on a
 // 1..1000 scale and does NOT read io.weight — that file belongs to the iocost
 // controller, which is inert unless io.cost.model/io.cost.qos are configured.
@@ -62,6 +121,40 @@ const (
 	BFQWeightDefault = 100
 )
 
+// rampMaxSteps caps how many memory.high writes a single ramp performs,
+// regardless of step size, so a tiny misconfigured step cannot turn into a
+// D-Bus write storm — the effective step is enlarged to fit this budget.
+const rampMaxSteps = 512
+
+// rampCeilings plans the descending sequence of memory.high values to walk a
+// ceiling from current usage `cur` down to `target` in steps of at most `step`
+// bytes, never more than rampMaxSteps writes. It returns nil when there is
+// nothing to walk (step 0, or cur already at/below target). The first element
+// is one step below cur — the span between an unset/high starting ceiling and
+// current usage is empty, so it need not be walked; the last element is exactly
+// target. Pure and deterministic, so the step/termination logic is unit-tested
+// without a live systemd.
+func rampCeilings(cur, target, step uint64) []uint64 {
+	if step == 0 || cur <= target {
+		return nil
+	}
+	span := cur - target
+	if n := (span + step - 1) / step; n > rampMaxSteps {
+		step = (span + rampMaxSteps - 1) / rampMaxSteps // enlarge to fit the budget
+	}
+	out := make([]uint64, 0, (span+step-1)/step)
+	high := cur
+	for high > target {
+		if high-target > step {
+			high -= step
+		} else {
+			high = target
+		}
+		out = append(out, high)
+	}
+	return out
+}
+
 // IOWeightFromBFQ inverts systemd's conversion, so an administrator can state
 // the BFQ weight they actually want instead of reverse-engineering the
 // IOWeight that happens to produce it. 900/9900 is exactly 1/11, so the round
@@ -124,6 +217,21 @@ func FormatSize(v uint64) string {
 	return strconv.FormatUint(v, 10)
 }
 
+// Equal reports whether two property sets request exactly the same thing,
+// including which properties are left unset. Compared structurally rather than
+// through String(), so the log format stays a logging concern.
+func (p Props) Equal(o Props) bool {
+	eq := func(a, b *uint64) bool {
+		if a == nil || b == nil {
+			return a == b
+		}
+		return *a == *b
+	}
+	return eq(p.MemoryMin, o.MemoryMin) && eq(p.MemoryLow, o.MemoryLow) &&
+		eq(p.MemoryHigh, o.MemoryHigh) && eq(p.MemoryMax, o.MemoryMax) &&
+		eq(p.CPUWeight, o.CPUWeight) && eq(p.IOWeight, o.IOWeight)
+}
+
 // String renders the requested properties for logs, naming each systemd
 // property (what Wings actually sets) and rendering memory sizes with the
 // binary suffix they were configured with, so a log line can be read against
@@ -239,6 +347,137 @@ func FromEnv(env []string) (props Props, errs []error) {
 	return props, errs
 }
 
+// StartupFromEnv extracts the startup-phase memory band overrides from a
+// resolved server environment. Like FromEnv, unparseable values are reported
+// and skipped rather than discarding the whole request.
+func StartupFromEnv(env []string) (props Props, errs []error) {
+	vals := map[string]string{}
+	for _, kv := range env {
+		k, v, ok := strings.Cut(kv, "=")
+		if !ok {
+			continue
+		}
+		switch k {
+		case EnvStartupMemoryMin, EnvStartupMemoryLow, EnvStartupMemoryHigh, EnvStartupMemoryMax:
+			vals[k] = v
+		}
+	}
+	set := func(name string, dst **uint64) {
+		s, ok := vals[name]
+		if !ok || s == "" {
+			return
+		}
+		v, err := ParseSize(s)
+		if err != nil {
+			errs = append(errs, errors.Wrap(err, name))
+			return
+		}
+		*dst = &v
+	}
+	set(EnvStartupMemoryMin, &props.MemoryMin)
+	set(EnvStartupMemoryLow, &props.MemoryLow)
+	set(EnvStartupMemoryHigh, &props.MemoryHigh)
+	set(EnvStartupMemoryMax, &props.MemoryMax)
+	return props, errs
+}
+
+// SteadyMatchFromEnv returns the per-server console matcher that ends the
+// startup phase, or "" when the server does not define one.
+func SteadyMatchFromEnv(env []string) string {
+	return envValue(env, EnvSteadyMatch)
+}
+
+// PhaseEvent is one informational console->activity mapping from
+// WINGS_CG_PHASE_EVENTS: a short name and the raw match string (with any
+// "regex:" prefix intact, for the caller to compile).
+type PhaseEvent struct {
+	Name  string
+	Match string
+}
+
+// PhaseEventsFromEnv parses WINGS_CG_PHASE_EVENTS into its entries, one
+// "name=match" per line. Blank lines and entries without a name or match are
+// skipped. Compilation of the match is left to the caller.
+func PhaseEventsFromEnv(env []string) []PhaseEvent {
+	raw := envValue(env, EnvPhaseEvents)
+	if raw == "" {
+		return nil
+	}
+	var out []PhaseEvent
+	for _, line := range strings.Split(raw, "\n") {
+		line = strings.TrimSpace(line)
+		if line == "" {
+			continue
+		}
+		name, match, ok := strings.Cut(line, "=")
+		name = strings.TrimSpace(name)
+		match = strings.TrimSpace(match)
+		if !ok || name == "" || match == "" {
+			continue
+		}
+		out = append(out, PhaseEvent{Name: name, Match: match})
+	}
+	return out
+}
+
+// StartupGraceFromEnv returns the per-server startup grace override. The bool
+// reports whether the server defined one at all; an unparseable value is
+// reported as an error so it can be logged and the node default used.
+func StartupGraceFromEnv(env []string) (time.Duration, bool, error) {
+	raw := envValue(env, EnvStartupGrace)
+	if raw == "" {
+		return 0, false, nil
+	}
+	d, err := time.ParseDuration(raw)
+	if err != nil {
+		return 0, true, errors.Wrap(err, EnvStartupGrace)
+	}
+	if d < 0 {
+		return 0, true, errors.New(EnvStartupGrace + " must not be negative")
+	}
+	return d, true, nil
+}
+
+func envValue(env []string, key string) string {
+	for _, kv := range env {
+		if k, v, ok := strings.Cut(kv, "="); ok && k == key {
+			return v
+		}
+	}
+	return ""
+}
+
+// StartupDefaults are the node-wide startup-phase memory band defaults. Empty
+// strings mean "no startup override": the steady value applies from the start,
+// which is the behaviour of a node that configures nothing here.
+type StartupDefaults struct {
+	MemoryMin  string
+	MemoryLow  string
+	MemoryHigh string
+	MemoryMax  string
+}
+
+// Props parses the startup defaults into a property set, reporting and
+// skipping invalid entries exactly as Defaults.Props does.
+func (d StartupDefaults) Props() (props Props, errs []error) {
+	size := func(name, raw string, dst **uint64) {
+		if raw == "" {
+			return
+		}
+		v, err := ParseSize(raw)
+		if err != nil {
+			errs = append(errs, errors.Wrap(err, name))
+			return
+		}
+		*dst = &v
+	}
+	size("startup_defaults.memory_min", d.MemoryMin, &props.MemoryMin)
+	size("startup_defaults.memory_low", d.MemoryLow, &props.MemoryLow)
+	size("startup_defaults.memory_high", d.MemoryHigh, &props.MemoryHigh)
+	size("startup_defaults.memory_max", d.MemoryMax, &props.MemoryMax)
+	return props, errs
+}
+
 // Defaults are node-wide slice property defaults, carried as the raw strings
 // and integers found in the Wings configuration. Zero values mean "no
 // default" for the respective property.

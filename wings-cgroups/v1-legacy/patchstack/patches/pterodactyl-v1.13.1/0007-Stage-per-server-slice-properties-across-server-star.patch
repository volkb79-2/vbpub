+func TestPerServerStartupGraceOverride(t *testing.T) {
+	sliceTestConfig(t, true, "15m", "64G")
+	for _, tt := range []struct {
+		raw  string
+		want time.Duration
+		set  bool
+	}{
+		{"30m", 30 * time.Minute, true},
+		{"", 0, false},
+		{"nonsense", 0, true}, // reported as an error, node default used
+	} {
+		d, set, err := cgroups.StartupGraceFromEnv([]string{"WINGS_CG_STARTUP_GRACE=" + tt.raw})
+		if tt.raw == "nonsense" {
+			if err == nil {
+				t.Error("an unparseable grace must report an error")
+			}
+			continue
+		}
+		if set != tt.set || d != tt.want {
+			t.Errorf("grace %q = (%v, %v), want (%v, %v)", tt.raw, d, set, tt.want, tt.set)
+		}
+	}
+}

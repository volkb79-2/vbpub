+// Placement is create-time only, so once a phase has begun the steady band
+// must target the slice that phase captured — not whatever the environment
+// resolves to later, which a Panel sync can change mid-startup.
+func TestSlicePhasePinsTheSliceItBeganWith(t *testing.T) {
+	sliceTestConfig(t, true, "15m", "64G")
+	s := newSliceTestServer()
+
+	if got := s.pinnedSlice(); got != "" {
+		t.Errorf("no phase in progress must pin nothing, got %q", got)
+	}
+	s.beginSlicePhase()
+	want := s.sliceRequest(cgroups.PhaseSteady).Slice
+	if got := s.pinnedSlice(); got != want {
+		t.Errorf("pinned slice = %q, want %q", got, want)
+	}
+	s.endSlicePhase()
+	if got := s.pinnedSlice(); got != "" {
+		t.Errorf("ended phase must clear the pin, got %q", got)
+	}
+}

+func TestPhaseEventsRecordOncePerLine(t *testing.T) {
+	sliceTestConfig(t, true, "15m", "64G")
+	s := newSliceTestServer()
+	s.cfg.EnvVars = map[string]interface{}{
+		"WINGS_CG_PHASE_EVENTS": "load=regex:LogLoad: LoadMap:\nupdate=Checking for available updates",
+	}
+	s.beginPhaseEvents()
+
+	// A non-matching line records nothing; the matching line arms once.
+	s.matchPhaseEvents([]byte("noise"))
+	s.slicePhaseMu.Lock()
+	fired := 0
+	for _, e := range s.sliceEvents {
+		if e.fired {
+			fired++
+		}
+	}
+	s.slicePhaseMu.Unlock()
+	if fired != 0 {
+		t.Fatalf("nothing should have fired yet, %d did", fired)
+	}
+
+	s.matchPhaseEvents([]byte("[..] Checking for available updates..."))
+	s.matchPhaseEvents([]byte("[..] Checking for available updates...")) // repeat: no re-fire
+	s.matchPhaseEvents([]byte("LogLoad: LoadMap: /Game/X"))
+
+	s.slicePhaseMu.Lock()
+	defer s.slicePhaseMu.Unlock()
+	byName := map[string]bool{}
+	for _, e := range s.sliceEvents {
+		byName[e.name] = e.fired
+	}
+	if !byName["update"] || !byName["load"] {
+		t.Errorf("both events should have fired once: %+v", byName)
+	}
+}

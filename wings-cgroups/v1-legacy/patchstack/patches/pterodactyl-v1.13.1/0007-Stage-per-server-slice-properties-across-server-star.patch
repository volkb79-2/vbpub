 		return err
 	}
 
+	// The container is about to start, so this is the one moment where the
+	// startup band is both correct and bounded: the server will either report
+	// ready or hit the startup grace, and either way the steady band replaces
+	// this. Best-effort, like every other slice operation.
+	e.applySliceBand(ctx, cgroups.PhaseStartup, "server starting")
+
 	return nil
 }
 
+// applySliceBand re-ensures this server's slice with the given phase's
+// property band. A server without a Wings-managed slice is skipped.
+func (e *Environment) applySliceBand(ctx context.Context, phase cgroups.Phase, reason string) {
+	cfg := config.Get()
+	if !cfg.Docker.PerServerSlices.Enabled {
+		return
+	}
+	evs := e.Configuration.EnvironmentVariables()
+	parent, managed, err := cfg.Docker.ResolveServerCgroupParent(e.Id, evs)
+	if err != nil {
+		e.log().WithField("cgroup_parent", parent).WithError(err).Warn("environment/docker: rejected per-server cgroup parent override")
+	}
+	if !managed {
+		return
+	}
+	req := cfg.Docker.SliceEnsureRequest(e.Id, parent, evs, phase)
+	if !req.Staged() {
+		// Nothing staged: the band applied at container create is already the
+		// steady one, so this would rewrite identical properties.
+		return
+	}
+	cgroups.EnsureForServer(ctx, e.log(), req, reason)
+}
+
 // Start will start the server environment and begins piping output to the event
 // listeners for the console. If a container does not exist, or needs to be
 // rebuilt that will happen in the call to OnBeforeStart().

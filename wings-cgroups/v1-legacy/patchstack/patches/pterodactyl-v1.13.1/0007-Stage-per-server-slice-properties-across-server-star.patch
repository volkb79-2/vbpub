+++ b/internal/cgroups/sysd.go
@@ -6,7 +6,9 @@ import (
 	"strconv"
 	"strings"
 	"sync"
+	"time"
 
+	"github.com/apex/log"
 	sdbus "github.com/coreos/go-systemd/v22/dbus"
 	godbus "github.com/godbus/dbus/v5"
 
@@ -294,6 +296,113 @@ func Ensure(ctx context.Context, name string, props Props, b Budget) (Result, er
 	return res, nil
 }
 
+// rampStepTimeout bounds how long a single ramp step waits for reclaim to
+// catch up before proceeding anyway. The ramp must reach its target even if
+// the workload refuses to yield (imposing the ceiling is the whole point), so
+// a stuck step falls through rather than blocking.
+const rampStepTimeout = 2 * time.Second
+
+// rampMaxDuration is a hard ceiling on a whole ramp, a backstop against a
+// pathological loop; a normal ramp of a few-GiB cold tail finishes in well
+// under a minute.
+const rampMaxDuration = 10 * time.Minute
+
+// memoryCurrent reads the slice's current memory usage (the MemoryCurrent unit
+// property) over D-Bus. systemd enables accounting implicitly once any Memory*
+// property is set, so this is valid for every slice this package manages. ok
+// is false when systemd reports it unavailable (MaxUint64) — treat as "unknown".
+func (c *conn) memoryCurrent(ctx context.Context, name string) (uint64, bool, error) {
+	p, err := c.dbus.GetUnitPropertyContext(ctx, name, "MemoryCurrent")
+	if err != nil {
+		return 0, false, err
+	}
+	v, ok := p.Value.Value().(uint64)
+	if !ok || v == ^uint64(0) {
+		return 0, false, nil
+	}
+	return v, true, nil
+}
+
+func (c *conn) setMemoryHigh(ctx context.Context, name string, v uint64) error {
+	return c.dbus.SetUnitPropertiesContext(ctx, name, true,
+		sdbus.Property{Name: "MemoryHigh", Value: godbus.MakeVariant(v)})
+}
+
+// rampHigh lowers memory.high on a slice to target, walking it down through the
+// sequence rampCeilings plans (steps of at most `step` bytes, capped count) and
+// pausing at each step until memory.current falls to the new ceiling so the
+// workload is throttled by at most about one step's overage per step. On the
+// per-step timeout it proceeds anyway — imposing the ceiling is the point — so
+// a workload that will not yield is walked to target gradually rather than in
+// one slam, bounded by rampMaxDuration.
+//
+// It holds a single D-Bus connection and stays on the systemd-owned channel
+// (SetUnitProperties runtime=true): the resting value survives daemon-reload and
+// no cgroupfs write is involved. step == 0 (or usage already at/below target)
+// applies the target in one shot.
+//
+// Only memory.high is walked. memory.max is a HARD limit and is applied at once
+// by the caller's base Ensure, so a steady memory.max staged below the load
+// peak would OOM the container regardless of this ramp — do not stage one there.
+func rampHigh(ctx context.Context, name string, target, step uint64, l *log.Entry) error {
+	ctx, cancel := context.WithTimeout(ctx, rampMaxDuration)
+	defer cancel()
+
+	c, err := connect(ctx)
+	if err != nil {
+		return err
+	}
+	defer c.close()
+
+	cur, ok, err := c.memoryCurrent(ctx, name)
+	if err != nil {
+		return err
+	}
+	ceilings := []uint64(nil)
+	if ok {
+		ceilings = rampCeilings(cur, target, step)
+	}
+	if len(ceilings) == 0 {
+		// Nothing to walk (one-shot config, usage already low, or accounting
+		// unavailable): drop straight to the target.
+		return c.setMemoryHigh(ctx, name, target)
+	}
+	for _, high := range ceilings {
+		if err := c.setMemoryHigh(ctx, name, high); err != nil {
+			return err
+		}
+		if high == target {
+			break
+		}
+		c.waitMemoryAtOrBelow(ctx, name, high)
+	}
+	l.WithField("slice", name).WithField("memory_high", FormatSize(target)).WithField("steps", len(ceilings)).
+		Info("cgroups: memory.high ramped to the steady ceiling")
+	return nil
+}
+
+// waitMemoryAtOrBelow polls memory.current until it is at most target, or
+// rampStepTimeout elapses, or ctx is done. Falling through on timeout is
+// deliberate — see rampHigh.
+func (c *conn) waitMemoryAtOrBelow(ctx context.Context, name string, target uint64) {
+	deadline := time.NewTimer(rampStepTimeout)
+	defer deadline.Stop()
+	tick := time.NewTicker(100 * time.Millisecond)
+	defer tick.Stop()
+	for {
+		if cur, ok, err := c.memoryCurrent(ctx, name); err != nil || (ok && cur <= target) {
+			return
+		}
+		select {
+		case <-ctx.Done():
+			return
+		case <-deadline.C:
+			return
+		case <-tick.C:
+		}
+	}
+}
+
 // Stop stops (and thereby removes) a slice unit. Stopping a transient slice
 // deletes it; stopping a unit-file-backed slice merely deactivates it until
 // its next start, so callers should only pass slices Wings itself derived.

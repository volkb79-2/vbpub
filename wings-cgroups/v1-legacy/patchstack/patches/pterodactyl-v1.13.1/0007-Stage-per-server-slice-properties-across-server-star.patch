diff --git a/server/slice_phase.go b/server/slice_phase.go
new file mode 100644
index 0000000..9bbbd0e
--- /dev/null
+++ b/server/slice_phase.go
@@ -0,0 +1,369 @@
+package server
+
+import (
+	"context"
+	"regexp"
+	"strconv"
+	"strings"
+	"time"
+
+	"github.com/apex/log"
+
+	"github.com/pterodactyl/wings/config"
+	"github.com/pterodactyl/wings/environment"
+	"github.com/pterodactyl/wings/internal/cgroups"
+	"github.com/pterodactyl/wings/internal/database"
+	"github.com/pterodactyl/wings/internal/models"
+)
+
+// Staged per-server slice properties.
+//
+// A game server's load-time peak routinely dwarfs its steady working set, and
+// a cgroup is not protected from reclaim it inflicts on itself (see the
+// package comment on internal/cgroups) — so a ceiling sized for the steady
+// state evicts the server through its own floor while it is still loading,
+// permanently, because nothing faults those pages back except the workload.
+//
+// Wings therefore applies the startup band before the container is created and
+// swaps in the steady band once the server is up. "Up" reuses the detection
+// Wings already performs: the egg's startup "done" matcher flips the
+// environment to the running state (see Server.onConsoleOutput), which reaches
+// us through OnStateChange. No new log scraping, and the trigger is per-egg
+// configuration that every game already carries.
+//
+// A grace timer bounds the startup band, because a ready line that never
+// matches — a broken egg, a game that changed its log format — must not leave
+// a server on startup properties forever.
+
+// Reasons name the trigger in every log line, so a server's phase transitions
+// are readable without correlating timestamps against console output.
+const (
+	sliceReasonReady = "server reported ready"
+	sliceReasonMatch = "steady match seen in console"
+	sliceReasonGrace = "startup grace expired"
+)
+
+// A note on delivery guarantees, because this design leans on them. Wings
+// dispatches each state-change event in its own goroutine (server/listeners.go)
+// and OnStateChange re-reads the current state rather than using the event
+// payload, so a fast starting -> running sequence can deliver "running" twice
+// and "starting" not at all. That is survivable here by construction: missing
+// "starting" only means no grace timer is armed, which matters solely when the
+// server never reaches "running" — and if it never reaches "running" after a
+// start, the startup band is the safer of the two to be holding. The terminal
+// states that replace the band are the ones delivered reliably.
+
+// beginSlicePhase starts the startup-grace timer for a server that has just
+// entered the starting state. It is a no-op when nothing stages the startup
+// band, or when no grace period is configured.
+func (s *Server) beginSlicePhase() {
+	cfg := config.Get()
+	if !cfg.Docker.PerServerSlices.Enabled {
+		return
+	}
+	// Nothing staged for this server: the band applied at container create is
+	// already the steady one, so there is nothing to swap in later.
+	req := s.sliceRequest(cgroups.PhaseSteady)
+	if !req.Staged() {
+		return
+	}
+	env := s.GetEnvironmentVariables()
+
+	// How long a world takes to load is a property of the game and its save,
+	// so the server may override the node default.
+	grace := cfg.Docker.SliceStartupGrace()
+	if d, set, err := cgroups.StartupGraceFromEnv(env); err != nil {
+		s.Log().WithError(err).Warn("cgroups: ignoring invalid per-server startup grace; using the node default")
+	} else if set {
+		grace = d
+	}
+
+	// An explicit matcher displaces the egg's "done" line as the trigger. That
+	// matters when "done" fires before the world has finished loading, which is
+	// exactly the case the startup band exists for.
+	matcher, err := compileSliceMatch(cgroups.SteadyMatchFromEnv(env))
+	if err != nil {
+		s.Log().WithError(err).Warn("cgroups: ignoring invalid " + cgroups.EnvSteadyMatch + "; falling back to the egg's startup done matcher")
+	}
+	s.slicePhaseMu.Lock()
+	defer s.slicePhaseMu.Unlock()
+	if s.slicePhaseTimer != nil {
+		s.slicePhaseTimer.Stop()
+	}
+	s.sliceSteadyDone = false
+	s.slicePhaseSlice = req.Slice // pinned for the whole phase, see enterSteady
+	s.slicePhaseMatch = matcher
+	s.slicePhaseTimer = nil
+	if grace > 0 {
+		s.slicePhaseTimer = time.AfterFunc(grace, func() {
+			s.Log().WithField("grace", grace.String()).
+				Warn("cgroups: startup grace expired without the steady trigger firing; applying steady slice properties")
+			s.enterSteady(sliceReasonGrace)
+		})
+	}
+	trigger := "the egg's startup done matcher"
+	if matcher != nil {
+		trigger = cgroups.EnvSteadyMatch + "=" + matcher.String()
+	}
+	s.Log().WithFields(log.Fields{"grace": grace.String(), "steady_trigger": trigger}).
+		Info("cgroups: startup slice properties in effect")
+}
+
+// enterSteady applies the steady band exactly once per start, whichever trigger
+// fires first — a console match, the running state, or the grace timer. The
+// idempotent guard is what makes the three triggers safe to race: an egg whose
+// steady matcher happens to appear before its "done"/running line would
+// otherwise emit two activity rows and apply the steady band twice.
+func (s *Server) enterSteady(reason string) {
+	s.slicePhaseMu.Lock()
+	if s.sliceSteadyDone {
+		s.slicePhaseMu.Unlock()
+		return
+	}
+	s.sliceSteadyDone = true
+	pinned := s.slicePhaseSlice // captured now; the apply runs on a goroutine
+	s.slicePhaseSlice = ""
+	if s.slicePhaseTimer != nil {
+		s.slicePhaseTimer.Stop()
+		s.slicePhaseTimer = nil
+	}
+	s.slicePhaseMatch = nil
+	s.slicePhaseMu.Unlock()
+
+	s.emitPhaseActivity("steady-reached", reason)
+	// Dispatched: OnStateChange runs crash detection after this, and a steady
+	// application is a D-Bus round trip plus a possible ramp — it must never sit
+	// in the state machine's path.
+	go s.applySliceProps(cgroups.PhaseSteady, reason, pinned)
+}
+
+// endSlicePhase resets all phase state; called when the server goes offline.
+func (s *Server) endSlicePhase() {
+	s.slicePhaseMu.Lock()
+	defer s.slicePhaseMu.Unlock()
+	if s.slicePhaseTimer != nil {
+		s.slicePhaseTimer.Stop()
+		s.slicePhaseTimer = nil
+	}
+	s.slicePhaseSlice = ""
+	s.slicePhaseMatch = nil
+	s.sliceSteadyDone = false
+}
+
+// sliceRequest resolves this server's slice and builds the ensure request for
+// the given phase. The zero request (empty Slice) means the server has no
+// Wings-managed slice and nothing should be applied.
+func (s *Server) sliceRequest(phase cgroups.Phase) cgroups.EnsureRequest {
+	cfg := config.Get()
+	if !cfg.Docker.PerServerSlices.Enabled {
+		return cgroups.EnsureRequest{}
+	}
+	env := s.GetEnvironmentVariables()
+	slice, managed, err := cfg.Docker.ResolveServerCgroupParent(s.ID(), env)
+	if err != nil {
+		s.Log().WithField("cgroup_parent", slice).WithError(err).
+			Warn("cgroups: rejected per-server cgroup parent override while applying slice properties")
+	}
+	if !managed {
+		return cgroups.EnsureRequest{}
+	}
+	return cfg.Docker.SliceEnsureRequest(s.ID(), slice, env, phase)
+}
+
+// hasSliceMatcher reports whether an explicit steady trigger is in effect for
+// the phase currently in progress.
+func (s *Server) hasSliceMatcher() bool {
+	s.slicePhaseMu.Lock()
+	defer s.slicePhaseMu.Unlock()
+	return s.slicePhaseMatch != nil
+}
+
+// matchSliceSteady is fed every console line while a startup phase is in
+// progress. The first line matching the server's steady trigger ends the
+// phase. Called from the console listener, so it must stay cheap and must
+// never block: the apply is dispatched.
+func (s *Server) matchSliceSteady(line []byte) {
+	s.slicePhaseMu.Lock()
+	m := s.slicePhaseMatch
+	s.slicePhaseMu.Unlock()
+	if m == nil || !m.Match(line) {
+		return
+	}
+	s.Log().WithFields(log.Fields{
+		"match":   m.String(),
+		"against": strconv.QuoteToASCII(string(line)),
+	}).Info("cgroups: steady trigger matched; leaving the startup band")
+	s.enterSteady(sliceReasonMatch)
+}
+
+// compileSliceMatch builds the steady trigger. A "regex:" prefix makes it a
+// regular expression, matching the convention the Panel uses for
+// startup.done; anything else is matched as a literal substring.
+func compileSliceMatch(raw string) (*regexp.Regexp, error) {
+	if raw == "" {
+		return nil, nil
+	}
+	if expr, ok := strings.CutPrefix(raw, "regex:"); ok {
+		return regexp.Compile(expr)
+	}
+	return regexp.Compile(regexp.QuoteMeta(raw))
+}
+
+// pinnedSlice returns the slice captured when this server's startup phase
+// began, or "" when no phase is in progress.
+func (s *Server) pinnedSlice() string {
+	s.slicePhaseMu.Lock()
+	defer s.slicePhaseMu.Unlock()
+	return s.slicePhaseSlice
+}
+
+// applySliceProps re-ensures this server's slice with the given phase's
+// property band. pinned is the slice captured when the phase began (see
+// enterSteady). Best-effort: a server that is already running is never
+// disturbed by a failure here.
+func (s *Server) applySliceProps(phase cgroups.Phase, reason, pinned string) {
+	req := s.sliceRequest(phase)
+	if req.Slice == "" {
+		return
+	}
+	// Placement is fixed when the container is created, so the container stays
+	// in whatever slice it was placed under even if the Panel later syncs a
+	// different WINGS_CGROUP_PARENT. Apply to the slice this phase began with,
+	// or the steady band lands on a unit holding nothing.
+	if pinned != "" && pinned != req.Slice {
+		s.Log().WithFields(log.Fields{"resolved": req.Slice, "applying_to": pinned}).
+			Warn("cgroups: server cgroup parent changed while starting; the container is still in the slice it was created under")
+		req.Slice = pinned
+		req.Budget.Exclude = pinned
+	}
+	// With no startup band staged, the properties set at container create are
+	// already the steady ones; re-applying them would cost a systemd round
+	// trip per server start and log a transition that did not happen.
+	if phase == cgroups.PhaseSteady && !req.Staged() {
+		return
+	}
+	// This runs on its own goroutine, where a panic takes the whole daemon
+	// with it, so do not assume a context exists.
+	ctx := s.Context()
+	if ctx == nil {
+		ctx = context.Background()
+	}
+	cgroups.EnsureForServer(ctx, s.Log(), req, reason)
+}
+
+// sliceConsoleEvent is one compiled WINGS_CG_PHASE_EVENTS entry plus whether it
+// has already been recorded (fire-once).
+type sliceConsoleEvent struct {
+	name  string
+	re    *regexp.Regexp
+	fired bool
+}
+
+// systemActivityIP is the source IP recorded for system-generated activity.
+// It must be a PARSEABLE address: the activity cron purges any row whose IP
+// fails net.ParseIP (a guard against a historical octet-truncation bug), so an
+// empty string would delete every phase event before it reached the Panel.
+// Loopback is the honest choice — the event originated on the node itself.
+const systemActivityIP = "127.0.0.1"
+
+// emitPhaseActivity records a per-server slice phase to the Panel activity log.
+// Best-effort and non-blocking (SaveActivity dispatches its own goroutine).
+func (s *Server) emitPhaseActivity(phase, detail string) {
+	s.Log().WithField("phase", phase).WithField("detail", detail).Info("cgroups: phase")
+	// The activity log needs the database; it is always initialised in a real
+	// Wings but not in unit tests, and SaveActivity dispatches its write on a
+	// goroutine where an unset handle would panic the daemon. Guard it.
+	if !database.Initialized() {
+		return
+	}
+	s.SaveActivity(s.NewRequestActivity("", systemActivityIP), ActivityCgroupPhase, models.ActivityMeta{
+		"phase":  phase,
+		"detail": detail,
+	})
+}
+
+// beginPhaseEvents compiles this server's WINGS_CG_PHASE_EVENTS once per start.
+// Gated on per-server slices being enabled node-wide, so a node not using this
+// feature never compiles or matches anything.
+func (s *Server) beginPhaseEvents() {
+	if !config.Get().Docker.PerServerSlices.Enabled {
+		return
+	}
+	env := s.GetEnvironmentVariables()
+	var evs []sliceConsoleEvent
+	for _, pe := range cgroups.PhaseEventsFromEnv(env) {
+		re, err := compileSliceMatch(pe.Match)
+		if err != nil || re == nil {
+			if err != nil {
+				s.Log().WithField("event", pe.Name).WithError(err).
+					Warn("cgroups: ignoring invalid " + cgroups.EnvPhaseEvents + " entry")
+			}
+			continue
+		}
+		evs = append(evs, sliceConsoleEvent{name: pe.Name, re: re})
+	}
+	s.slicePhaseMu.Lock()
+	s.sliceEvents = evs
+	s.sliceEventsSet = true
+	s.slicePhaseMu.Unlock()
+}
+
+// matchPhaseEvents records the first console line that matches each configured
+// informational phase event. Cheap and non-blocking; fed every console line.
+func (s *Server) matchPhaseEvents(line []byte) {
+	s.slicePhaseMu.Lock()
+	if !s.sliceEventsSet || len(s.sliceEvents) == 0 {
+		s.slicePhaseMu.Unlock()
+		return
+	}
+	var hit string
+	remaining := 0
+	for i := range s.sliceEvents {
+		e := &s.sliceEvents[i]
+		if e.fired {
+			continue
+		}
+		if hit == "" && e.re.Match(line) {
+			e.fired = true
+			hit = e.name
+			continue
+		}
+		remaining++
+	}
+	if remaining == 0 {
+		// All events have fired: stop matching every console line for the rest
+		// of the server's life.
+		s.sliceEventsSet = false
+	}
+	s.slicePhaseMu.Unlock()
+	if hit != "" {
+		s.emitPhaseActivity(hit, strings.TrimSpace(string(line)))
+	}
+}
+
+// onSliceStateChange drives the startup -> steady transition from the server's
+// own state machine.
+func (s *Server) onSliceStateChange(state string) {
+	switch state {
+	case environment.ProcessStartingState:
+		s.beginPhaseEvents()
+		s.beginSlicePhase()
+	case environment.ProcessRunningState:
+		// The egg's "done" matcher fired. When the server defines its own
+		// steady trigger this is deliberately NOT the end of the startup
+		// phase: "done" is whatever makes the Panel show Running, which for a
+		// world-streaming game is routinely well before loading finishes. Once
+		// that trigger has fired (or without one at all), enterSteady is the
+		// idempotent gate — a duplicate call here is a no-op.
+		if s.hasSliceMatcher() {
+			return
+		}
+		s.enterSteady(sliceReasonReady)
+	case environment.ProcessOfflineState:
+		s.endSlicePhase()
+		s.slicePhaseMu.Lock()
+		s.sliceEvents = nil
+		s.sliceEventsSet = false
+		s.slicePhaseMu.Unlock()
+	}
+}
diff --git a/server/slice_phase_test.go b/server/slice_phase_test.go
new file mode 100644
index 0000000..ba28966
--- /dev/null
+++ b/server/slice_phase_test.go
@@ -0,0 +1,325 @@
+package server
+
+import (
+	"context"
+	"testing"
+	"time"
+
+	"github.com/pterodactyl/wings/config"
+	"github.com/pterodactyl/wings/internal/cgroups"
+)
+
+// sliceTestConfig installs a per-server-slices configuration for these tests.
+//
+// It deliberately does NOT snapshot the previous configuration first:
+// config.Get() takes mu.RLock() and then dereferences a nil _config when no
+// configuration has been set, and its mu.RUnlock() is not deferred — so a
+// single Get() before the first Set() leaves the read lock held forever and
+// every later Set() deadlocks. Unit tests are exactly that situation.
+func sliceTestConfig(t *testing.T, enabled bool, grace string, startupHigh string) {
+	t.Helper()
+	var c config.Configuration
+	// config.Set derives the JWT signer from the token and panics on an empty
+	// HMAC key, so a non-empty placeholder is required.
+	c.AuthenticationToken = "slice-phase-test-token"
+	c.Docker.CgroupParent = "wings.slice"
+	c.Docker.PerServerSlices.Enabled = enabled
+	c.Docker.PerServerSlices.Defaults.MemoryHigh = "7G"
+	c.Docker.PerServerSlices.StartupDefaults.MemoryHigh = startupHigh
+	c.Docker.PerServerSlices.StartupGrace = grace
+	config.Set(&c)
+}
+
+// newSliceTestServer builds the minimum Server these tests need, including a
+// context: applySliceProps is dispatched onto a goroutine and would otherwise
+// panic on a nil parent.
+func newSliceTestServer() *Server {
+	ctx, cancel := context.WithCancel(context.Background())
+	s := &Server{ctx: ctx, ctxCancel: &cancel}
+	s.cfg.Uuid = "b87c0a5b-2387-4a1c-8863-ff23e6800a1d"
+	return s
+}
+
+func TestSliceStartupGraceParsing(t *testing.T) {
+	for _, tt := range []struct {
+		raw  string
+		want time.Duration
+	}{
+		{"15m", 15 * time.Minute},
+		{"90s", 90 * time.Second},
+		{"", 0},
+		{"0", 0},
+		{"garbage", 0}, // unreachable via config (validation rejects it first)
+		{"-5m", 0},
+	} {
+		sliceTestConfig(t, true, tt.raw, "64G")
+		if got := config.Get().Docker.SliceStartupGrace(); got != tt.want {
+			t.Errorf("startup_grace %q = %v, want %v", tt.raw, got, tt.want)
+		}
+	}
+}
+
+// The grace timer must not be armed when nothing is staged, or every server on
+// a node that does not use the feature gets a 15-minute timer and an eventual
+// spurious warning.
+func TestBeginSlicePhaseOnlyArmsWhenStaged(t *testing.T) {
+	s := newSliceTestServer()
+
+	sliceTestConfig(t, true, "15m", "") // no startup band configured
+	s.beginSlicePhase()
+	if s.slicePhaseTimer != nil {
+		t.Error("timer armed with no startup band staged")
+	}
+	s.endSlicePhase()
+
+	sliceTestConfig(t, true, "15m", "64G") // startup band configured
+	s.beginSlicePhase()
+	if s.slicePhaseTimer == nil {
+		t.Error("timer not armed despite a staged startup band")
+	}
+	s.endSlicePhase()
+
+	sliceTestConfig(t, false, "15m", "64G") // per-server slices disabled entirely
+	s.beginSlicePhase()
+	if s.slicePhaseTimer != nil {
+		t.Error("timer armed while per_server_slices is disabled")
+	}
+	s.endSlicePhase()
+
+	sliceTestConfig(t, true, "0", "64G") // grace disabled
+	s.beginSlicePhase()
+	if s.slicePhaseTimer != nil {
+		t.Error("timer armed with startup_grace disabled")
+	}
+	s.endSlicePhase()
+}
+
+func TestEndSlicePhaseIsIdempotent(t *testing.T) {
+	sliceTestConfig(t, true, "15m", "64G")
+	s := newSliceTestServer()
+
+	s.endSlicePhase() // nothing armed yet
+	s.beginSlicePhase()
+	s.endSlicePhase()
+	s.endSlicePhase()
+	if s.slicePhaseTimer != nil {
+		t.Error("timer should be nil after cancellation")
+	}
+	if s.sliceSteadyDone {
+		t.Error("a cancelled phase must not be marked steady-done")
+	}
+}
+
+// enterSteady must apply the steady band exactly once no matter how many
+// triggers fire — the guard against a matcher-before-running double-apply.
+func TestEnterSteadyIsIdempotent(t *testing.T) {
+	sliceTestConfig(t, true, "15m", "64G")
+	s := newSliceTestServer()
+	s.beginSlicePhase()
+	if s.pinnedSlice() == "" {
+		t.Fatal("precondition: a phase should be in progress")
+	}
+	s.enterSteady("match") // first trigger wins
+	if !s.sliceSteadyDone {
+		t.Fatal("first enterSteady must mark the phase steady-done")
+	}
+	if s.pinnedSlice() != "" || s.hasSliceMatcher() {
+		t.Error("entering steady must clear the pin and matcher")
+	}
+	// Subsequent triggers (running, grace) are no-ops.
+	s.enterSteady("running")
+	s.onSliceStateChange("running")
+	if !s.sliceSteadyDone {
+		t.Error("phase must stay steady-done")
+	}
+}
+
+// CleanupForDestroy must cancel the timer: its closure pins the whole *Server.
+func TestCleanupForDestroyCancelsSlicePhase(t *testing.T) {
+	sliceTestConfig(t, true, "15m", "64G")
+	s, err := New(nil)
+	if err != nil {
+		t.Fatalf("New: %v", err)
+	}
+	s.cfg.Uuid = "b87c0a5b-2387-4a1c-8863-ff23e6800a1d"
+	s.beginSlicePhase()
+	if s.slicePhaseTimer == nil {
+		t.Fatal("precondition: timer should be armed")
+	}
+	s.CleanupForDestroy()
+	if s.slicePhaseTimer != nil {
+		t.Error("CleanupForDestroy left the grace timer running")
+	}
+}

+// DockerSliceStartupDefaults is the startup-phase memory band. Only the memory
+// knobs are staged: cpu/io weights are work-conserving and cannot evict a
+// workload, so they have no startup/steady distinction.
+type DockerSliceStartupDefaults struct {
+	MemoryMin  string `default:"" json:"memory_min" yaml:"memory_min"`
+	MemoryLow  string `default:"" json:"memory_low" yaml:"memory_low"`
+	MemoryHigh string `default:"" json:"memory_high" yaml:"memory_high"`
+	MemoryMax  string `default:"" json:"memory_max" yaml:"memory_max"`
+}
+
 // PerServerSlicesConfiguration configures automatic per-server slice
 // management (docker.per_server_slices). Requires CgroupParent to be set:
 // derived slices nest under it via systemd dash naming.
@@ -191,6 +202,32 @@ type PerServerSlicesConfiguration struct {
 	// check.
 	MemoryMinBudget string `default:"" json:"memory_min_budget" yaml:"memory_min_budget"`
 
+	// StartupDefaults are the node-wide memory band applied to a derived slice
+	// while the server is still starting, replaced by Defaults once the server
+	// reports ready (the egg's startup "done" matcher) or StartupGrace
+	// expires. Empty fields mean "no startup override".
+	//
+	// This exists because a memory.high sized for the steady working set
+	// throttles the load-time peak, and a cgroup is not protected from reclaim
+	// it inflicts on itself — a ceiling below the peak evicts the server
+	// through its own floor, permanently. See internal/cgroups.
+	StartupDefaults DockerSliceStartupDefaults `json:"startup_defaults" yaml:"startup_defaults"`
+
+	// StartupGrace bounds how long the startup band may hold. A server whose
+	// ready line never matches — a broken egg, a game that changed its log
+	// format — must not keep the startup band forever, so the steady band is
+	// applied unconditionally once this elapses. Empty or "0" disables the
+	// timer, leaving the ready line as the only transition.
+	StartupGrace string `default:"15m" json:"startup_grace" yaml:"startup_grace"`
+
+	// SteadyRampStep, when set, walks a server's memory.high down to its steady
+	// ceiling in steps of at most this size instead of dropping it in one shot
+	// when the startup band gives way to the steady band. Sizes take the usual
+	// suffixes ("64M"). Empty or "0" = one-shot (the pre-ramp behaviour). Only
+	// the ceiling is stepped, and only when the steady ceiling is below current
+	// usage; the floor and everything else apply immediately.
+	SteadyRampStep string `default:"" json:"steady_ramp_step" yaml:"steady_ramp_step"`
+
 	// BudgetPolicy decides what happens to a MemoryMin request exceeding the
 	// remaining budget. Every other property is applied unchanged in all
 	// three cases:
@@ -391,6 +428,27 @@ func (c DockerConfiguration) ValidatePerServerSlices() error {
 	if _, errs := c.SliceDefaults().Props(); len(errs) > 0 {
 		return errors.Wrap(errs[0], "docker.per_server_slices.defaults")
 	}
+	if _, errs := c.SliceStartupDefaults().Props(); len(errs) > 0 {
+		return errors.Wrap(errs[0], "docker.per_server_slices.startup_defaults")
+	}
+	if raw := s.SteadyRampStep; raw != "" && raw != "0" {
+		v, err := cgroups.ParseSize(raw)
+		if err != nil {
+			return errors.Wrap(err, "docker.per_server_slices.steady_ramp_step")
+		}
+		if v < 1<<20 {
+			return errors.New("docker.per_server_slices.steady_ramp_step must be at least 1M (a smaller step just multiplies systemd writes for no benefit)")
+		}
+	}
+	if raw := s.StartupGrace; raw != "" {
+		d, err := time.ParseDuration(raw)
+		if err != nil {
+			return errors.Wrap(err, "docker.per_server_slices.startup_grace")
+		}
+		if d < 0 {
+			return errors.New("docker.per_server_slices.startup_grace must not be negative")
+		}
+	}
 	return nil
 }
 
@@ -412,14 +470,57 @@ func (c DockerConfiguration) SliceDefaults() cgroups.Defaults {
 // SliceEnsureRequest assembles the cgroups.EnsureForServer request for a
 // server whose containers are about to be placed under slice (a value
 // previously returned as managed by ResolveServerCgroupParent).
-func (c DockerConfiguration) SliceEnsureRequest(uuid, slice string, env []string) cgroups.EnsureRequest {
+func (c DockerConfiguration) SliceEnsureRequest(uuid, slice string, env []string, phase cgroups.Phase) cgroups.EnsureRequest {
 	return cgroups.EnsureRequest{
-		Slice:    slice,
-		Derived:  slice == c.ServerSliceName(uuid),
-		Defaults: c.SliceDefaults(),
-		Env:      env,
-		Budget:   c.SliceBudget(slice),
+		Slice:           slice,
+		Derived:         slice == c.ServerSliceName(uuid),
+		Phase:           phase,
+		Defaults:        c.SliceDefaults(),
+		StartupDefaults: c.SliceStartupDefaults(),
+		Env:             env,
+		Budget:          c.SliceBudget(slice),
+		RampStep:        c.sliceRampStep(),
+	}
+}
+
+// sliceRampStep parses docker.per_server_slices.steady_ramp_step into bytes.
+// Invalid or empty yields 0 (one-shot); a bad value is validated at startup.
+func (c DockerConfiguration) sliceRampStep() uint64 {
+	raw := c.PerServerSlices.SteadyRampStep
+	if raw == "" || raw == "0" {
+		return 0
+	}
+	if v, err := cgroups.ParseSize(raw); err == nil {
+		return v
+	}
+	return 0
+}
+
+// SliceStartupDefaults converts the configured startup-phase memory band into
+// the internal/cgroups representation.
+func (c DockerConfiguration) SliceStartupDefaults() cgroups.StartupDefaults {
+	d := c.PerServerSlices.StartupDefaults
+	return cgroups.StartupDefaults{
+		MemoryMin:  d.MemoryMin,
+		MemoryLow:  d.MemoryLow,
+		MemoryHigh: d.MemoryHigh,
+		MemoryMax:  d.MemoryMax,
+	}
+}
+
+// SliceStartupGrace returns how long the startup band may hold before the
+// steady band is applied regardless of whether the server reported ready.
+// Zero disables the timer.
+func (c DockerConfiguration) SliceStartupGrace() time.Duration {
+	raw := c.PerServerSlices.StartupGrace
+	if raw == "" {
+		return 0
+	}
+	d, err := time.ParseDuration(raw)
+	if err != nil || d < 0 {
+		return 0
 	}
+	return d
 }
 
 // SliceBudget converts the configured floor budget into the internal/cgroups

+// ResolveRamdiskUnits parses the per-server WINGS_CG_RAMDISK_UNITS variable
+// (cgroups.RamdiskUnitsFromEnv) and splits the requested unit names into the
+// subset allowed by docker.allowed_ramdisk_units and the subset rejected.
+// Every rejected name is returned (not just dropped) so the caller can log
+// each one individually, exactly as a rejected WINGS_CGROUP_PARENT override
+// is by ResolveCgroupParent. Both slices are nil when the server requests
+// nothing.
+//
+// There is deliberately no fallback namespace the way ResolveCgroupParent
+// falls back to "wings-*.slice": an empty AllowedRamdiskUnits rejects every
+// request, because a unit name has no equivalent structural marker Wings
+// could trust in its place.
+func (c DockerConfiguration) ResolveRamdiskUnits(env []string) (allowed, rejected []string) {
+	requested := cgroups.RamdiskUnitsFromEnv(env)
+	if len(requested) == 0 {
+		return nil, nil
+	}
+	allow := make(map[string]struct{}, len(c.AllowedRamdiskUnits))
+	for _, u := range c.AllowedRamdiskUnits {
+		allow[u] = struct{}{}
+	}
+	for _, u := range requested {
+		if _, ok := allow[u]; ok {
+			allowed = append(allowed, u)
+		} else {
+			rejected = append(rejected, u)
+		}
+	}
+	return allowed, rejected
+}
+
 // ServerSliceName derives the per-server slice unit name for a server UUID:
 // the node-wide CgroupParent with the dashless lowercase UUID appended, e.g.
 // "wings.slice" + "b87c0a5b-…" -> "wings-b87c0a5b23874a1c8863ff23e6800a1d.slice".

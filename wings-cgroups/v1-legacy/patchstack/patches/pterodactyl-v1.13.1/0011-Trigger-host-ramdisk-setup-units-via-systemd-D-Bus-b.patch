+func TestDockerConfigurationResolveRamdiskUnits(t *testing.T) {
+	tests := []struct {
+		name         string
+		cfg          DockerConfiguration
+		env          []string
+		wantAllowed  []string
+		wantRejected []string
+	}{
+		{
+			name: "no variable set",
+			cfg:  DockerConfiguration{AllowedRamdiskUnits: []string{"soulmask-pak-ramdisk.service"}},
+			env:  nil,
+		},
+		{
+			name:        "listed unit accepted",
+			cfg:         DockerConfiguration{AllowedRamdiskUnits: []string{"soulmask-pak-ramdisk.service", "soulmask-static-ramdisk.service"}},
+			env:         []string{"WINGS_CG_RAMDISK_UNITS=soulmask-pak-ramdisk.service"},
+			wantAllowed: []string{"soulmask-pak-ramdisk.service"},
+		},
+		{
+			name:         "unlisted unit rejected",
+			cfg:          DockerConfiguration{AllowedRamdiskUnits: []string{"soulmask-pak-ramdisk.service"}},
+			env:          []string{"WINGS_CG_RAMDISK_UNITS=sshd.service"},
+			wantRejected: []string{"sshd.service"},
+		},
+		{
+			name:         "empty allowlist rejects everything",
+			cfg:          DockerConfiguration{},
+			env:          []string{"WINGS_CG_RAMDISK_UNITS=soulmask-pak-ramdisk.service"},
+			wantRejected: []string{"soulmask-pak-ramdisk.service"},
+		},
+		{
+			name:         "mixed list splits allowed and rejected, order preserved",
+			cfg:          DockerConfiguration{AllowedRamdiskUnits: []string{"soulmask-pak-ramdisk.service"}},
+			env:          []string{"WINGS_CG_RAMDISK_UNITS=soulmask-pak-ramdisk.service,sshd.service,soulmask-static-ramdisk.service"},
+			wantAllowed:  []string{"soulmask-pak-ramdisk.service"},
+			wantRejected: []string{"sshd.service", "soulmask-static-ramdisk.service"},
+		},
+	}
+
+	strEq := func(a, b []string) bool {
+		if len(a) != len(b) {
+			return false
+		}
+		for i := range a {
+			if a[i] != b[i] {
+				return false
+			}
+		}
+		return true
+	}
+
+	for _, tc := range tests {
+		t.Run(tc.name, func(t *testing.T) {
+			allowed, rejected := tc.cfg.ResolveRamdiskUnits(tc.env)
+			if !strEq(allowed, tc.wantAllowed) {
+				t.Errorf("allowed = %v, want %v", allowed, tc.wantAllowed)
+			}
+			if !strEq(rejected, tc.wantRejected) {
+				t.Errorf("rejected = %v, want %v", rejected, tc.wantRejected)
+			}
+		})
+	}
+}

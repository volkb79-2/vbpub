diff --git a/environment/docker/container.go b/environment/docker/container.go
index 2311850..09bb321 100644
--- a/environment/docker/container.go
+++ b/environment/docker/container.go
@@ -187,6 +187,41 @@ func (e *Environment) Create() error {
 		cgroups.EnsureForServer(ctx, e.log(), cfg.Docker.SliceEnsureRequest(e.Id, cgroupParent, evs, cgroups.PhaseSteady), "container create")
 	}
 
+	// Trigger any host-side, pre-existing systemd units this server names via
+	// WINGS_CG_RAMDISK_UNITS — typically a ramdisk-setup unit shared with
+	// sibling servers (see scripts/gstammtisch-guide/SOULMASK.md). Wings never
+	// manages the mount itself: it only asks systemd to start a unit that is
+	// already installed and defined on the host, and waits for the job to
+	// finish, exactly like an operator running `systemctl start <unit>` — the
+	// host scripts remain the only thing that ever touches a mount. Only unit
+	// names also listed in docker.allowed_ramdisk_units are honoured; every
+	// other requested name is rejected and logged, never acted on, because
+	// this variable is panel data a compromised or misconfigured server could
+	// otherwise abuse to ask Wings to (re)start an arbitrary host unit. See
+	// config.DockerConfiguration.ResolveRamdiskUnits.
+	//
+	// Runs on every Create(), not only the server's first: the units this
+	// targets are idempotent oneshots (systemd's "start" job on an
+	// already-active-exited oneshot does not re-run ExecStart — see
+	// cgroups.StartUnit), so a repeat trigger is a cheap no-op.
+	//
+	// Fail-open, exactly like the slice management above: a missing, failing,
+	// or slow unit is logged and never blocks the server from starting — a
+	// missing ramdisk share degrades to each server keeping its own private
+	// copy of whatever it backs, which is correct/safe, never a reason to
+	// refuse to start the server.
+	allowedRamdiskUnits, rejectedRamdiskUnits := cfg.Docker.ResolveRamdiskUnits(evs)
+	for _, name := range rejectedRamdiskUnits {
+		e.log().WithField("unit", name).Warn("environment/docker: rejected WINGS_CG_RAMDISK_UNITS unit not listed in docker.allowed_ramdisk_units")
+	}
+	for _, name := range allowedRamdiskUnits {
+		if err := cgroups.StartUnit(ctx, name); err != nil {
+			e.log().WithField("unit", name).WithError(err).Warn("environment/docker: failed to trigger ramdisk-setup unit; continuing without it")
+		} else {
+			e.log().WithField("unit", name).Info("environment/docker: triggered ramdisk-setup unit")
+		}
+	}
+
 	// Merge user-provided labels with system labels
 	confLabels := e.Configuration.Labels()
 	labels := make(map[string]string, 2+len(confLabels))

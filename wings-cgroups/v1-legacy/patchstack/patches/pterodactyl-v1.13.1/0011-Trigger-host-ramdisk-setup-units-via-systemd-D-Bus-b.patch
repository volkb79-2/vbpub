+// TriggerUnitTimeout bounds how long StartUnit waits for a triggered unit's
+// start job to finish. Sized against the concrete units this exists to
+// trigger — the host ramdisk-setup services (soulmask-pak-ramdisk.service,
+// soulmask-static-ramdisk.service) declare TimeoutStartSec=120 for their own
+// cold-cache ExecStart (copying up to a few hundred MB on a slow disk) — so
+// this is that outer bound plus margin, not an independent policy choice. A
+// warm no-op start (see StartUnit) returns almost immediately regardless.
+const TriggerUnitTimeout = 150 * time.Second
+
+// StartUnit asks systemd to start a unit that is expected to already be
+// loaded from disk (e.g. an admin-installed /etc/systemd/system/*.service),
+// and blocks until the job completes or ctx is done (bounded by
+// TriggerUnitTimeout regardless of what ctx itself allows). Unlike
+// Ensure/StartTransientUnitContext above, this never creates, modifies, or
+// removes a unit definition — Wings does not own it, only asks systemd to
+// (re)run it, exactly like an operator typing `systemctl start <unit>`.
+//
+// This is deliberately systemd's "start" job (StartUnitContext), never
+// "restart" (RestartUnitContext): restarting an already-active oneshot unit
+// runs its ExecStop before ExecStart, and for the ramdisk-setup units this
+// function exists to trigger, ExecStop tears down the bind mounts one or
+// more sibling servers may be actively relying on — a live lesson from this
+// project's own host-side operation, not a theoretical concern. "start" on
+// an already-active-exited oneshot is instead a documented systemd no-op
+// (ExecStart is not re-run), which is exactly the idempotent, cheap, safe
+// behaviour wanted here: this runs on every container Create(), not only
+// the server's first.
+func StartUnit(ctx context.Context, name string) error {
+	ctx, cancel := context.WithTimeout(ctx, TriggerUnitTimeout)
+	defer cancel()
+
+	c, err := connect(ctx)
+	if err != nil {
+		return err
+	}
+	defer c.close()
+
+	ch := make(chan string, 1)
+	if _, err := c.dbus.StartUnitContext(ctx, name, "replace", ch); err != nil {
+		return err
+	}
+	select {
+	case result := <-ch:
+		if result != "done" {
+			return errors.New("starting unit " + name + ": job result " + strconv.Quote(result))
+		}
+	case <-ctx.Done():
+		return ctx.Err()
+	}
+	return nil
+}

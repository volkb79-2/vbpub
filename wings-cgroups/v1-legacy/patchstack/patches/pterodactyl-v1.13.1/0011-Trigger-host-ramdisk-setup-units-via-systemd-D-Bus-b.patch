+// itMarkerPath and itUnitName back TestStartUnitIntegration: a real
+// persistent (non-transient) oneshot unit, installed the same way an
+// administrator's ramdisk-setup unit is, whose ExecStart/ExecStop each append
+// a line to the marker file so the test can observe exactly which of them ran.
+const (
+	itUnitName   = "wings-e2e-startunit-test.service"
+	itMarkerPath = "/tmp/wings-e2e-startunit.marker"
+)
+
+func itWriteStartUnitTestUnit(t *testing.T) {
+	t.Helper()
+	unit := "[Unit]\n" +
+		"Description=wings-cgroups e2e StartUnit test unit\n\n" +
+		"[Service]\n" +
+		"Type=oneshot\n" +
+		"RemainAfterExit=yes\n" +
+		"ExecStart=/bin/sh -c 'echo start >> " + itMarkerPath + "'\n" +
+		"ExecStop=/bin/sh -c 'echo stop >> " + itMarkerPath + "'\n"
+	path := "/etc/systemd/system/" + itUnitName
+	if err := os.WriteFile(path, []byte(unit), 0o644); err != nil {
+		t.Fatalf("writing test unit file: %v", err)
+	}
+	t.Cleanup(func() { _ = os.Remove(path) })
+	if out, err := exec.Command("systemctl", "daemon-reload").CombinedOutput(); err != nil {
+		t.Fatalf("daemon-reload: %v: %s", err, out)
+	}
+}
+
+// itMarkerLines reads the marker file as a plain ordered log of events, one
+// per line — NOT via splitCommaOrNewlineList, whose de-duplication is correct
+// for its actual callers (a list of distinct names) but wrong here: this test
+// relies on telling a single "start" from two "start" lines (idempotent no-op
+// vs. a genuine second ExecStart), so a repeated identical line must survive.
+func itMarkerLines(t *testing.T) []string {
+	t.Helper()
+	b, err := os.ReadFile(itMarkerPath)
+	if err != nil {
+		if os.IsNotExist(err) {
+			return nil
+		}
+		t.Fatalf("reading marker file: %v", err)
+	}
+	var out []string
+	for _, line := range strings.Split(string(b), "\n") {
+		if line != "" {
+			out = append(out, line)
+		}
+	}
+	return out
+}
+
+// TestStartUnitIntegration proves the exact contract StartUnit relies on for
+// the ramdisk-trigger feature: "start" on an already-active-exited oneshot is
+// a no-op (ExecStart does not re-run), and — as a negative control on this
+// same systemd version — "restart" is NOT equivalent: it runs ExecStop first.
+// Getting this distinction backwards in production would tear down a live
+// sibling server's bind mount on every subsequent container Create().
+func TestStartUnitIntegration(t *testing.T) {
+	ctx := itCtx(t)
+	_ = os.Remove(itMarkerPath)
+	t.Cleanup(func() { _ = os.Remove(itMarkerPath) })
+	itWriteStartUnitTestUnit(t)
+	t.Cleanup(func() {
+		cctx, cancel := context.WithTimeout(context.Background(), 10*time.Second)
+		defer cancel()
+		_ = Stop(cctx, itUnitName)
+	})
+
+	// 1. First start: the unit is not yet loaded/active, so ExecStart runs.
+	if err := StartUnit(ctx, itUnitName); err != nil {
+		t.Fatalf("StartUnit (first): %v", err)
+	}
+	if got := itMarkerLines(t); len(got) != 1 || got[0] != "start" {
+		t.Fatalf("marker after first StartUnit = %v, want [start]", got)
+	}
+	if s := itActiveState(t, ctx, itUnitName); s != "active" {
+		t.Fatalf("unit ActiveState after first StartUnit = %q, want active", s)
+	}
+
+	// 2. Second start: the unit is already active-exited. This must be a
+	// no-op — ExecStart must NOT run again, and critically ExecStop must NOT
+	// run either (that would be the "restart" behaviour, and for the real
+	// ramdisk-setup units it would tear down a sibling's live bind mount).
+	if err := StartUnit(ctx, itUnitName); err != nil {
+		t.Fatalf("StartUnit (second, already active): %v", err)
+	}
+	if got := itMarkerLines(t); len(got) != 1 || got[0] != "start" {
+		t.Fatalf("marker after second StartUnit = %v, want [start] unchanged (start must be a no-op on an active-exited oneshot)", got)
+	}
+
+	// 3. Negative control: systemd's RESTART job — never issued through this
+	// package's public API, which deliberately has no restart mode — DOES run
+	// ExecStop then ExecStart on this same unit. Issued via the systemctl CLI,
+	// which blocks until the whole restart transaction (stop, then start) is
+	// complete.
+	if out, err := exec.Command("systemctl", "restart", itUnitName).CombinedOutput(); err != nil {
+		t.Fatalf("systemctl restart %s: %v: %s", itUnitName, err, out)
+	}
+	if got := itMarkerLines(t); len(got) != 3 || got[0] != "start" || got[1] != "stop" || got[2] != "start" {
+		t.Fatalf("marker after systemctl restart = %v, want [start stop start] (restart runs ExecStop then ExecStart)", got)
+	}
+}

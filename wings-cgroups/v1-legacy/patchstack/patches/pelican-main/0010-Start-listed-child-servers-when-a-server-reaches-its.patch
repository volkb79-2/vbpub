index 0000000..aa015fa
--- /dev/null
+++ b/server/slice_children.go
@@ -0,0 +1,96 @@
+package server
+
+import (
+	"github.com/pelican-dev/wings/internal/cgroups"
+)
+
+// Starting a listed child server when this server reaches its steady trigger.
+//
+// A single Wings node routinely runs servers that depend on one another. The
+// motivating case: two instances share a read-only bind mount holding
+// installed content that only one of them (the owner) writes to. If the
+// dependent instance starts while the owner's write is still in flight it can
+// read a half-written file. The general shape is ordinary cluster
+// start-ordering: a client that must not come up until its main is confirmed
+// ready.
+//
+// WINGS_CG_CHILD_SERVERS (internal/cgroups.EnvChildServers) names the other
+// servers to start. It piggybacks on the existing steady trigger
+// (enterSteady) rather than on plain "started": that trigger only fires once
+// the server is genuinely up, which for an update-on-boot server is after the
+// update has completed — so a dependent server gated on it never races a
+// half-written install. See the EnvChildServers doc comment for the exact
+// contract (skip rules, boot-time interaction, fail-open behaviour).
+
+// resolveChildServers returns the *Server for each UUID named in raw that is
+// safe to start: managed by this node, not this server itself, and not
+// suspended (HandlePowerAction does not itself refuse a suspended start the
+// way the Panel router does, so that check has to happen here). Every other
+// entry is logged and skipped.
+//
+// Deliberately pure with respect to HandlePowerAction — it only reads the
+// current server set through s.manager and never starts anything — so the
+// resolution/skip logic is unit-testable with a plain *Manager and bare
+// *Server values, without a live Environment. See slice_children_test.go and
+// the "childStartAction" discussion it replaces: earlier drafts of this patch
+// used a package-level function variable to stub the actual start call for
+// tests, which this codebase does not do anywhere else (the established
+// pattern for a side effect that genuinely needs Docker/systemd is a
+// build-tag-gated integration test, e.g. internal/cgroups/integration_test.go
+// and environment/docker/cgroup_integration_test.go — not a test seam in the
+// production call graph). Splitting resolution from dispatch gets the same
+// testability without introducing an unidiomatic seam: only the dispatch
+// half — a single HandlePowerAction call per resolved child — goes untested
+// at the unit level, exactly like applySliceProps's call into
+// cgroups.EnsureForServer.
+func (s *Server) resolveChildServers(raw []string) []*Server {
+	if s.manager == nil || len(raw) == 0 {
+		return nil
+	}
+	selfID := s.ID()
+	var out []*Server
+	for _, id := range raw {
+		if id == selfID {
+			s.Log().WithField("child", id).Warn("cgroups: WINGS_CG_CHILD_SERVERS lists the server itself; skipping")
+			continue
+		}
+		child, ok := s.manager.Get(id)
+		if !ok {
+			s.Log().WithField("child", id).Warn("cgroups: WINGS_CG_CHILD_SERVERS lists a UUID not managed by this node; skipping")
+			continue
+		}
+		if child.IsSuspended() {
+			s.Log().WithField("child", id).Info("cgroups: child server is suspended; not starting it")
+			continue
+		}
+		out = append(out, child)
+	}
+	return out
+}
+
+// startChildren starts every resolved WINGS_CG_CHILD_SERVERS entry after this
+// server has reached its steady trigger. Called on its own goroutine from
+// enterSteady, so nothing here may block that server's own state machine or
+// console processing.
+//
+// Each child is started through HandlePowerAction, the exact path the
+// Panel/API start uses: it takes the child's own power lock and re-checks its
+// state, so "already running" and installing/transferring/restoring are
+// reported by it, not raced here. Nothing here is fatal to the server whose
+// trigger fired — every outcome is a single "cgroups: child server ..." log
+// line attributed to the child, naming the server and reason that triggered
+// it.
+func (s *Server) startChildren(reason string) {
+	raw := cgroups.ChildServersFromEnv(s.GetEnvironmentVariables())
+	for _, child := range s.resolveChildServers(raw) {
+		child := child
+		go func() {
+			l := child.Log().WithField("trigger_server", s.ID()).WithField("trigger_reason", reason)
+			if err := child.HandlePowerAction(PowerActionStart); err != nil {
+				l.WithError(err).Warn("cgroups: child server did not start")
+				return
+			}
+			l.Info("cgroups: child server started")
+		}()
+	}
+}

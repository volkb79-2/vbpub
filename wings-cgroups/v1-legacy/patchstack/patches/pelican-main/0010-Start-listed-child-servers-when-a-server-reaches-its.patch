 )
 
 // Phase selects which property band a slice should carry.
@@ -420,6 +458,34 @@ func PhaseEventsFromEnv(env []string) []PhaseEvent {
 	return out
 }
 
+// ChildServersFromEnv parses EnvChildServers into the list of server UUIDs it
+// names: comma- or newline-separated (mirroring the multi-entry convention of
+// the other WINGS_CG_* list variable, EnvPhaseEvents), trimmed, de-duplicated,
+// and order-preserving. Resolving whether an entry is actually a UUID this
+// node manages, or the server's own ID, is left to the caller (server.
+// resolveChildServers) — this function only parses the raw list.
+func ChildServersFromEnv(env []string) []string {
+	raw := envValue(env, EnvChildServers)
+	if raw == "" {
+		return nil
+	}
+	raw = strings.ReplaceAll(raw, "\n", ",")
+	var out []string
+	seen := map[string]struct{}{}
+	for _, part := range strings.Split(raw, ",") {
+		id := strings.TrimSpace(part)
+		if id == "" {
+			continue
+		}
+		if _, ok := seen[id]; ok {
+			continue
+		}
+		seen[id] = struct{}{}
+		out = append(out, id)
+	}

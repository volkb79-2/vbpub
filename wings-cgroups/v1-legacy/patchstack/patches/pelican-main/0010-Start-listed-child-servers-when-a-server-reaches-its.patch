+package server
+
+import "testing"
+
+// childTestServer builds a bare Server carrying just enough state for
+// resolveChildServers to exercise its skip rules -- no Environment, no
+// Docker, no systemd. HandlePowerAction is deliberately never called by these
+// tests: see the package doc comment on resolveChildServers for why that
+// split exists.
+func childTestServer(uuid string) *Server {
+	s := &Server{}
+	s.cfg.Uuid = uuid
+	return s
+}
+
+func TestResolveChildServersHappyPath(t *testing.T) {
+	mgr := NewEmptyManager(nil)
+	parent := childTestServer("parent-1")
+	parent.manager = mgr
+	child := childTestServer("child-1")
+	mgr.Put([]*Server{parent, child})
+
+	got := parent.resolveChildServers([]string{"child-1"})
+	if len(got) != 1 || got[0] != child {
+		t.Fatalf("resolveChildServers = %v, want [child]", got)
+	}
+}
+
+func TestResolveChildServersSkipsSelf(t *testing.T) {
+	mgr := NewEmptyManager(nil)
+	parent := childTestServer("parent-1")
+	parent.manager = mgr
+	mgr.Put([]*Server{parent})
+
+	if got := parent.resolveChildServers([]string{"parent-1"}); len(got) != 0 {
+		t.Errorf("a server listing itself must resolve to nothing, got %v", got)
+	}
+}
+
+func TestResolveChildServersSkipsUnknownUUID(t *testing.T) {
+	mgr := NewEmptyManager(nil)
+	parent := childTestServer("parent-1")
+	parent.manager = mgr
+	mgr.Put([]*Server{parent})
+
+	if got := parent.resolveChildServers([]string{"not-on-this-node"}); len(got) != 0 {
+		t.Errorf("a UUID unknown to this node must resolve to nothing, got %v", got)
+	}
+}
+
+func TestResolveChildServersSkipsSuspended(t *testing.T) {
+	mgr := NewEmptyManager(nil)
+	parent := childTestServer("parent-1")
+	parent.manager = mgr
+	child := childTestServer("child-1")
+	child.cfg.Suspended = true
+	mgr.Put([]*Server{parent, child})
+
+	if got := parent.resolveChildServers([]string{"child-1"}); len(got) != 0 {
+		t.Errorf("a suspended child must resolve to nothing, got %v", got)
+	}
+}
+
+func TestResolveChildServersNilManager(t *testing.T) {
+	parent := childTestServer("parent-1")
+	if got := parent.resolveChildServers([]string{"child-1"}); got != nil {
+		t.Errorf("a server with no manager (built outside one) must resolve nothing, got %v", got)
+	}
+}
+
+func TestChildStartEligible(t *testing.T) {
+	for _, reason := range []string{sliceReasonReady, sliceReasonMatch} {
+		if !childStartEligible(reason) {
+			t.Errorf("reason %q should be eligible to start children", reason)
+		}
+	}
+	if childStartEligible(sliceReasonGrace) {
+		t.Error("the grace backstop must never start children: a trigger that never fired means readiness was never confirmed")
+	}
+}
+
+func TestResolveChildServersMixedValidAndInvalid(t *testing.T) {
+	mgr := NewEmptyManager(nil)
+	parent := childTestServer("parent-1")
+	parent.manager = mgr
+	good := childTestServer("child-good")
+	suspended := childTestServer("child-suspended")
+	suspended.cfg.Suspended = true
+	mgr.Put([]*Server{parent, good, suspended})
+
+	got := parent.resolveChildServers([]string{"parent-1", "child-good", "unknown", "child-suspended"})
+	if len(got) != 1 || got[0] != good {
+		t.Fatalf("resolveChildServers = %v, want only [child-good]", got)
+	}
+}

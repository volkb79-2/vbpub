diff --git a/internal/cgroups/boot.go b/internal/cgroups/boot.go
new file mode 100644
index 0000000..ae3cbe7
--- /dev/null
+++ b/internal/cgroups/boot.go
@@ -0,0 +1,109 @@
+package cgroups
+
+// DeferBootRestart computes, among a set of servers Wings is about to restart
+// directly on its own boot sequence, which ones should instead be left for a
+// WINGS_CG_CHILD_SERVERS parent to start once THAT parent's own restart
+// reaches its steady trigger.
+//
+// The problem this solves: Wings' boot sequence restores every server whose
+// persisted state was running/starting by calling HandlePowerAction directly
+// (cmd/root.go), with no awareness of WINGS_CG_CHILD_SERVERS. If a parent and
+// its child were both running when Wings (or the host) restarted, both would
+// be started by that same boot sequence concurrently — reintroducing exactly
+// the race the feature exists to prevent, since the child's own
+// HandlePowerAction start bypasses the parent-steady wait entirely. Deferring
+// the child's direct boot start closes that gap: the parent's restart replays
+// the ordinary HandlePowerAction path, which refires the parent's console
+// listener and therefore its steady trigger exactly as it would at runtime,
+// and THAT is what starts the child (server.startChildren) — no new waiting
+// or timeout machinery needed, just not racing it a second time here.
+//
+// restartCandidates is the set of server IDs Wings is about to start directly
+// this boot: persisted state running/starting AND no live container found for
+// it. children maps a server ID to the (already-parsed) list of server IDs it
+// names via WINGS_CG_CHILD_SERVERS; only entries for servers who define at
+// least one child need be present.
+//
+// The result maps a deferred child's ID to the parent ID it is waiting on. A
+// candidate is deferred only when:
+//   - it is named as a child by at least one OTHER restart candidate, and
+//   - the parent relationship does not loop back to the candidate within
+//     maxAncestorHops.
+//
+// The second condition matters because a cyclic or mutual relationship (A
+// lists B as a child, B lists A) cannot supply a server that starts
+// unprompted — deferring every member of such a cycle would leave all of them
+// offline forever after a reboot, with nothing left to break the deadlock.
+// Wings fails open here exactly as server.resolveChildServers does at
+// runtime: a relationship it cannot safely honour is logged and ignored
+// rather than allowed to strand a server, so every member of a cycle is left
+// unsuppressed and starts directly, same as before this feature existed.
+func DeferBootRestart(children map[string][]string, restartCandidates map[string]struct{}) map[string]string {
+	if len(children) == 0 || len(restartCandidates) == 0 {
+		return nil
+	}
+
+	// Invert to child -> parents, restricted to parents that are themselves
+	// restart candidates (only those will actually replay their steady
+	// trigger this boot) and excluding self-references (a server listing
+	// itself is a no-op everywhere else this list is consumed).
+	parentsOf := make(map[string][]string)
+	for parent, kids := range children {
+		if _, ok := restartCandidates[parent]; !ok {
+			continue
+		}
+		for _, kid := range kids {
+			if kid == parent {
+				continue
+			}
+			parentsOf[kid] = append(parentsOf[kid], parent)
+		}
+	}
+	if len(parentsOf) == 0 {
+		return nil
+	}
+
+	const maxAncestorHops = 64
+	deferred := make(map[string]string)
+	for id := range restartCandidates {
+		parents := parentsOf[id]
+		if len(parents) == 0 {
+			continue
+		}
+		if isSelfAncestor(id, parentsOf, maxAncestorHops) {
+			continue
+		}
+		deferred[id] = parents[0]
+	}
+	if len(deferred) == 0 {
+		return nil
+	}
+	return deferred
+}
+
+// isSelfAncestor reports whether id is reachable from itself by following
+// parentsOf edges upward — i.e. whether id participates in a cycle of the
+// parent relationship. Bounded to maxHops so a pathological/very long chain
+// cannot turn boot into an unbounded walk; a chain that deep is for all
+// practical purposes indistinguishable from a cycle, and failing open
+// (treating it as one, i.e. NOT deferring) is the same safe choice this
+// function makes for a genuine cycle.
+func isSelfAncestor(id string, parentsOf map[string][]string, maxHops int) bool {
+	visited := map[string]bool{id: true}
+	frontier := parentsOf[id]
+	for hop := 0; hop < maxHops && len(frontier) > 0; hop++ {
+		var next []string
+		for _, p := range frontier {
+			if p == id {
+				return true
+			}
+			if visited[p] {
+				continue
+			}
+			visited[p] = true
+			next = append(next, parentsOf[p]...)
+		}
+		frontier = next
+	}
+	return false
+}
diff --git a/internal/cgroups/boot_test.go b/internal/cgroups/boot_test.go
new file mode 100644
index 0000000..ea2bae3
--- /dev/null
+++ b/internal/cgroups/boot_test.go
@@ -0,0 +1,111 @@
+package cgroups
+
+import "testing"
+
+func TestDeferBootRestartSimpleChain(t *testing.T) {
+	// A -> B -> C, all about to be restarted directly by boot.
+	children := map[string][]string{
+		"A": {"B"},
+		"B": {"C"},
+	}
+	candidates := map[string]struct{}{"A": {}, "B": {}, "C": {}}
+	got := DeferBootRestart(children, candidates)
+	if got["A"] != "" {
+		t.Errorf("A has no parent and must not be deferred, got %q", got["A"])
+	}
+	if got["B"] != "A" {
+		t.Errorf("B should defer to A, got %q", got["B"])
+	}
+	if got["C"] != "B" {
+		t.Errorf("C should defer to B, got %q", got["C"])
+	}
+}
+
+func TestDeferBootRestartMutualCycleStartsBothDirectly(t *testing.T) {
+	// A and B each list the other as a child: neither can supply an
+	// unprompted starter, so deferring either would strand both forever.
+	children := map[string][]string{
+		"A": {"B"},
+		"B": {"A"},
+	}
+	candidates := map[string]struct{}{"A": {}, "B": {}}
+	got := DeferBootRestart(children, candidates)
+	if len(got) != 0 {
+		t.Errorf("a mutual cycle must defer nobody, got %v", got)
+	}
+}
+
+func TestDeferBootRestartSelfReferenceIgnored(t *testing.T) {
+	children := map[string][]string{"A": {"A", "B"}}
+	candidates := map[string]struct{}{"A": {}, "B": {}}
+	got := DeferBootRestart(children, candidates)
+	if got["A"] != "" {
+		t.Errorf("A must not defer to itself, got %q", got["A"])
+	}
+	if got["B"] != "A" {
+		t.Errorf("B should still defer to A despite the self-reference entry, got %q", got["B"])
+	}
+}
+
+func TestDeferBootRestartParentNotRestartingLeavesChildDirect(t *testing.T) {
+	// A is the configured parent but is NOT itself a restart candidate this
+	// boot (e.g. it was already stopped) -- nothing will replay its trigger,
+	// so B must start directly, exactly as it would without this feature.
+	children := map[string][]string{"A": {"B"}}
+	candidates := map[string]struct{}{"B": {}}
+	got := DeferBootRestart(children, candidates)
+	if len(got) != 0 {
+		t.Errorf("a non-restarting parent must defer nothing, got %v", got)
+	}
+}
+
+func TestDeferBootRestartNoChildConfigDefersNothing(t *testing.T) {
+	if got := DeferBootRestart(nil, map[string]struct{}{"A": {}}); got != nil {
+		t.Errorf("no WINGS_CG_CHILD_SERVERS anywhere must defer nothing, got %v", got)
+	}
+	children := map[string][]string{"A": {"B"}}
+	if got := DeferBootRestart(children, nil); got != nil {
+		t.Errorf("no restart candidates must defer nothing, got %v", got)
+	}
+}
+
+func TestDeferBootRestartMultipleParentsPicksOne(t *testing.T) {
+	// C is named as a child by both A and B; either is a valid anchor.
+	children := map[string][]string{"A": {"C"}, "B": {"C"}}
+	candidates := map[string]struct{}{"A": {}, "B": {}, "C": {}}
+	got := DeferBootRestart(children, candidates)
+	if got["C"] != "A" && got["C"] != "B" {
+		t.Errorf("C should defer to one of its restarting parents, got %q", got["C"])
+	}
+}
+
+func TestIsSelfAncestorLongChainIsNotACycle(t *testing.T) {
+	// A -> B -> C -> D -> E, well within the hop bound: none of these should
+	// be reported as their own ancestor.
+	parentsOf := map[string][]string{
+		"B": {"A"},
+		"C": {"B"},
+		"D": {"C"},
+		"E": {"D"},
+	}
+	for _, id := range []string{"B", "C", "D", "E"} {
+		if isSelfAncestor(id, parentsOf, 64) {
+			t.Errorf("%s should not be its own ancestor in a simple chain", id)
+		}
+	}
+}
+
+func TestIsSelfAncestorThreeCycle(t *testing.T) {
+	// A -> B -> C -> A: a longer cycle than the mutual case, still must be
+	// caught for every member.
+	parentsOf := map[string][]string{
+		"A": {"C"},
+		"B": {"A"},
+		"C": {"B"},
+	}
+	for _, id := range []string{"A", "B", "C"} {
+		if !isSelfAncestor(id, parentsOf, 64) {
+			t.Errorf("%s should be detected as part of the 3-cycle", id)
+		}
+	}
+}

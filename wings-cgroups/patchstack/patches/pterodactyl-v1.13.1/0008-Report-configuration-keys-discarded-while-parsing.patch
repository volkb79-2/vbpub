 	if !filepath.IsAbs(configPath) {
 		d, err := filepath.Abs(configPath)
diff --git a/config/config.go b/config/config.go
index b133123..453ed30 100644
--- a/config/config.go
+++ b/config/config.go
@@ -330,6 +330,11 @@ type Configuration struct {
 	// The location from which this configuration instance was instantiated.
 	path string
 
+	// Keys the configuration file contained but the parser discarded. Filled
+	// in by FromFile, reported through DiscardedKeys. Unexported so that the
+	// config rewrite never serializes it back into the file.
+	discarded []string
+
 	// Determines if wings should be running in debug mode. This value is ignored
 	// if the debug flag is passed through the command line arguments.
 	Debug bool
@@ -584,6 +589,48 @@ nobody:x:65534:65534::/var/empty:/bin/sh
 	return nil
 }
 
+// discardedKeys re-decodes the raw configuration strictly, purely to report
+// what the permissive decode above accepted and then threw away.
+//
+// Two silent-loss cases are worth an administrator's attention, and neither
+// produces any diagnostic today:
+//
+//   - A key the schema does not define — most often a real key at the wrong
+//     indentation, so it lands under the wrong parent or at the document root.
+//     The value is dropped, the feature it was meant to configure stays at its
+//     default, and nothing is logged. Because Wings rewrites config.yml from
+//     the parsed struct at boot, the rewrite then deletes the line as well:
+//     the administrator is left with a file that looks untouched and a setting
+//     that never took effect.
+//   - A duplicate mapping key, where the last occurrence silently wins over
+//     everything set earlier under the same name.
+//
+// This is diagnostics only. The permissive decode stays authoritative — a
+// strict decode would turn a stale key left over from an older Wings into a
+// boot failure — so unknown keys must never be fatal here.
+func discardedKeys(b []byte) []string {
+	var probe Configuration
+	err := yaml.UnmarshalStrict(b, &probe)
+	if err == nil {
+		return nil
+	}
+	var te *yaml.TypeError
+	if errors.As(err, &te) {
+		return te.Errors
+	}
+	// Anything that is not a TypeError would already have failed the
+	// authoritative decode; there is nothing useful left to report.
+	return nil
+}
+
+// DiscardedKeys reports configuration keys that were present in the file but
+// dropped when it was parsed: unknown or misplaced keys, and duplicate keys.
+// Each entry is a yaml diagnostic naming the offending line. Empty for a clean
+// file.
+func (c *Configuration) DiscardedKeys() []string {
+	return c.discarded
+}
+
 // FromFile reads the configuration from the provided file and stores it in the
 // global singleton for this instance.
 func FromFile(path string) error {
@@ -599,6 +646,7 @@ func FromFile(path string) error {
 	if err := yaml.Unmarshal(b, c); err != nil {
 		return err
 	}
+	c.discarded = discardedKeys(b)
 
 	c.Token = Token{
 		ID:    os.Getenv("WINGS_TOKEN_ID"),
diff --git a/config/config_discarded_test.go b/config/config_discarded_test.go
new file mode 100644
index 0000000..d12bf06
--- /dev/null
+++ b/config/config_discarded_test.go
@@ -0,0 +1,74 @@
+package config
+
+import (
+	"strings"
+	"testing"
+)
+
+// The misindentation this guards against is not hypothetical: a deployment lost
+// a nested key to it, the boot rewrite then removed the line from the file, and
+// the only symptom was a setting that never took effect.
+func TestDiscardedKeys(t *testing.T) {
+	for _, tt := range []struct {
+		name string
+		yaml string
+		want string
+	}{
+		{
+			name: "clean file reports nothing",
+			yaml: "debug: true\nsystem:\n  username: pterodactyl\n",
+		},
+		{
+			name: "key indented under the wrong parent",
+			yaml: "system:\n  username: pterodactyl\n  interface: 172.18.0.1\n",
+			want: "interface",
+		},
+		{
+			name: "nested key hoisted to the document root",
+			yaml: "docker:\n  username: pterodactyl\nnetwork:\n  interface: 172.18.0.1\n",
+			want: "network",
+		},
+		{
+			name: "duplicate key silently overwrites the first",
+			yaml: "system:\n  username: pterodactyl\nsystem:\n  username: wings\n",
+			want: "system",
+		},
+	} {
+		t.Run(tt.name, func(t *testing.T) {
+			got := discardedKeys([]byte(tt.yaml))
+			if tt.want == "" {
+				if len(got) != 0 {
+					t.Fatalf("want no diagnostics, got %v", got)
+				}
+				return
+			}
+			if len(got) == 0 {
+				t.Fatalf("want a diagnostic naming %q, got none", tt.want)
+			}
+			if !strings.Contains(strings.Join(got, "\n"), tt.want) {
+				t.Errorf("diagnostics %v do not name %q", got, tt.want)
+			}
+		})
+	}
+}
+
+// A valid file must never produce diagnostics: false positives here would train
+// administrators to ignore the warning.
+func TestDiscardedKeysIgnoresValidSchema(t *testing.T) {
+	yml := `
+debug: false
+uuid: 563bb5d5-c7bf-4a9e-84df-cb12b824c627
+api:
+  host: 0.0.0.0
+  port: 8080
+system:
+  data: /var/lib/pterodactyl/volumes
+  username: pterodactyl
+docker:
+  network:
+    interface: 172.18.0.1
+`
+	if got := discardedKeys([]byte(yml)); len(got) != 0 {
+		t.Errorf("valid configuration produced diagnostics: %v", got)
+	}
+}

@@ -459,11 +459,17 @@ func (ip *InstallationProcess) Execute() (string, error) {
 		UsernsMode:  container.UsernsMode(cfg.Docker.UsernsMode),
 	}
 
-	// Keep the installer container under the same cgroup parent as the server
-	// containers so that installation workloads are subject to the same
-	// slice-level resource policy. See config.DockerConfiguration.CgroupParent.
-	if cfg.Docker.CgroupParent != "" {
-		hostConf.CgroupParent = cfg.Docker.CgroupParent
+	// Keep the installer container under the same cgroup parent as the
+	// server's runtime container so that installation workloads are subject to
+	// the same slice-level resource policy. Per-server overrides resolve
+	// through the same helper as the runtime container; rejected overrides
+	// fail closed to the node-wide value.
+	cgroupParent, err := cfg.Docker.ResolveCgroupParent(ip.Server.GetEnvironmentVariables())
+	if err != nil {
+		ip.Server.Log().WithField("cgroup_parent", cgroupParent).WithError(err).Warn("installer: rejected per-server cgroup parent override")
+	}
+	if cgroupParent != "" {
+		hostConf.CgroupParent = cgroupParent
 	}
 
 	// Ensure the root directory for the server exists properly before attempting

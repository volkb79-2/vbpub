@@ -132,12 +134,75 @@ type DockerConfiguration struct {
 	// system.slice.
 	AllowedCgroupParents []string `json:"allowed_cgroup_parents" yaml:"allowed_cgroup_parents"`
 
+	// PerServerSlices enables automatic per-server slice management: every
+	// server is placed under its own derived slice (see ServerSliceName)
+	// nested inside CgroupParent, and Wings creates/reconciles that slice as
+	// a transient systemd unit — with the configured default resource
+	// properties and any per-server WINGS_CG_* overrides — before containers
+	// are created under it.
+	PerServerSlices PerServerSlicesConfiguration `json:"per_server_slices" yaml:"per_server_slices"`
+
 	LogConfig struct {
 		Type   string            `default:"local" json:"type" yaml:"type"`
 		Config map[string]string `default:"{\"max-size\":\"5m\",\"max-file\":\"1\",\"compress\":\"false\",\"mode\":\"non-blocking\"}" json:"config" yaml:"config"`
 	} `json:"log_config" yaml:"log_config"`
 }
 
+// DockerSliceDefaults are the node-wide default resource properties applied
+// to every Wings-derived per-server slice. Sizes use single-letter binary
+// suffixes ("6G", "512M") or plain byte counts; empty means "no default".
+// Weights are the systemd cgroup weight range 1..10000; 0 means "no default".
+// A per-server WINGS_CG_* environment variable overrides the corresponding
+// default for that server only.
+type DockerSliceDefaults struct {
+	MemoryMin  string `default:"" json:"memory_min" yaml:"memory_min"`
+	MemoryLow  string `default:"" json:"memory_low" yaml:"memory_low"`
+	MemoryHigh string `default:"" json:"memory_high" yaml:"memory_high"`
+	MemoryMax  string `default:"" json:"memory_max" yaml:"memory_max"`
+	CPUWeight  uint64 `default:"0" json:"cpu_weight" yaml:"cpu_weight"`
+	IOWeight   uint64 `default:"0" json:"io_weight" yaml:"io_weight"`
+}
+
+// PerServerSlicesConfiguration configures automatic per-server slice
+// management (docker.per_server_slices). Requires CgroupParent to be set:
+// derived slices nest under it via systemd dash naming.
+type PerServerSlicesConfiguration struct {
+	Enabled bool `default:"false" json:"enabled" yaml:"enabled"`
+
+	// Defaults are applied to every derived per-server slice; individual
+	// servers may override single properties through admin-only WINGS_CG_*
+	// variables. Slices selected through an explicit WINGS_CGROUP_PARENT
+	// override are considered hand-managed and receive only the explicit
+	// WINGS_CG_* values, never these defaults.
+	Defaults DockerSliceDefaults `json:"defaults" yaml:"defaults"`
+
+	// MemoryMinBudget caps the sum of MemoryMin floors across all managed
+	// slices of this node. It should match the parent slice's own MemoryMin:
+	// child floors beyond the parent's floor are arithmetically dead, so an
+	// unchecked budget silently weakens every guarantee. Empty disables the
+	// check.
+	MemoryMinBudget string `default:"" json:"memory_min_budget" yaml:"memory_min_budget"`
+
+	// BudgetPolicy decides what happens to a MemoryMin request exceeding the
+	// remaining budget. Every other property is applied unchanged in all
+	// three cases:
+	//
+	//   clamp      (default) reduce the floor to whatever budget remains, so
+	//              that every granted floor stays a real guarantee.
+	//   refuse     drop the floor entirely rather than grant a smaller one
+	//              than the server asked for.
+	//   distribute apply the floor as requested and let the kernel resolve the
+	//              shortfall: on overcommit it splits the parent slice's
+	//              protection between the children in proportion to each
+	//              one's usage below its own floor, so busy servers keep more
+	//              protected memory than idle ones and the split follows load.
+	//              Individual floors stop being guarantees; the tier total
+	//              still is.
+	//
+	// See cgroups.BudgetClamp/BudgetRefuse/BudgetDistribute.
+	BudgetPolicy string `default:"clamp" json:"budget_policy" yaml:"budget_policy"`
+}

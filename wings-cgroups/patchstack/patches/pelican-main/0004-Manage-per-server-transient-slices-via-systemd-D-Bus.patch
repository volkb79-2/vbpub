diff --git a/internal/cgroups/budget_test.go b/internal/cgroups/budget_test.go
new file mode 100644
index 0000000..29a5355
--- /dev/null
+++ b/internal/cgroups/budget_test.go
@@ -0,0 +1,139 @@
+package cgroups
+
+import "testing"
+
+// The floor budget is the arithmetic that decides whether an administrator's
+// memory.min is honoured, shrunk or dropped. It runs inside Ensure behind a
+// D-Bus connection, so this table is the only coverage it gets in a normal
+// `go test ./...` run.
+func TestApplyBudget(t *testing.T) {
+	const limit = 10 << 30 // 10G
+
+	for _, tt := range []struct {
+		name       string
+		floor      *uint64
+		limit      uint64
+		policy     string
+		used       uint64
+		wantFloor  *uint64
+		wantCommit bool
+	}{
+		{
+			name:      "no floor requested is never touched",
+			floor:     nil,
+			limit:     limit,
+			policy:    BudgetClamp,
+			used:      0,
+			wantFloor: nil,
+		},
+		{
+			name:      "no budget configured disables the check entirely",
+			floor:     u64(99 << 30),
+			limit:     0,
+			policy:    BudgetClamp,
+			used:      0,
+			wantFloor: u64(99 << 30),
+		},
+		{
+			name:      "floor inside the remainder is applied as asked",
+			floor:     u64(6 << 30),
+			limit:     limit,
+			policy:    BudgetClamp,
+			used:      2 << 30,
+			wantFloor: u64(6 << 30),
+		},
+		{
+			name:      "floor exactly filling the remainder is not an overcommit",
+			floor:     u64(8 << 30),
+			limit:     limit,
+			policy:    BudgetClamp,
+			used:      2 << 30,
+			wantFloor: u64(8 << 30),
+		},
+		{
+			name:       "clamp reduces the floor to what is left",
+			floor:      u64(6 << 30),
+			limit:      limit,
+			policy:     BudgetClamp,
+			used:       7 << 30,
+			wantFloor:  u64(3 << 30),
+			wantCommit: true,
+		},
+		{
+			name:       "clamp with the budget already exhausted yields a zero floor",
+			floor:      u64(6 << 30),
+			limit:      limit,
+			policy:     BudgetClamp,
+			used:       12 << 30, // siblings already over budget; no underflow
+			wantFloor:  u64(0),
+			wantCommit: true,
+		},
+		{
+			name:       "refuse drops the floor rather than shrink it",
+			floor:      u64(6 << 30),
+			limit:      limit,
+			policy:     BudgetRefuse,
+			used:       7 << 30,
+			wantFloor:  nil,
+			wantCommit: true,
+		},
+		{
+			name:       "distribute applies the floor as requested and only reports",
+			floor:      u64(6 << 30),
+			limit:      limit,
+			policy:     BudgetDistribute,
+			used:       7 << 30,
+			wantFloor:  u64(6 << 30),
+			wantCommit: true,
+		},
+		{
+			name:       "an empty policy behaves as clamp",
+			floor:      u64(6 << 30),
+			limit:      limit,
+			policy:     "",
+			used:       7 << 30,
+			wantFloor:  u64(3 << 30),
+			wantCommit: true,
+		},
+	} {
+		t.Run(tt.name, func(t *testing.T) {
+			in := Props{MemoryMin: tt.floor, MemoryHigh: u64(1 << 30), CPUWeight: u64(200)}
+			got, overcommit := applyBudget(in, Budget{
+				MemoryMinLimit: tt.limit,
+				Policy:         tt.policy,
+			}, tt.used)
+
+			if overcommit != tt.wantCommit {
+				t.Errorf("overcommit = %v, want %v", overcommit, tt.wantCommit)
+			}
+			switch {
+			case tt.wantFloor == nil && got.MemoryMin != nil:
+				t.Errorf("MemoryMin = %d, want unset", *got.MemoryMin)
+			case tt.wantFloor != nil && got.MemoryMin == nil:
+				t.Errorf("MemoryMin unset, want %d", *tt.wantFloor)
+			case tt.wantFloor != nil && *got.MemoryMin != *tt.wantFloor:
+				t.Errorf("MemoryMin = %d, want %d", *got.MemoryMin, *tt.wantFloor)
+			}
+
+			// Every policy leaves the non-floor properties strictly alone.
+			if got.MemoryHigh == nil || *got.MemoryHigh != 1<<30 {
+				t.Error("memory.high must be applied unchanged by every policy")
+			}
+			if got.CPUWeight == nil || *got.CPUWeight != 200 {
+				t.Error("cpu.weight must be applied unchanged by every policy")
+			}
+		})
+	}
+}
+
+// The caller must not be able to mutate the request through the returned Props.
+func TestApplyBudgetDoesNotAliasTheRequest(t *testing.T) {
+	req := Props{MemoryMin: u64(6 << 30)}
+	got, _ := applyBudget(req, Budget{MemoryMinLimit: 10 << 30, Policy: BudgetClamp}, 7<<30)
+	if *req.MemoryMin != 6<<30 {
+		t.Fatalf("request floor mutated to %d", *req.MemoryMin)
+	}
+	if got.MemoryMin == req.MemoryMin {
+		t.Fatal("clamped floor aliases the caller's pointer")
+	}
+}
diff --git a/internal/cgroups/cgroups.go b/internal/cgroups/cgroups.go
new file mode 100644
index 0000000..5498002
--- /dev/null
+++ b/internal/cgroups/cgroups.go
@@ -0,0 +1,223 @@
+// Package cgroups manages per-server transient systemd slice units for
+// Wings-created containers.
+//
+// Placement (which slice a container is created under) is decided by
+// config.DockerConfiguration and applied through Docker's
+// HostConfig.CgroupParent. This package supplies the other half: making sure
+// the slice unit actually exists and carries the requested cgroup-v2 resource
+// properties (memory.min/low/high/max, cpu.weight, io.weight) BEFORE a
+// container is placed under it. Without this, systemd silently materializes a
+// transient slice with no resource properties — the cgroup path looks correct
+// while every intended guarantee is absent.
+//
+// Properties are applied exclusively through the systemd D-Bus API
+// (StartTransientUnit / SetUnitProperties with runtime=true), never through
+// raw cgroupfs writes: values owned by systemd are re-applied by systemd and
+// survive daemon-reload; raw cgroupfs writes can be wiped by it.
+package cgroups
+
+import (
+	"math"
+	"strconv"
+	"strings"
+
+	"emperror.dev/errors"
+)
+
+// Per-server environment variables recognized as slice property overrides.
+// They are expected to be defined as admin-only egg or server variables in the
+// Panel (user_viewable=false, user_editable=false). Like every server
+// environment variable the values are visible to the server process itself, so
+// they must only ever carry non-secret resource metadata. Wings does not trust
+// them: every value is parsed, validated and budget-checked before use.
+const (
+	EnvMemoryMin  = "WINGS_CG_MEMORY_MIN"
+	EnvMemoryLow  = "WINGS_CG_MEMORY_LOW"
+	EnvMemoryHigh = "WINGS_CG_MEMORY_HIGH"
+	EnvMemoryMax  = "WINGS_CG_MEMORY_MAX"
+	EnvCPUWeight  = "WINGS_CG_CPU_WEIGHT"
+	EnvIOWeight   = "WINGS_CG_IO_WEIGHT"
+)
+
+// Props are the systemd slice properties requested for a per-server slice.
+// Nil means "not requested": the slice keeps whatever systemd default or
+// previously-set value applies to that property.
+type Props struct {
+	MemoryMin  *uint64
+	MemoryLow  *uint64
+	MemoryHigh *uint64
+	MemoryMax  *uint64
+	CPUWeight  *uint64
+	IOWeight   *uint64
+}
+
+// Empty reports whether no property is requested at all.
+func (p Props) Empty() bool {
+	return p.MemoryMin == nil && p.MemoryLow == nil && p.MemoryHigh == nil &&
+		p.MemoryMax == nil && p.CPUWeight == nil && p.IOWeight == nil
+}
+
+// String renders the requested properties for logs.
+func (p Props) String() string {
+	var b strings.Builder
+	add := func(name string, v *uint64) {
+		if v != nil {
+			if b.Len() > 0 {
+				b.WriteByte(' ')
+			}
+			b.WriteString(name)
+			b.WriteByte('=')
+			b.WriteString(strconv.FormatUint(*v, 10))
+		}
+	}
+	add("MemoryMin", p.MemoryMin)
+	add("MemoryLow", p.MemoryLow)
+	add("MemoryHigh", p.MemoryHigh)
+	add("MemoryMax", p.MemoryMax)
+	add("CPUWeight", p.CPUWeight)
+	add("IOWeight", p.IOWeight)
+	if b.Len() == 0 {
+		return "(none)"
+	}
+	return b.String()
+}
+
+// Merge returns base with every property that is set in over replacing the
+// corresponding base property.
+func Merge(base, over Props) Props {
+	pick := func(b, o *uint64) *uint64 {
+		if o != nil {
+			return o
+		}
+		return b
+	}
+	return Props{
+		MemoryMin:  pick(base.MemoryMin, over.MemoryMin),
+		MemoryLow:  pick(base.MemoryLow, over.MemoryLow),
+		MemoryHigh: pick(base.MemoryHigh, over.MemoryHigh),
+		MemoryMax:  pick(base.MemoryMax, over.MemoryMax),
+		CPUWeight:  pick(base.CPUWeight, over.CPUWeight),
+		IOWeight:   pick(base.IOWeight, over.IOWeight),
+	}
+}
+
+// FromEnv extracts per-server slice property overrides from a resolved server
+// environment. Unparseable values are reported in errs and skipped; parsing
+// continues so that one bad value never discards the rest of the request.
+func FromEnv(env []string) (props Props, errs []error) {
+	vals := map[string]string{}
+	for _, kv := range env {
+		k, v, ok := strings.Cut(kv, "=")
+		if !ok {
+			continue
+		}
+		switch k {
+		case EnvMemoryMin, EnvMemoryLow, EnvMemoryHigh, EnvMemoryMax, EnvCPUWeight, EnvIOWeight:
+			vals[k] = v
+		}
+	}
+	set := func(name string, dst **uint64, parse func(string) (uint64, error)) {
+		s, ok := vals[name]
+		if !ok || s == "" {
+			return
+		}
+		v, err := parse(s)
+		if err != nil {
+			errs = append(errs, errors.Wrap(err, name))
+			return
+		}
+		*dst = &v
+	}
+	set(EnvMemoryMin, &props.MemoryMin, ParseSize)
+	set(EnvMemoryLow, &props.MemoryLow, ParseSize)
+	set(EnvMemoryHigh, &props.MemoryHigh, ParseSize)
+	set(EnvMemoryMax, &props.MemoryMax, ParseSize)
+	set(EnvCPUWeight, &props.CPUWeight, ParseWeight)
+	set(EnvIOWeight, &props.IOWeight, ParseWeight)
+	return props, errs
+}
+
+// Defaults are node-wide slice property defaults, carried as the raw strings
+// and integers found in the Wings configuration. Zero values mean "no
+// default" for the respective property.
+type Defaults struct {
+	MemoryMin  string
+	MemoryLow  string
+	MemoryHigh string
+	MemoryMax  string
+	CPUWeight  uint64
+	IOWeight   uint64
+}
+
+// Props parses the defaults into a property set. Invalid entries are reported
+// and skipped, mirroring FromEnv; configuration validation at startup should
+// have caught them long before this is ever hit at runtime.
+func (d Defaults) Props() (props Props, errs []error) {
+	set := func(name, s string, dst **uint64) {
+		if s == "" {
+			return
+		}
+		v, err := ParseSize(s)
+		if err != nil {
+			errs = append(errs, errors.Wrap(err, name))
+			return
+		}
+		*dst = &v
+	}
+	set("memory_min", d.MemoryMin, &props.MemoryMin)
+	set("memory_low", d.MemoryLow, &props.MemoryLow)
+	set("memory_high", d.MemoryHigh, &props.MemoryHigh)
+	set("memory_max", d.MemoryMax, &props.MemoryMax)
+	setW := func(name string, w uint64, dst **uint64) {
+		if w == 0 {
+			return
+		}
+		if w > 10000 {
+			errs = append(errs, errors.New(name+": weight out of range 1..10000"))
+			return
+		}
+		v := w
+		*dst = &v
+	}
+	setW("cpu_weight", d.CPUWeight, &props.CPUWeight)
+	setW("io_weight", d.IOWeight, &props.IOWeight)
+	return props, errs
+}
+
+// ParseSize parses "6G", "512M", "1024K" (single-letter binary suffixes,
+// case-insensitive) or a plain byte count into bytes.
+func ParseSize(s string) (uint64, error) {
+	t := strings.TrimSpace(s)
+	if t == "" {
+		return 0, errors.New("empty size")
+	}
+	mult := uint64(1)
+	switch t[len(t)-1] {
+	case 'G', 'g':
+		mult, t = 1<<30, t[:len(t)-1]
+	case 'M', 'm':
+		mult, t = 1<<20, t[:len(t)-1]
+	case 'K', 'k':
+		mult, t = 1<<10, t[:len(t)-1]
+	}
+	n, err := strconv.ParseUint(t, 10, 64)
+	if err != nil {
+		return 0, errors.New("invalid size " + strconv.Quote(s) + " (want e.g. 6G, 512M, 1024K or bytes)")
+	}
+	if mult > 1 && n > math.MaxUint64/mult {
+		return 0, errors.New("size " + strconv.Quote(s) + " overflows")
+	}
+	return n * mult, nil
+}
+
+// ParseWeight parses a systemd cgroup weight (1..10000).
+func ParseWeight(s string) (uint64, error) {
+	n, err := strconv.ParseUint(strings.TrimSpace(s), 10, 64)
+	if err != nil {
+		return 0, errors.New("invalid weight " + strconv.Quote(s))
+	}
+	if n < 1 || n > 10000 {
+		return 0, errors.New("weight " + strconv.FormatUint(n, 10) + " out of range 1..10000")
+	}
+	return n, nil
+}

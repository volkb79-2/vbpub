@@ -224,6 +284,156 @@ func (c DockerConfiguration) ResolveCgroupParent(env []string) (string, error) {
 	return c.CgroupParent, errors.New(CgroupParentOverrideEnv + " override " + strconv.Quote(override) + " is outside the built-in wings-*.slice namespace and docker.allowed_cgroup_parents is not configured")
 }
 
+// cgroupParentOverride extracts the raw (unvalidated) WINGS_CGROUP_PARENT
+// value from a resolved server environment; the last occurrence wins.
+func cgroupParentOverride(env []string) string {
+	override := ""
+	for _, v := range env {
+		if val, ok := strings.CutPrefix(v, CgroupParentOverrideEnv+"="); ok {
+			override = val
+		}
+	}
+	return override
+}
+
+// ServerSliceName derives the per-server slice unit name for a server UUID:
+// the node-wide CgroupParent with the dashless lowercase UUID appended, e.g.
+// "wings.slice" + "b87c0a5b-…" -> "wings-b87c0a5b23874a1c8863ff23e6800a1d.slice".
+// systemd's dash naming automatically nests it under CgroupParent. The UUID's
+// own dashes MUST be stripped: a dash in a slice unit name denotes a hierarchy
+// level. Returns "" when no valid name can be derived (no parent configured,
+// or a UUID that is not plain hex/dashes).
+func (c DockerConfiguration) ServerSliceName(uuid string) string {
+	base, ok := strings.CutSuffix(c.CgroupParent, ".slice")
+	if !ok || base == "" {
+		return ""
+	}
+	id := strings.ToLower(strings.ReplaceAll(uuid, "-", ""))
+	if id == "" {
+		return ""
+	}
+	for _, r := range id {
+		if !((r >= '0' && r <= '9') || (r >= 'a' && r <= 'f')) {
+			return ""
+		}
+	}
+	return base + "-" + id + ".slice"
+}
+
+// ResolveServerCgroupParent resolves the cgroup parent for a specific server,
+// taking per-server slice management into account. Resolution order:
+//
+//  1. an explicit WINGS_CGROUP_PARENT override, with exactly the fail-closed
+//     validation of ResolveCgroupParent. Setting the override to the node-wide
+//     CgroupParent value is an explicit opt-out from per-server slices for
+//     that server;
+//  2. the derived per-server slice (ServerSliceName) when
+//     docker.per_server_slices.enabled — including as the fallback for a
+//     rejected override, which is still reported through err;
+//  3. the node-wide CgroupParent.
+//
+// The managed return value reports whether Wings is responsible for ensuring
+// the returned slice exists (and carries its resource properties) before
+// containers are placed under it. The returned name is always safe to use.
+func (c DockerConfiguration) ResolveServerCgroupParent(uuid string, env []string) (parent string, managed bool, err error) {
+	parent, err = c.ResolveCgroupParent(env)
+	if !c.PerServerSlices.Enabled {
+		return parent, false, err
+	}
+	if override := cgroupParentOverride(env); override != "" {
+		if override == c.CgroupParent {
+			// Explicit opt-out: node-wide placement, no managed slice.
+			return c.CgroupParent, false, nil
+		}
+		if err == nil {
+			// Accepted override: Wings still ensures the slice exists (a
+			// missing unit would silently degrade to a limit-less transient
+			// slice) and applies explicit WINGS_CG_* properties, but never
+			// the node defaults — an override slice is hand-managed.
+			return parent, true, nil
+		}
+	}
+	if derived := c.ServerSliceName(uuid); derived != "" {
+		return derived, true, err
+	}
+	return parent, false, err
+}
+
+// ValidatePerServerSlices sanity-checks the docker.per_server_slices block at
+// startup so misconfiguration fails loudly at boot instead of surfacing as
+// per-server warnings at create time.
+func (c DockerConfiguration) ValidatePerServerSlices() error {
+	s := c.PerServerSlices
+	if !s.Enabled {
+		return nil
+	}
+	if c.CgroupParent == "" {
+		return errors.New("docker.per_server_slices requires docker.cgroup_parent to be set: derived per-server slices nest under it")
+	}
+	switch s.BudgetPolicy {
+	case cgroups.BudgetClamp, cgroups.BudgetRefuse, cgroups.BudgetDistribute:
+	default:
+		return errors.New("docker.per_server_slices.budget_policy must be \"clamp\", \"refuse\" or \"distribute\", not " + strconv.Quote(s.BudgetPolicy))
+	}
+	if s.MemoryMinBudget != "" {
+		if _, err := cgroups.ParseSize(s.MemoryMinBudget); err != nil {
+			return errors.Wrap(err, "docker.per_server_slices.memory_min_budget")
+		}
+	}
+	if _, errs := c.SliceDefaults().Props(); len(errs) > 0 {
+		return errors.Wrap(errs[0], "docker.per_server_slices.defaults")
+	}
+	return nil
+}
+
+// SliceDefaults converts the configured per-server slice defaults into the
+// internal/cgroups representation.
+func (c DockerConfiguration) SliceDefaults() cgroups.Defaults {
+	d := c.PerServerSlices.Defaults
+	return cgroups.Defaults{
+		MemoryMin:  d.MemoryMin,
+		MemoryLow:  d.MemoryLow,
+		MemoryHigh: d.MemoryHigh,
+		MemoryMax:  d.MemoryMax,
+		CPUWeight:  d.CPUWeight,
+		IOWeight:   d.IOWeight,
+	}
+}
+
+// SliceEnsureRequest assembles the cgroups.EnsureForServer request for a
+// server whose containers are about to be placed under slice (a value
+// previously returned as managed by ResolveServerCgroupParent).
+func (c DockerConfiguration) SliceEnsureRequest(uuid, slice string, env []string) cgroups.EnsureRequest {
+	return cgroups.EnsureRequest{
+		Slice:    slice,
+		Derived:  slice == c.ServerSliceName(uuid),
+		Defaults: c.SliceDefaults(),
+		Env:      env,
+		Budget:   c.SliceBudget(slice),
+	}
+}
+
+// SliceBudget converts the configured floor budget into the internal/cgroups
+// representation, excluding the slice currently being ensured from the
+// sibling sum. Derived slices share the parent's name prefix, so the sibling
+// pattern also covers admin-created wings-*.slice units — their floors draw
+// from the same parent budget.
+func (c DockerConfiguration) SliceBudget(exclude string) cgroups.Budget {
+	b := cgroups.Budget{
+		Policy:  c.PerServerSlices.BudgetPolicy,
+		Exclude: exclude,
+	}
+	if base, ok := strings.CutSuffix(c.CgroupParent, ".slice"); ok && base != "" {
+		b.SiblingPrefix = base + "-"
+	}
+	if c.PerServerSlices.MemoryMinBudget != "" {
+		if v, err := cgroups.ParseSize(c.PerServerSlices.MemoryMinBudget); err == nil {
+			b.MemoryMinLimit = v
+		}
+	}
+	return b
+}
+
 // RegistryConfiguration defines the authentication credentials for a given
 // Docker registry.
 type RegistryConfiguration struct {
diff --git a/config/config_docker_slices_test.go b/config/config_docker_slices_test.go
new file mode 100644
index 0000000..a86ac5a
--- /dev/null
+++ b/config/config_docker_slices_test.go
@@ -0,0 +1,168 @@
+package config
+
+import (
+	"testing"
+)
+
+const testUUID = "b87c0a5b-2387-4a1c-8863-ff23e6800a1d"
+const testDerived = "wings-b87c0a5b23874a1c8863ff23e6800a1d.slice"
+
+func slicesConfig(enabled bool) DockerConfiguration {
+	c := DockerConfiguration{CgroupParent: "wings.slice"}
+	c.PerServerSlices.Enabled = enabled
+	c.PerServerSlices.BudgetPolicy = "clamp"
+	return c
+}
+
+func TestServerSliceName(t *testing.T) {
+	c := slicesConfig(true)
+	if got := c.ServerSliceName(testUUID); got != testDerived {
+		t.Errorf("ServerSliceName = %q, want %q", got, testDerived)
+	}
+	// Dashes MUST be stripped: a dash denotes a systemd hierarchy level.
+	if got := c.ServerSliceName(testUUID); len(got) > 0 && got != testDerived {
+		t.Errorf("derived name must not contain UUID dashes: %q", got)
+	}
+	c.CgroupParent = ""
+	if got := c.ServerSliceName(testUUID); got != "" {
+		t.Errorf("no parent must derive nothing, got %q", got)
+	}
+	c.CgroupParent = "wings.slice"
+	if got := c.ServerSliceName("../etc; rm"); got != "" {
+		t.Errorf("non-hex uuid must derive nothing, got %q", got)
+	}
+	if got := c.ServerSliceName(""); got != "" {
+		t.Errorf("empty uuid must derive nothing, got %q", got)
+	}
+}
+
+func TestResolveServerCgroupParentDisabledPassthrough(t *testing.T) {
+	c := slicesConfig(false)
+	parent, managed, err := c.ResolveServerCgroupParent(testUUID, nil)
+	if err != nil || managed || parent != "wings.slice" {
+		t.Errorf("disabled feature must behave exactly like ResolveCgroupParent: %q %v %v", parent, managed, err)
+	}
+	parent, managed, err = c.ResolveServerCgroupParent(testUUID, []string{"WINGS_CGROUP_PARENT=wings-custom.slice"})
+	if err != nil || managed || parent != "wings-custom.slice" {
+		t.Errorf("disabled feature must still honor plain overrides unmanaged: %q %v %v", parent, managed, err)
+	}
+}
+
+func TestResolveServerCgroupParentDerived(t *testing.T) {
+	c := slicesConfig(true)
+	parent, managed, err := c.ResolveServerCgroupParent(testUUID, []string{"SERVER_MEMORY=1024"})
+	if err != nil {
+		t.Fatalf("unexpected error: %v", err)
+	}
+	if !managed || parent != testDerived {
+		t.Errorf("want managed derived slice, got %q managed=%v", parent, managed)
+	}
+}
+
+func TestResolveServerCgroupParentExplicitOverride(t *testing.T) {
+	c := slicesConfig(true)
+	parent, managed, err := c.ResolveServerCgroupParent(testUUID, []string{"WINGS_CGROUP_PARENT=wings-custom.slice"})
+	if err != nil {
+		t.Fatalf("unexpected error: %v", err)
+	}
+	if !managed || parent != "wings-custom.slice" {
+		t.Errorf("accepted override must be managed: %q managed=%v", parent, managed)
+	}
+}
+
+func TestResolveServerCgroupParentOptOut(t *testing.T) {
+	// Overriding with exactly the node-wide value is the explicit opt-out
+	// from per-server slice management for one server.
+	c := slicesConfig(true)
+	parent, managed, err := c.ResolveServerCgroupParent(testUUID, []string{"WINGS_CGROUP_PARENT=wings.slice"})
+	if err != nil {
+		t.Fatalf("unexpected error: %v", err)
+	}
+	if managed || parent != "wings.slice" {
+		t.Errorf("opt-out must return unmanaged node parent, got %q managed=%v", parent, managed)
+	}
+}
+
+func TestResolveServerCgroupParentRejectedOverrideFallsToDerived(t *testing.T) {
+	c := slicesConfig(true)
+	parent, managed, err := c.ResolveServerCgroupParent(testUUID, []string{"WINGS_CGROUP_PARENT=system.slice"})
+	if err == nil {
+		t.Fatal("rejected override must still be reported")
+	}
+	if !managed || parent != testDerived {
+		t.Errorf("rejected override must fall to the managed derived slice, got %q managed=%v", parent, managed)
+	}
+}
+
+func TestResolveServerCgroupParentDerivationFailureFallsToNodeDefault(t *testing.T) {
+	c := slicesConfig(true)
+	parent, managed, err := c.ResolveServerCgroupParent("not-a-uuid-zz", nil)
+	if err != nil {
+		t.Fatalf("unexpected error: %v", err)
+	}
+	if managed || parent != "wings.slice" {
+		t.Errorf("underivable uuid must fall back unmanaged to node default, got %q managed=%v", parent, managed)
+	}
+}
+
+func TestValidatePerServerSlices(t *testing.T) {
+	c := slicesConfig(false)
+	c.CgroupParent = ""
+	if err := c.ValidatePerServerSlices(); err != nil {
+		t.Errorf("disabled block must always validate, got %v", err)
+	}
+
+	c = slicesConfig(true)
+	if err := c.ValidatePerServerSlices(); err != nil {
+		t.Errorf("minimal enabled block must validate, got %v", err)
+	}
+
+	c.CgroupParent = ""
+	if err := c.ValidatePerServerSlices(); err == nil {
+		t.Error("enabled without cgroup_parent must fail")
+	}
+
+	for _, policy := range []string{"clamp", "refuse", "distribute"} {
+		c = slicesConfig(true)
+		c.PerServerSlices.BudgetPolicy = policy
+		if err := c.ValidatePerServerSlices(); err != nil {
+			t.Errorf("budget_policy %q must validate, got %v", policy, err)
+		}
+	}
+
+	c = slicesConfig(true)
+	c.PerServerSlices.BudgetPolicy = "explode"
+	if err := c.ValidatePerServerSlices(); err == nil {
+		t.Error("unknown budget_policy must fail")
+	}
+
+	c = slicesConfig(true)
+	c.PerServerSlices.MemoryMinBudget = "banana"
+	if err := c.ValidatePerServerSlices(); err == nil {
+		t.Error("unparseable memory_min_budget must fail")
+	}
+
+	c = slicesConfig(true)
+	c.PerServerSlices.Defaults.MemoryMin = "banana"
+	if err := c.ValidatePerServerSlices(); err == nil {
+		t.Error("unparseable default must fail")
+	}
+}
+
+func TestSliceBudget(t *testing.T) {
+	c := slicesConfig(true)
+	c.PerServerSlices.MemoryMinBudget = "8G"
+	b := c.SliceBudget(testDerived)
+	if b.MemoryMinLimit != 8<<30 {
+		t.Errorf("MemoryMinLimit = %d, want 8G", b.MemoryMinLimit)
+	}
+	if b.SiblingPrefix != "wings-" {
+		t.Errorf("SiblingPrefix = %q, want wings-", b.SiblingPrefix)
+	}
+	if b.Exclude != testDerived {
+		t.Errorf("Exclude = %q", b.Exclude)
+	}
+	if b.Policy != "clamp" {
+		t.Errorf("Policy = %q", b.Policy)
+	}
+}

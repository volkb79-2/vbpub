+	// With every server configuration known, garbage-collect derived
+	// per-server slices left behind by servers that were deleted while Wings
+	// was not running. Administrator-owned unit-file slices are never touched.
+	if cfg := config.Get().Docker; cfg.PerServerSlices.Enabled {
+		known := make(map[string]struct{}, manager.Len())
+		for _, s := range manager.All() {
+			if name := cfg.ServerSliceName(s.ID()); name != "" {
+				known[name] = struct{}{}
+			}
+		}
+		if prefix := cfg.SliceBudget("").SiblingPrefix; prefix != "" {
+			go func() {
+				ctx, cancel := context.WithTimeout(cmd.Context(), time.Minute)
+				defer cancel()
+				stopped, err := cgroups.CleanupOrphans(ctx, prefix, func(name string) bool {
+					_, ok := known[name]
+					return ok
+				})
+				if err != nil {
+					log.WithField("error", err).Warn("failed to garbage-collect orphaned per-server slices")
+				}
+				for _, name := range stopped {
+					log.WithField("slice", name).Info("garbage-collected orphaned per-server slice")
+				}
+			}()
+		}
+	}
+
 	states, err := manager.ReadStates()
 	if err != nil {
 		log.WithField("error", err).Error("failed to retrieve locally cached server states from disk, assuming all servers in offline state")

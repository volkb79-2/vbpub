index 0000000..11c235f
--- /dev/null
+++ b/internal/cgroups/cgroups_test.go
@@ -0,0 +1,183 @@
+package cgroups
+
+import (
+	"testing"
+)
+
+func u64(v uint64) *uint64 { return &v }
+
+func TestParseSize(t *testing.T) {
+	cases := []struct {
+		in      string
+		want    uint64
+		wantErr bool
+	}{
+		{"6G", 6 << 30, false},
+		{"512M", 512 << 20, false},
+		{"1024K", 1 << 20, false},
+		{"123", 123, false},
+		{"6g", 6 << 30, false},
+		{" 8G ", 8 << 30, false},
+		{"", 0, true},
+		{"abc", 0, true},
+		{"6GB", 0, true},
+		{"-1", 0, true},
+		{"99999999999G", 0, true}, // overflow
+	}
+	for _, c := range cases {
+		got, err := ParseSize(c.in)
+		if c.wantErr != (err != nil) {
+			t.Errorf("ParseSize(%q) error = %v, wantErr %v", c.in, err, c.wantErr)
+			continue
+		}
+		if err == nil && got != c.want {
+			t.Errorf("ParseSize(%q) = %d, want %d", c.in, got, c.want)
+		}
+	}
+}
+
+func TestParseWeight(t *testing.T) {
+	for _, c := range []struct {
+		in      string
+		want    uint64
+		wantErr bool
+	}{
+		{"1", 1, false},
+		{"800", 800, false},
+		{"10000", 10000, false},
+		{"0", 0, true},
+		{"10001", 0, true},
+		{"abc", 0, true},
+		{"", 0, true},
+	} {
+		got, err := ParseWeight(c.in)
+		if c.wantErr != (err != nil) {
+			t.Errorf("ParseWeight(%q) error = %v, wantErr %v", c.in, err, c.wantErr)
+			continue
+		}
+		if err == nil && got != c.want {
+			t.Errorf("ParseWeight(%q) = %d, want %d", c.in, got, c.want)
+		}
+	}
+}
+
+func TestFromEnv(t *testing.T) {
+	props, errs := FromEnv([]string{
+		"SERVER_MEMORY=8192",
+		EnvMemoryMin + "=6G",
+		EnvMemoryHigh + "=7G",
+		EnvCPUWeight + "=800",
+		"UNRELATED=x",
+	})
+	if len(errs) != 0 {
+		t.Fatalf("unexpected errors: %v", errs)
+	}
+	if props.MemoryMin == nil || *props.MemoryMin != 6<<30 {
+		t.Errorf("MemoryMin = %v, want 6G", props.MemoryMin)
+	}
+	if props.MemoryHigh == nil || *props.MemoryHigh != 7<<30 {
+		t.Errorf("MemoryHigh = %v, want 7G", props.MemoryHigh)
+	}
+	if props.CPUWeight == nil || *props.CPUWeight != 800 {
+		t.Errorf("CPUWeight = %v, want 800", props.CPUWeight)
+	}
+	if props.MemoryLow != nil || props.MemoryMax != nil || props.IOWeight != nil {
+		t.Errorf("unexpected properties set: %s", props)
+	}
+}
+
+func TestFromEnvBadValueDoesNotDiscardRest(t *testing.T) {
+	props, errs := FromEnv([]string{
+		EnvMemoryMin + "=banana",
+		EnvMemoryHigh + "=1G",
+	})
+	if len(errs) != 1 {
+		t.Fatalf("want exactly one error, got %v", errs)
+	}
+	if props.MemoryMin != nil {
+		t.Error("bad MemoryMin should be skipped")
+	}
+	if props.MemoryHigh == nil || *props.MemoryHigh != 1<<30 {
+		t.Error("valid MemoryHigh should survive a bad sibling value")
+	}
+}
+
+func TestFromEnvLastOccurrenceWins(t *testing.T) {
+	props, errs := FromEnv([]string{EnvMemoryMin + "=1G", EnvMemoryMin + "=2G"})
+	if len(errs) != 0 {
+		t.Fatalf("unexpected errors: %v", errs)
+	}
+	if props.MemoryMin == nil || *props.MemoryMin != 2<<30 {
+		t.Errorf("MemoryMin = %v, want the later 2G", props.MemoryMin)
+	}
+}
+
+func TestMerge(t *testing.T) {
+	base := Props{MemoryMin: u64(1), MemoryHigh: u64(2), CPUWeight: u64(100)}
+	over := Props{MemoryMin: u64(9), IOWeight: u64(500)}
+	got := Merge(base, over)
+	if *got.MemoryMin != 9 {
+		t.Errorf("override must win: MemoryMin = %d", *got.MemoryMin)
+	}
+	if *got.MemoryHigh != 2 || *got.CPUWeight != 100 {
+		t.Error("base values without override must survive")
+	}
+	if *got.IOWeight != 500 {
+		t.Error("override-only values must be picked up")
+	}
+	if got.MemoryLow != nil || got.MemoryMax != nil {
+		t.Error("unset on both sides must stay unset")
+	}
+}
+
+func TestDefaultsProps(t *testing.T) {
+	props, errs := Defaults{MemoryMin: "6G", MemoryHigh: "7G", CPUWeight: 800}.Props()
+	if len(errs) != 0 {
+		t.Fatalf("unexpected errors: %v", errs)
+	}
+	if props.MemoryMin == nil || *props.MemoryMin != 6<<30 ||
+		props.MemoryHigh == nil || *props.MemoryHigh != 7<<30 ||
+		props.CPUWeight == nil || *props.CPUWeight != 800 {
+		t.Errorf("unexpected props: %s", props)
+	}
+	if props.MemoryLow != nil || props.MemoryMax != nil || props.IOWeight != nil {
+		t.Errorf("zero-value defaults must stay unset: %s", props)
+	}
+
+	if _, errs := (Defaults{MemoryMin: "banana"}).Props(); len(errs) != 1 {
+		t.Errorf("invalid default size must be reported, got %v", errs)
+	}
+	if _, errs := (Defaults{CPUWeight: 20000}).Props(); len(errs) != 1 {
+		t.Errorf("out-of-range default weight must be reported, got %v", errs)
+	}
+}
+
+func TestPropsString(t *testing.T) {
+	if s := (Props{}).String(); s != "(none)" {
+		t.Errorf("empty props = %q", s)
+	}
+	p := Props{MemoryMin: u64(64 << 20), CPUWeight: u64(800)}
+	if s := p.String(); s != "MemoryMin=67108864 CPUWeight=800" {
+		t.Errorf("props string = %q", s)
+	}
+}
+
+func TestIsDerivedName(t *testing.T) {
+	for _, c := range []struct {
+		name string
+		want bool
+	}{
+		{"wings-b87c0a5b23874a1c8863ff23e6800a1d.slice", true},
+		{"wings-b87c0a5b.slice", false},                            // admin short-form, not derived shape
+		{"wings-B87C0A5B23874A1C8863FF23E6800A1D.slice", false},    // uppercase never derived
+		{"wings-b87c0a5b23874a1c8863ff23e6800a1d", false},          // missing suffix
+		{"other-b87c0a5b23874a1c8863ff23e6800a1d.slice", false},    // wrong prefix
+		{"wings-g87c0a5b23874a1c8863ff23e6800a1d.slice", false},    // non-hex
+		{"wings-b87c0a5b23874a1c8863ff23e6800a1d00.slice", false},  // wrong length
+		{"wings.slice", false},
+	} {
+		if got := isDerivedName(c.name, "wings-"); got != c.want {
+			t.Errorf("isDerivedName(%q) = %v, want %v", c.name, got, c.want)
+		}
+	}
+}
diff --git a/internal/cgroups/ensure.go b/internal/cgroups/ensure.go
new file mode 100644
index 0000000..003dccb
--- /dev/null
+++ b/internal/cgroups/ensure.go
@@ -0,0 +1,75 @@
+package cgroups
+
+import (
+	"context"
+	"time"
+
+	"github.com/apex/log"
+)
+
+// ensureTimeout bounds a single systemd D-Bus round trip. Slice management is
+// best-effort decoration of container creation and must never stall it.
+const ensureTimeout = 10 * time.Second
+
+// EnsureRequest carries everything needed to ensure one server's slice. It is
+// normally built by config.DockerConfiguration.SliceEnsureRequest.
+type EnsureRequest struct {
+	// Slice is the resolved cgroup parent unit name for the server.
+	Slice string
+	// Derived reports whether Slice is the Wings-derived per-server slice
+	// (as opposed to an explicit WINGS_CGROUP_PARENT override). Only derived
+	// slices receive the node-wide property defaults.
+	Derived bool
+	// Defaults are the node-wide slice property defaults.
+	Defaults Defaults
+	// Env is the resolved server environment, the source of the per-server
+	// WINGS_CG_* property overrides.
+	Env []string
+	// Budget bounds the memory.min floor this request may claim.
+	Budget Budget
+}
+
+// EnsureForServer ensures a server's slice unit exists and carries its
+// resource properties, logging instead of failing: without the unit, systemd
+// still materializes a limit-less transient slice at container placement, so
+// the container runs either way — just without the guarantees, which is
+// exactly what the emitted warning tells the administrator.
+func EnsureForServer(ctx context.Context, l *log.Entry, req EnsureRequest) {
+	props, errs := FromEnv(req.Env)
+	if req.Derived {
+		defaults, derrs := req.Defaults.Props()
+		errs = append(errs, derrs...)
+		props = Merge(defaults, props)
+	}
+	for _, err := range errs {
+		l.WithField("slice", req.Slice).WithError(err).Warn("cgroups: ignoring invalid per-server slice property")
+	}
+
+	ctx, cancel := context.WithTimeout(ctx, ensureTimeout)
+	defer cancel()
+	requested := props.String()
+	res, err := Ensure(ctx, req.Slice, props, req.Budget)
+	if err != nil {
+		l.WithField("slice", req.Slice).WithError(err).Warn("cgroups: could not ensure per-server slice; containers will run under it without managed resource properties")
+		return
+	}
+	entry := l.WithField("slice", req.Slice).WithField("properties", res.Applied.String())
+	if s := res.Applied.String(); s != requested {
+		entry.WithField("requested", requested).Warn("cgroups: memory.min floor reduced by the node budget (docker.per_server_slices.memory_min_budget)")
+		return
+	}
+	if res.Overcommit {
+		// budget_policy: distribute. Applied == requested, so this is not a
+		// reduction — but the floors on this node now add up to more than the
+		// parent slice can back, which changes what they mean: the kernel will
+		// share the parent's protection out in proportion to each server's
+		// usage below its own floor rather than honouring all of them.
+		entry.WithFields(log.Fields{
+			"requested_floor": *props.MemoryMin,
+			"sibling_floors":  res.BudgetUsed,
+			"budget":          res.BudgetLimit,
+		}).Info("cgroups: per-server memory.min floors exceed the node budget; policy \"distribute\" applies them as requested and lets the kernel share the parent slice's protection proportionally to each server's usage")
+		return
+	}
+	entry.Info("cgroups: ensured per-server slice")
+}
diff --git a/internal/cgroups/integration_test.go b/internal/cgroups/integration_test.go
new file mode 100644
index 0000000..359ade4
--- /dev/null
+++ b/internal/cgroups/integration_test.go
@@ -0,0 +1,198 @@
+//go:build systemdintegration
+
+package cgroups
+
+// Integration tests against a REAL systemd instance over D-Bus. They create
+// and remove transient wings-*.slice units, so never point them at a
+// production host; they are made to run inside the project's privileged
+// systemd-in-Docker e2e container:
+//
+//	go test -tags systemdintegration ./internal/cgroups/
+
+import (
+	"context"
+	"testing"
+	"time"
+)
+
+const (
+	itSliceA = "wings-00000000000000000000000000000001.slice"
+	itSliceB = "wings-00000000000000000000000000000002.slice"
+)
+
+func itCtx(t *testing.T) context.Context {
+	ctx, cancel := context.WithTimeout(context.Background(), 30*time.Second)
+	t.Cleanup(cancel)
+	return ctx
+}
+
+func itUnitProp(t *testing.T, ctx context.Context, unit, name string) uint64 {
+	t.Helper()
+	c, err := connect(ctx)
+	if err != nil {
+		t.Fatalf("connect: %v", err)
+	}
+	defer c.close()
+	prop, err := c.dbus.GetUnitTypePropertyContext(ctx, unit, "Slice", name)
+	if err != nil {
+		t.Fatalf("reading %s of %s: %v", name, unit, err)
+	}
+	v, ok := prop.Value.Value().(uint64)
+	if !ok {
+		t.Fatalf("%s of %s has unexpected type %T", name, unit, prop.Value.Value())
+	}
+	return v
+}
+
+func itActiveState(t *testing.T, ctx context.Context, unit string) string {
+	t.Helper()
+	c, err := connect(ctx)
+	if err != nil {
+		t.Fatalf("connect: %v", err)
+	}
+	defer c.close()
+	prop, err := c.dbus.GetUnitPropertyContext(ctx, unit, "ActiveState")
+	if err != nil {
+		return "unknown"
+	}
+	s, _ := prop.Value.Value().(string)
+	return s
+}
+
+func TestSliceLifecycleIntegration(t *testing.T) {
+	ctx := itCtx(t)
+	t.Cleanup(func() {
+		cctx, cancel := context.WithTimeout(context.Background(), 10*time.Second)
+		defer cancel()
+		_ = Stop(cctx, itSliceA)
+		_ = Stop(cctx, itSliceB)
+	})
+
+	// The test environment may carry other wings-*.slice floors (unit files
+	// from other e2e sections); express the budget relative to that baseline
+	// so the arithmetic below is deterministic regardless.
+	c, err := connect(ctx)
+	if err != nil {
+		t.Fatalf("connecting to systemd: %v", err)
+	}
+	baseline, err := c.sumMemoryMin(ctx, "wings-", "")
+	c.close()
+	if err != nil {
+		t.Fatalf("baseline floor sum: %v", err)
+	}
+
+	// 1. Create a transient slice with properties.
+	res, err := Ensure(ctx, itSliceA, Props{MemoryMin: u64(64 << 20), MemoryHigh: u64(96 << 20), CPUWeight: u64(800)}, Budget{})
+	if err != nil {
+		t.Fatalf("Ensure(A): %v", err)
+	}
+	if res.Applied.MemoryMin == nil || *res.Applied.MemoryMin != 64<<20 {
+		t.Fatalf("Ensure(A) applied = %s", res.Applied)
+	}
+	if res.Overcommit {
+		t.Errorf("Ensure(A) with no budget must not report overcommit")
+	}
+	if got := itUnitProp(t, ctx, itSliceA, "MemoryMin"); got != 64<<20 {
+		t.Errorf("A MemoryMin = %d, want 64M", got)
+	}
+	if got := itUnitProp(t, ctx, itSliceA, "CPUWeight"); got != 800 {
+		t.Errorf("A CPUWeight = %d, want 800", got)
+	}
+
+	// 2. Re-ensure updates the loaded unit in place (runtime SetUnitProperties).
+	if _, err := Ensure(ctx, itSliceA, Props{MemoryMin: u64(32 << 20)}, Budget{}); err != nil {
+		t.Fatalf("Ensure(A) update: %v", err)
+	}
+	if got := itUnitProp(t, ctx, itSliceA, "MemoryMin"); got != 32<<20 {
+		t.Errorf("A MemoryMin after update = %d, want 32M", got)
+	}
+	if _, err := Ensure(ctx, itSliceA, Props{MemoryMin: u64(64 << 20)}, Budget{}); err != nil {
+		t.Fatalf("Ensure(A) restore: %v", err)
+	}
+
+	// 3. Budget clamp: 96M budget above baseline, A holds 64M -> B gets 32M.
+	budget := Budget{
+		MemoryMinLimit: baseline + 96<<20,
+		Policy:         BudgetClamp,
+		SiblingPrefix:  "wings-",
+		Exclude:        itSliceB,
+	}
+	res, err = Ensure(ctx, itSliceB, Props{MemoryMin: u64(64 << 20)}, budget)
+	if err != nil {
+		t.Fatalf("Ensure(B): %v", err)
+	}
+	if res.Applied.MemoryMin == nil || *res.Applied.MemoryMin != 32<<20 {
+		t.Errorf("B clamped MemoryMin = %s, want 32M", res.Applied)
+	}
+	if !res.Overcommit {
+		t.Errorf("B clamp must report overcommit")
+	}
+	if got := itUnitProp(t, ctx, itSliceB, "MemoryMin"); got != 32<<20 {
+		t.Errorf("B MemoryMin = %d, want clamped 32M", got)
+	}
+
+	// 4. Budget refuse: no remaining budget -> floor request dropped, other
+	// properties still applied.
+	budget.Policy = BudgetRefuse
+	budget.MemoryMinLimit = baseline + 64<<20
+	res, err = Ensure(ctx, itSliceB, Props{MemoryMin: u64(64 << 20), MemoryHigh: u64(48 << 20)}, budget)
+	if err != nil {
+		t.Fatalf("Ensure(B) refuse: %v", err)
+	}
+	if res.Applied.MemoryMin != nil {
+		t.Errorf("refused MemoryMin must be dropped, applied = %s", res.Applied)
+	}
+	if got := itUnitProp(t, ctx, itSliceB, "MemoryHigh"); got != 48<<20 {
+		t.Errorf("B MemoryHigh = %d, want 48M applied despite refused floor", got)
+	}
+
+	// 4b. Budget distribute: the over-budget floor is applied verbatim and the
+	// overcommit is reported rather than corrected — the kernel shares the
+	// parent's protection out by usage instead.
+	budget.Policy = BudgetDistribute
+	res, err = Ensure(ctx, itSliceB, Props{MemoryMin: u64(64 << 20)}, budget)
+	if err != nil {
+		t.Fatalf("Ensure(B) distribute: %v", err)
+	}
+	if res.Applied.MemoryMin == nil || *res.Applied.MemoryMin != 64<<20 {
+		t.Errorf("distribute must apply the floor as requested, applied = %s", res.Applied)
+	}
+	if !res.Overcommit {
+		t.Errorf("distribute must still report the overcommit")
+	}
+	if got := itUnitProp(t, ctx, itSliceB, "MemoryMin"); got != 64<<20 {
+		t.Errorf("B MemoryMin = %d, want the requested 64M under distribute", got)
+	}
+
+	// 5. Orphan cleanup stops derived slices not kept, leaves kept ones.
+	stopped, err := CleanupOrphans(ctx, "wings-", func(name string) bool { return name == itSliceB })
+	if err != nil {
+		t.Fatalf("CleanupOrphans: %v", err)
+	}
+	found := false
+	for _, name := range stopped {
+		if name == itSliceA {
+			found = true
+		}
+		if name == itSliceB {
+			t.Error("kept slice was stopped")
+		}
+	}
+	if !found {
+		t.Errorf("orphan A not stopped; stopped = %v", stopped)
+	}
+	if s := itActiveState(t, ctx, itSliceA); s == "active" {
+		t.Errorf("A still active after orphan cleanup")
+	}
+	if s := itActiveState(t, ctx, itSliceB); s != "active" {
+		t.Errorf("B no longer active after orphan cleanup: %s", s)
+	}
+
+	// 6. Stop is idempotent: a second stop of a gone unit is not an error.
+	if err := Stop(ctx, itSliceB); err != nil {
+		t.Fatalf("Stop(B): %v", err)
+	}
+	if err := Stop(ctx, itSliceB); err != nil {
+		t.Errorf("Stop(B) again must tolerate a not-loaded unit: %v", err)
+	}
+}
diff --git a/internal/cgroups/sysd.go b/internal/cgroups/sysd.go
new file mode 100644
index 0000000..79fd3ca
--- /dev/null
+++ b/internal/cgroups/sysd.go
@@ -0,0 +1,416 @@
+package cgroups
+
+import (
+	"context"
+	"os"
+	"strconv"
+	"strings"
+	"sync"
+
+	sdbus "github.com/coreos/go-systemd/v22/dbus"
+	godbus "github.com/godbus/dbus/v5"
+
+	"emperror.dev/errors"
+)
+
+// Budget bounds the memory.min floors Wings may hand out across the managed
+// slices of a node. Floors are only guarantees when the parent slice's own
+// MemoryMin covers their sum — an over-committed budget silently weakens
+// every child floor, so Wings enforces the arithmetic at apply time.
+type Budget struct {
+	// MemoryMinLimit is the total number of bytes available for child
+	// MemoryMin floors, normally matching the parent slice's MemoryMin.
+	// 0 disables budget checking entirely.
+	MemoryMinLimit uint64
+	// Policy is what happens to a MemoryMin request that exceeds the
+	// remaining budget: BudgetClamp (default), BudgetRefuse or
+	// BudgetDistribute. Every other property is applied unchanged regardless.
+	Policy string
+	// SiblingPrefix is the unit-name prefix ("wings-") used to discover the
+	// sibling slices whose MemoryMin values already draw from the budget.
+	SiblingPrefix string
+	// Exclude is a unit name skipped in the sibling sum, i.e. the slice
+	// currently being (re-)ensured, whose old floor is being replaced.
+	Exclude string
+}
+
+// BudgetPolicy values for Budget.Policy / docker.per_server_slices.budget_policy.
+//
+// The three policies answer one question — what to do when the per-server
+// memory.min floors on a node add up to more than the parent slice can back:
+//
+//   - BudgetClamp keeps every granted floor honest by shrinking the newest
+//     request to the room that is left. A server that starts late gets a
+//     smaller guarantee than its egg asks for, permanently, no matter how busy
+//     it is. Right for nodes selling per-server guarantees.
+//   - BudgetRefuse drops the floor entirely rather than granting a smaller one
+//     than requested, on the theory that a half guarantee is worse than none.
+//   - BudgetDistribute applies floors as requested and lets the kernel resolve
+//     the shortfall. This is not a loophole: on overcommit the kernel hands
+//     each child a share of the parent's protection in proportion to
+//     min(usage, floor) — its usage *below* its own floor. An idle server
+//     therefore claims little and a hot one keeps most of the tier's protected
+//     memory, with the split re-evaluated continuously as usage moves. Right
+//     for nodes running co-operating servers (e.g. two instances of one game)
+//     where a static carve-up would strand memory in whichever server happens
+//     to be quiet. The cost is that no single server's floor is a guarantee any
+//     more; the tier's total is.
+const (
+	BudgetClamp      = "clamp"
+	BudgetRefuse     = "refuse"
+	BudgetDistribute = "distribute"
+)
+
+// budgetMu serializes the floor-budget read-modify-write in Ensure. See the
+// comment at its acquisition for why the critical section spans the apply.
+var budgetMu sync.Mutex
+
+// applyBudget resolves a MemoryMin request against the node floor budget,
+// given the floors already claimed by the sibling slices. It reports the
+// properties to apply and whether the request overcommitted the budget.
+//
+// Split out from Ensure so the policy table is testable without systemd: this
+// is the arithmetic that decides whether an administrator's floor is honoured,
+// shrunk or dropped, and it is the part worth being sure about.
+func applyBudget(props Props, b Budget, used uint64) (Props, bool) {
+	if props.MemoryMin == nil || b.MemoryMinLimit == 0 {
+		return props, false
+	}
+	var avail uint64
+	if b.MemoryMinLimit > used {
+		avail = b.MemoryMinLimit - used
+	}
+	if *props.MemoryMin <= avail {
+		return props, false
+	}
+	switch b.Policy {
+	case BudgetRefuse:
+		props.MemoryMin = nil
+	case BudgetDistribute:
+		// Applied as requested on purpose: the kernel resolves the shortfall
+		// by usage-proportional distribution, which tracks load instead of
+		// freezing an arbitrary split at start time.
+	default: // BudgetClamp
+		clamped := avail
+		props.MemoryMin = &clamped
+	}
+	return props, true
+}
+
+// Result reports what Ensure did, so the caller can log it. Applied is
+// authoritative — it is what systemd was actually asked for.
+type Result struct {
+	// Applied are the properties set on the slice, after budget enforcement.
+	Applied Props
+	// BudgetLimit and BudgetUsed are the node floor budget and the sum of the
+	// sibling floors already drawing on it. Both 0 when no budget is
+	// configured or the request carries no MemoryMin.
+	BudgetLimit uint64
+	BudgetUsed  uint64
+	// Overcommit reports that the requested MemoryMin exceeded the budget
+	// remainder. Under BudgetClamp/BudgetRefuse, Applied differs from the
+	// request as a result; under BudgetDistribute the request was applied
+	// as-is and the kernel will share the parent's protection out instead.
+	Overcommit bool
+}
+
+// conn wraps the systemd D-Bus connection. Connections are opened per
+// operation: slice management happens a handful of times per server lifecycle,
+// and a fresh connection sidesteps every stale-socket concern of a long-lived
+// one.
+type conn struct {
+	dbus *sdbus.Conn
+}
+
+// systemBusAddresses lists the D-Bus system bus addresses to try, in order.
+//
+// The D-Bus client library dials a compile-time default of
+// /var/run/dbus/system_bus_socket. That resolves on any distribution where
+// /var/run is a symlink to /run, but Wings ships a distroless image which has
+// no /var/run at all — so the conventional
+// `-v /run/dbus/system_bus_socket:/run/dbus/system_bus_socket` mount is
+// invisible to it and slice management silently degrades to placement-only.
+// Try the modern path first, then the library default, and let an explicit
+// DBUS_SYSTEM_BUS_ADDRESS override both.
+func systemBusAddresses() []string {
+	if a := os.Getenv("DBUS_SYSTEM_BUS_ADDRESS"); a != "" {
+		return []string{a}
+	}
+	return []string{
+		"unix:path=/run/dbus/system_bus_socket",
+		"unix:path=/var/run/dbus/system_bus_socket",
+	}
+}
+
+// dialSystemBus connects to the D-Bus broker at addr, performing the same
+// EXTERNAL auth + Hello handshake go-systemd does internally. The uid is
+// passed as a literal so authentication never needs a username lookup (Wings
+// builds with CGO_ENABLED=0 and runs from a distroless image).
+func dialSystemBus(ctx context.Context, addr string) (*sdbus.Conn, error) {
+	return sdbus.NewConnection(func() (*godbus.Conn, error) {
+		c, err := godbus.Dial(addr, godbus.WithContext(ctx))
+		if err != nil {
+			return nil, err
+		}
+		if err := c.Auth([]godbus.Auth{godbus.AuthExternal(strconv.Itoa(os.Getuid()))}); err != nil {
+			_ = c.Close()
+			return nil, err
+		}
+		if err := c.Hello(); err != nil {
+			_ = c.Close()
+			return nil, err
+		}
+		return c, nil
+	})
+}
+
+// connect reaches systemd over the system message bus, falling back to
+// systemd's private socket (/run/systemd/private, root only) for hosts that
+// run systemd without a D-Bus broker. A containerized Wings needs one of the
+// two bind-mounted from the host.
+//
+// Deliberately not sdbus.NewWithContext: that helper tries the system bus,
+// discards its error, and — when running as root — reports only the private
+// socket's failure. A missing or misplaced bus mount therefore surfaces as
+// "dial unix /run/systemd/private: no such file or directory", naming a path
+// the administrator never configured while hiding the one that actually
+// failed. Dialing each candidate here keeps every attempt in the error.
+func connect(ctx context.Context) (*conn, error) {
+	tried := make([]string, 0, 3)
+	for _, addr := range systemBusAddresses() {
+		c, err := dialSystemBus(ctx, addr)
+		if err == nil {
+			return &conn{dbus: c}, nil
+		}
+		tried = append(tried, addr+": "+err.Error())
+	}
+	c, err := sdbus.NewSystemdConnectionContext(ctx)
+	if err == nil {
+		return &conn{dbus: c}, nil
+	}
+	tried = append(tried, "unix:path=/run/systemd/private: "+err.Error())
+	return nil, errors.New("connecting to systemd (tried " + strings.Join(tried, "; ") + ")")
+}
+
+func (c *conn) close() {
+	c.dbus.Close()
+}
+
+func propsToDBus(p Props) []sdbus.Property {
+	var out []sdbus.Property
+	add := func(name string, v *uint64) {
+		if v != nil {
+			out = append(out, sdbus.Property{Name: name, Value: godbus.MakeVariant(*v)})
+		}
+	}
+	add("MemoryMin", p.MemoryMin)
+	add("MemoryLow", p.MemoryLow)
+	add("MemoryHigh", p.MemoryHigh)
+	add("MemoryMax", p.MemoryMax)
+	add("CPUWeight", p.CPUWeight)
+	add("IOWeight", p.IOWeight)
+	return out
+}
+
+// Ensure creates the transient slice unit with the given properties or, if the
+// unit is already loaded, updates its runtime properties in place. The returned
+// Result reports what was applied after budget enforcement and whether the
+// budget was overcommitted, so the caller can log both.
+//
+// Transient-unit properties are systemd-owned: they survive daemon-reload and
+// are re-applied by systemd, which is the entire point of this channel.
+func Ensure(ctx context.Context, name string, props Props, b Budget) (Result, error) {
+	res := Result{Applied: props}
+	c, err := connect(ctx)
+	if err != nil {
+		return res, err
+	}
+	defer c.close()
+
+	if props.MemoryMin != nil && b.MemoryMinLimit > 0 {
+		// The budget is a read-modify-write against shared state: the sum is
+		// read from the live sibling slices, and it only accounts for this
+		// request once the properties below have been applied. Two servers
+		// starting concurrently would otherwise both observe the same
+		// remainder and both claim it, overrunning the budget by design.
+		// Held across the apply for that reason; contended only by starts
+		// that actually carry a floor on a node that configures a budget.
+		budgetMu.Lock()
+		defer budgetMu.Unlock()
+
+		used, err := c.sumMemoryMin(ctx, b.SiblingPrefix, b.Exclude)
+		if err != nil {
+			return res, errors.Wrap(err, "summing sibling memory.min floors for budget check")
+		}
+		res.BudgetLimit, res.BudgetUsed = b.MemoryMinLimit, used
+		props, res.Overcommit = applyBudget(props, b, used)
+		res.Applied = props
+	}
+
+	dprops := propsToDBus(props)
+	// systemd "loads" slice units on demand: ListUnitsByNames reports
+	// LoadState=loaded even for a slice that has never existed, so LoadState
+	// cannot distinguish "unit exists" from "name is loadable". Only an
+	// ACTIVE slice really exists (has a cgroup); for everything else the
+	// transient unit must be created and started.
+	active := false
+	if units, err := c.dbus.ListUnitsByNamesContext(ctx, []string{name}); err == nil {
+		for _, u := range units {
+			if u.Name == name && u.ActiveState == "active" {
+				active = true
+			}
+		}
+	}
+	if active {
+		if len(dprops) == 0 {
+			return res, nil
+		}
+		return res, c.dbus.SetUnitPropertiesContext(ctx, name, true, dprops...)
+	}
+
+	full := append([]sdbus.Property{
+		{Name: "Description", Value: godbus.MakeVariant("Wings per-server slice")},
+	}, dprops...)
+	ch := make(chan string, 1)
+	if _, err := c.dbus.StartTransientUnitContext(ctx, name, "replace", full, ch); err != nil {
+		// Lost a race with systemd materializing the slice (e.g. Docker placing
+		// a scope under it concurrently): fall back to a property update.
+		if strings.Contains(err.Error(), "already exists") {
+			if len(dprops) == 0 {
+				return res, nil
+			}
+			return res, c.dbus.SetUnitPropertiesContext(ctx, name, true, dprops...)
+		}
+		return res, err
+	}
+	select {
+	case result := <-ch:
+		if result != "done" {
+			return res, errors.New("starting transient slice " + name + ": job result " + strconv.Quote(result))
+		}
+	case <-ctx.Done():
+		return res, ctx.Err()
+	}
+	return res, nil
+}
+
+// Stop stops (and thereby removes) a slice unit. Stopping a transient slice
+// deletes it; stopping a unit-file-backed slice merely deactivates it until
+// its next start, so callers should only pass slices Wings itself derived.
+func Stop(ctx context.Context, name string) error {
+	c, err := connect(ctx)
+	if err != nil {
+		return err
+	}
+	defer c.close()
+
+	ch := make(chan string, 1)
+	if _, err := c.dbus.StopUnitContext(ctx, name, "replace", ch); err != nil {
+		// A unit that is not loaded is already in the desired state; this is
+		// the normal case for a server that never started under the slice.
+		if strings.Contains(err.Error(), "not loaded") {
+			return nil
+		}
+		return err
+	}
+	select {
+	case result := <-ch:
+		if result != "done" {
+			return errors.New("stopping slice " + name + ": job result " + strconv.Quote(result))
+		}
+	case <-ctx.Done():
+		return ctx.Err()
+	}
+	return nil
+}
+
+// CleanupOrphans stops active transient slices matching prefix<32 hex>.slice —
+// the shape of Wings-derived per-server slices — for which keep returns
+// false. Slices not marked Transient by systemd are never touched: those are
+// administrator-owned. It returns the names of the slices it stopped.
+func CleanupOrphans(ctx context.Context, prefix string, keep func(name string) bool) ([]string, error) {
+	c, err := connect(ctx)
+	if err != nil {
+		return nil, err
+	}
+	defer c.close()
+
+	units, err := c.dbus.ListUnitsByPatternsContext(ctx, nil, []string{prefix + "*.slice"})
+	if err != nil {
+		return nil, err
+	}
+	var stopped []string
+	for _, u := range units {
+		if u.ActiveState != "active" || !isDerivedName(u.Name, prefix) || keep(u.Name) {
+			continue
+		}
+		// Only ever stop units systemd itself marks transient. Note that
+		// transient units DO have a FragmentPath (/run/systemd/transient/…),
+		// so the fragment path cannot serve as the discriminator here.
+		prop, err := c.dbus.GetUnitPropertyContext(ctx, u.Name, "Transient")
+		if err != nil {
+			continue
+		}
+		if transient, ok := prop.Value.Value().(bool); !ok || !transient {
+			continue
+		}
+		ch := make(chan string, 1)
+		if _, err := c.dbus.StopUnitContext(ctx, u.Name, "replace", ch); err != nil {
+			continue
+		}
+		select {
+		case <-ch:
+			stopped = append(stopped, u.Name)
+		case <-ctx.Done():
+			return stopped, ctx.Err()
+		}
+	}
+	return stopped, nil
+}
+
+// isDerivedName reports whether name has the exact shape of a Wings-derived
+// per-server slice: prefix + 32 lowercase hex characters (a dashless server
+// UUID) + ".slice".
+func isDerivedName(name, prefix string) bool {
+	body, ok := strings.CutPrefix(name, prefix)
+	if !ok {
+		return false
+	}
+	body, ok = strings.CutSuffix(body, ".slice")
+	if !ok || len(body) != 32 {
+		return false
+	}
+	for _, r := range body {
+		if !((r >= '0' && r <= '9') || (r >= 'a' && r <= 'f')) {
+			return false
+		}
+	}
+	return true
+}
+
+// sumMemoryMin adds up the MemoryMin values of every loaded slice matching
+// prefix*.slice except exclude. Unset floors read as 0; systemd reports
+// "infinity" as MaxUint64, which would poison the sum and is treated as 0 —
+// a slice with an infinite floor makes the budget meaningless either way.
+func (c *conn) sumMemoryMin(ctx context.Context, prefix, exclude string) (uint64, error) {
+	units, err := c.dbus.ListUnitsByPatternsContext(ctx, nil, []string{prefix + "*.slice"})
+	if err != nil {
+		return 0, err
+	}
+	var total uint64
+	for _, u := range units {
+		if u.Name == exclude || u.ActiveState != "active" {
+			continue
+		}
+		prop, err := c.dbus.GetUnitTypePropertyContext(ctx, u.Name, "Slice", "MemoryMin")
+		if err != nil {
+			continue
+		}
+		v, ok := prop.Value.Value().(uint64)
+		if !ok || v == ^uint64(0) {
+			continue
+		}
+		total += v
+	}
+	return total, nil
+}

@@ -0,0 +1,142 @@
+package cgroups
+
+import "testing"
+
+func TestFormatSize(t *testing.T) {
+	for _, c := range []struct {
+		in   uint64
+		want string
+	}{
+		{6 << 30, "6G"},
+		{512 << 20, "512M"},
+		{64 << 20, "64M"},
+		{4 << 10, "4K"},
+		{0, "0"},
+		{1536, "1536"},                // 1.5K is not a whole unit: stays exact
+		{(6 << 30) + 1, "6442450945"}, // ditto
+	} {
+		if got := FormatSize(c.in); got != c.want {
+			t.Errorf("FormatSize(%d) = %q, want %q", c.in, got, c.want)
+		}
+	}
+}
+
+func TestStartupFromEnv(t *testing.T) {
+	env := []string{
+		"WINGS_CG_MEMORY_MIN=6G",
+		"WINGS_CG_MEMORY_HIGH=7G",
+		"WINGS_CG_STARTUP_MEMORY_MIN=9G",
+		"WINGS_CG_STARTUP_MEMORY_HIGH=",
+		"UNRELATED=x",
+	}
+	p, errs := StartupFromEnv(env)
+	if len(errs) != 0 {
+		t.Fatalf("unexpected errors: %v", errs)
+	}
+	if p.MemoryMin == nil || *p.MemoryMin != 9<<30 {
+		t.Errorf("startup memory_min = %v, want 9G", p.MemoryMin)
+	}
+	// An empty value is "not set", not an error and not a zero override.
+	if p.MemoryHigh != nil {
+		t.Errorf("empty startup memory_high should stay unset, got %d", *p.MemoryHigh)
+	}
+	if _, errs := StartupFromEnv([]string{"WINGS_CG_STARTUP_MEMORY_MIN=nonsense"}); len(errs) != 1 {
+		t.Errorf("bad value should report exactly one error, got %v", errs)
+	}
+}
+
+// The whole point of the feature: during startup the ceiling must be the
+// startup one, and the steady band must come back afterwards.
+func TestEnsureRequestPhaseBands(t *testing.T) {
+	req := EnsureRequest{
+		Derived: true,
+		Defaults: Defaults{
+			MemoryMin:  "6G",
+			MemoryHigh: "7G",
+			CPUWeight:  1000,
+		},
+		StartupDefaults: StartupDefaults{
+			MemoryMin:  "9G",
+			MemoryHigh: "64G", // effectively no ceiling during world load
+		},
+		Env: []string{"WINGS_CG_MEMORY_HIGH=8G"},
+	}
+
+	req.Phase = PhaseSteady
+	steady, errs := req.props()
+	if len(errs) != 0 {
+		t.Fatalf("steady errors: %v", errs)
+	}
+	if steady.MemoryMin == nil || *steady.MemoryMin != 6<<30 {
+		t.Errorf("steady min = %v, want 6G", steady.MemoryMin)
+	}
+	// The per-server variable overrides the node default in the steady band.
+	if steady.MemoryHigh == nil || *steady.MemoryHigh != 8<<30 {
+		t.Errorf("steady high = %v, want 8G (per-server override)", steady.MemoryHigh)
+	}
+	if steady.CPUWeight == nil || *steady.CPUWeight != 1000 {
+		t.Errorf("steady cpu weight = %v, want 1000", steady.CPUWeight)
+	}
+
+	req.Phase = PhaseStartup
+	startup, errs := req.props()
+	if len(errs) != 0 {
+		t.Fatalf("startup errors: %v", errs)
+	}
+	if startup.MemoryMin == nil || *startup.MemoryMin != 9<<30 {
+		t.Errorf("startup min = %v, want 9G (startup default wins)", startup.MemoryMin)
+	}
+	if startup.MemoryHigh == nil || *startup.MemoryHigh != 64<<30 {
+		t.Errorf("startup high = %v, want 64G (startup band beats the per-server 8G)", startup.MemoryHigh)
+	}
+	// Weights are not staged and must survive both phases identically.
+	if startup.CPUWeight == nil || *startup.CPUWeight != 1000 {
+		t.Errorf("startup cpu weight = %v, want 1000", startup.CPUWeight)
+	}
+}
+
+// A node that configures no startup band must behave exactly as before the
+// feature existed: the same properties in both phases.
+func TestEnsureRequestNoStartupOverrideIsIdentical(t *testing.T) {
+	req := EnsureRequest{
+		Derived:  true,
+		Defaults: Defaults{MemoryMin: "6G", MemoryHigh: "7G"},
+	}
+	req.Phase = PhaseStartup
+	a, _ := req.props()
+	req.Phase = PhaseSteady
+	b, _ := req.props()
+	if a.String() != b.String() {
+		t.Errorf("startup band %q differs from steady %q with nothing staged", a, b)
+	}
+}
+
+// A per-server startup variable must work even when the node stages nothing.
+func TestEnsureRequestPerServerStartupOverride(t *testing.T) {
+	req := EnsureRequest{
+		Derived:  true,
+		Phase:    PhaseStartup,
+		Defaults: Defaults{MemoryHigh: "7G"},
+		Env:      []string{"WINGS_CG_STARTUP_MEMORY_HIGH=12G"},
+	}
+	p, _ := req.props()
+	if p.MemoryHigh == nil || *p.MemoryHigh != 12<<30 {
+		t.Errorf("startup high = %v, want 12G", p.MemoryHigh)
+	}
+}
+
+// Hand-managed slices (explicit WINGS_CGROUP_PARENT) never receive node
+// defaults — including the startup band.
+func TestEnsureRequestNonDerivedSkipsDefaults(t *testing.T) {
+	req := EnsureRequest{
+		Derived:         false,
+		Phase:           PhaseStartup,
+		Defaults:        Defaults{MemoryMin: "6G"},
+		StartupDefaults: StartupDefaults{MemoryMin: "9G"},
+		Env:             []string{"WINGS_CG_MEMORY_MIN=1G"},
+	}
+	p, _ := req.props()
+	if p.MemoryMin == nil || *p.MemoryMin != 1<<30 {
+		t.Errorf("non-derived min = %v, want only the explicit 1G", p.MemoryMin)
+	}
+}

# ==========================================================================
# PWMCP — Playwright-as-a-Service (official Microsoft images), ciu stack
# ==========================================================================
#
# pwmcp is a thin, hardened ciu packaging of the OFFICIAL Playwright images.
# It runs two services so a project never installs a browser into its own
# devcontainer / CI runner:
#
#   playwright_server :  mcr.microsoft.com/playwright  running `npx playwright
#                        run-server`  ->  native Playwright connect() endpoint
#                        (FULL API) for test suites.
#   playwright_mcp    :  mcr.microsoft.com/playwright/mcp  ->  MCP surface
#                        (HTTP/SSE) for AI clients (VS Code Copilot, etc.).
#
# Deployment modes
# ----------------
#   internal (default): both services join the project Docker network with NO
#       TLS and NO auth. Sibling containers (the test runner / devcontainer)
#       reach them BY CONTAINER NAME on the shared network — never localhost:
#           PLAYWRIGHT_SERVER_WS = ws://<playwright_server.name>:<port>/
#       The network boundary is the control; this is correct for dev + CI.
#
#   external (external.enabled = true): front with a running tls-edge (Traefik).
#       The route is TLS-terminated and (by default) protected by a per-route
#       basicAuth guard — a secret the consumer defines — so the public URL is
#       not usable without it. See pwmcp.external below + tls-edge guard docs.
#
# Browser isolation hardening (non-root, dropped caps, no-new-privileges) is
# applied in BOTH modes — that is the whole reason the browser is offloaded.

[pwmcp]
# The single source of truth for the Playwright version. It pins:
#   - the base image tag (mcr.microsoft.com/playwright:v<version>-<distro>),
#   - the playwright JS package baked into the playwright-server image, and
#   - the version connect() consumers must install (`pip install playwright==<version>`).
playwright_version = "1.61.0"
image_distro = "noble"            # -> mcr.microsoft.com/playwright:v<version>-<distro>

[pwmcp.network]
ingress_network = "ingress_public"   # shared tls-edge network (external mode only)

[pwmcp.playwright_server]
name = "pwmcp-playwright"
port = 3000                       # run-server listens here (container-internal)
expose = false                    # publish to host 127.0.0.1 (dev convenience only)
host_port = 3000

# The playwright-server image = official base + the matching playwright JS pkg
# (the base ships only browsers). Built from containers/playwright-server/Dockerfile.
# tag should track playwright_version so the consumer pin stays in lockstep.
[pwmcp.playwright_server.image]
registry = "ghcr.io"
namespace = "volkb79-2"
name = "pwmcp-playwright"
tag = "1.61.0-r1"

[pwmcp.playwright_mcp]
enabled = true
name = "pwmcp-mcp"
image_tag = "latest"              # @playwright/mcp has its OWN version line (not Playwright's)
port = 8931
expose = false
host_port = 8931
browser = "chromium"
extra_args = ""                   # e.g. "--caps=vision,pdf"

[pwmcp.hardening]
# Applied to BOTH services, in BOTH modes.
run_as_uid = 1000                 # official image ships a non-root user at 1000
run_as_gid = 1000
no_new_privileges = true
drop_all_caps = true
shm_size = "2gb"                  # Chromium needs shared memory

[pwmcp.external]
# External exposure via a running tls-edge. Leave disabled for dev/CI.
enabled = false
server_host = ""                  # e.g. "pw.example.com"  -> playwright_server (wss connect)
mcp_host = ""                     # e.g. "pw-mcp.example.com" -> playwright_mcp
# Per-route access guard (Traefik basicAuth). The consumer defines the secret;
# supply the htpasswd hash (generate once: `htpasswd -nbB <user> <secret>`).
# A bare "$" is fine here — the compose template escapes it to "$$".
# Default empty: fill it in your gitignored override (ciu.toml.j2) when you
# enable external+guard, or wire a ciu-managed secret via [pwmcp.secrets] below.
guard_enabled = true
guard_user = "pwmcp"
guard_htpasswd = ""

# ciu secrets table. Empty by default — the standalone renderer rejects active
# ASK_EXTERNAL/ASK_VAULT entries in committed defaults. For ciu-managed injection
# of the guard hash, declare it in your override (ciu.toml.j2):
#   [pwmcp.secrets]
#   guard_htpasswd = "ASK_EXTERNAL:PWMCP_GUARD_HTPASSWD"   # or ASK_VAULT:<path>
[pwmcp.secrets]

[state]
initialized = false

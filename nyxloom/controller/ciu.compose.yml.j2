# ─── nyxloom controller (nyxloomd daemon) — ciu stack template ───────────
# Rendered by ciu; the sibling docker-compose.yml is the pre-rendered copy for
# plain-compose deploys (keep both in sync: edit HERE, re-render or hand-sync).
#
# Runs the resident reconciler daemon + dashboard + ntfy command listener in a
# ciu-owned container. Base = the mdt image (binary-compatible with the host
# CLIs the daemon dispatches). Runs as uid 1003 + group 994 (docker gid).
# HOME <- the real host home (auth + .local state); repos bound at matching
# physical paths (DooD); network_mode: host -> dashboard on 127.0.0.1:8942;
# state on the host bind, survives restart.
#
# Secrets: NTFY_TOKEN / NTFY_CMD_TOKEN via controller/.env (gitignored).

# Explicit compose project name — NEVER let it default to the dir basename
# ("controller"), which collides with the dstdns app's per-service "controller"
# compose project (they'd share a project; a `compose -p controller down` would
# hit both). Unique project isolates the nyxloom stack.
name: nyxloom-controller

services:
  nyxloomd:
    build:
      context: .
      dockerfile: Dockerfile
    image: {{ nyxloomd.image }}
    container_name: {{ nyxloomd.container_prefix }}-controller
    restart: unless-stopped
    user: "{{ nyxloomd.runtime.run_as_uid }}:{{ nyxloomd.runtime.run_as_gid }}"
    group_add:
      - "{{ nyxloomd.runtime.docker_gid }}"    # docker gid — sock access for agent gates
    network_mode: host                          # dashboard binds host 127.0.0.1:{{ nyxloomd.dashboard_port }}
    working_dir: /workspaces/vbpub/nyxloom
    env_file:
      - .env                                    # NTFY_TOKEN, NTFY_CMD_TOKEN (gitignored)
    environment:
      HOME: /home/vscode
      TZ: UTC
      PYTHONPATH: /workspaces/vbpub/nyxloom/src
      PATH: /home/vscode/.local/bin:/usr/local/bin:/usr/bin:/bin
    # Clear the stale pidfile on start: the pid-liveness singleton guard is moot
    # in a container (daemon is always pid 1); ciu/docker is the singleton.
    command:
      - bash
      - -c
      - "rm -f /home/vscode/.local/state/nyxloom/daemon/nyxloomd.pid; exec /opt/nyxloom-venv/bin/python -m nyxloom.cli daemon"
    volumes:
      - /home/vb/mdt--mounted-folders:/home/vscode          # home: auth + .local (state)
      - /home/vb/volkb79-2/vbpub:/workspaces/vbpub          # repo + nyxloom src
      - /home/vb/volkb79-2/dstdns:/workspaces/dstdns        # repo (registered project)
      - /var/run/docker.sock:/var/run/docker.sock           # agent dispatch gates
    healthcheck:
      test: ["CMD-SHELL", "timeout 3 bash -c '</dev/tcp/127.0.0.1/{{ nyxloomd.dashboard_port }}' 2>/dev/null || exit 1"]
      interval: {{ nyxloomd.health.interval }}
      timeout: {{ nyxloomd.health.timeout }}
      retries: {{ nyxloomd.health.retries }}
      start_period: {{ nyxloomd.health.start_period }}
    logging:
      driver: json-file
      options:
        max-size: "{{ nyxloomd.logging.max_size }}"
        max-file: "{{ nyxloomd.logging.max_file }}"

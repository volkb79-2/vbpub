# ─── nyxloom controller (nyxloomd daemon) — ciu stack template ───────────
# Rendered by ciu; the sibling docker-compose.yml is the pre-rendered copy for
# plain-compose deploys (keep both in sync: edit HERE, re-render or hand-sync).
#
# Runs the resident reconciler daemon + dashboard + ntfy command listener in a
# ciu-owned container. Base = the mdt image (binary-compatible with the host
# CLIs the daemon dispatches). Runs as uid 1003 + group 994 (docker gid).
# HOME <- the real host home (auth + .local state); repos bound at matching
# physical paths (DooD); state on the host bind, survives restart.
#
# Network (P38, docs/runtime-process-model.md §3): a ciu-owned bridge network,
# NOT host-network -- host-net left the dashboard reachable only from the
# daemon's own netns (127.0.0.1 on the docker host), invisible to the
# devcontainer, so VS Code could never auto-forward it. On the bridge the
# dashboard binds 0.0.0.0 (private to this network, still off the LAN) under
# the stable alias "nyxloomd"; a co-networked container (e.g. the devcontainer,
# once it joins this network -- see the REPORT for that join step) reaches it
# at http://nyxloomd:{{ nyxloomd.dashboard_port }}. docker.sock + the physical
# repo binds are unaffected by the network mode (DooD/repo access is NOT
# host-net-dependent -- verified in the doc above).
#
# Process model (P37, docs/runtime-process-model.md §2): tini (init: true) is
# container PID 1; the daemon runs under a supervisor loop (`command`, no
# `exec`), NOT as PID 1. A daemon crash or restart therefore never tears down
# the container -- its wrapper children (agent processes) reparent to tini and
# keep running, the loop respawns the daemon, and the daemon re-adopts the
# still-live wrappers from their on-disk pid/wrapper.pid. Without this, any
# daemon fault (or a routine code-update restart) killed every in-flight
# agent. ciu/docker remains the container-level singleton (one container,
# `restart: unless-stopped`); tini + the loop add crash-safety *within* it.
#
# Secrets: NTFY_TOKEN / NTFY_CMD_TOKEN via controller/.env (gitignored).

# Explicit compose project name — NEVER let it default to the dir basename
# ("controller"), which collides with the dstdns app's per-service "controller"
# compose project (they'd share a project; a `compose -p controller down` would
# hit both). Unique project isolates the nyxloom stack.
name: nyxloom-nyxloomd

services:
  nyxloomd:
    build:
      context: .
      dockerfile: Dockerfile
    image: {{ nyxloomd.image }}
    container_name: {{ nyxloomd.container_prefix }}-nyxloomd
    restart: unless-stopped
    init: true                                   # tini as PID 1: reaps zombies, forwards
                                                   # signals, and -- critically -- means the
                                                   # daemon (below) is NOT PID 1, so its
                                                   # crash/restart never tears down the
                                                   # container (docs/runtime-process-model.md §2)
    user: "{{ nyxloomd.runtime.run_as_uid }}:{{ nyxloomd.runtime.run_as_gid }}"
    group_add:
      - "{{ nyxloomd.runtime.docker_gid }}"    # docker gid — sock access for agent gates
    working_dir: /workspaces/vbpub/nyxloom
    env_file:
      - .env                                    # NTFY_TOKEN, NTFY_CMD_TOKEN (gitignored)
    environment:
      HOME: /home/vscode
      TZ: UTC
      PYTHONPATH: /workspaces/vbpub/nyxloom/src
      PATH: /home/vscode/.local/bin:/usr/local/bin:/usr/bin:/bin
      NYXLOOM_STATE_BACKEND: "sqlite"          # SP03 cutover 2026-07-21:
                                                 # authoritative state store is
                                                 # per-project SQLite (state.db);
                                                 # events.jsonl retired to
                                                 # .pre-sqlite. Reversible: drop
                                                 # this line -> file backend.
      NYXLOOM_HTTP_BIND: "0.0.0.0"              # P38: safe here -- a private ciu
                                                 # bridge network, never host-net
    # tini (PID 1, via init: true above) supervises this shell, which runs
    # supervise.sh -- a SUPERVISOR LOOP for the daemon, not the daemon itself
    # (no `exec`), so bash stays the daemon's parent and respawns it after each
    # exit. A daemon crash reparents its still-live wrapper children to tini;
    # the respawned daemon re-adopts them via their on-disk pid/wrapper.pid
    # (the belt-and-braces liveness check daemon.py already implements -- see
    # docs/runtime-process-model.md §2). The stale pidfile is cleared once up
    # front. CRASH-LOOP BREAKER (2026-07-21): after N consecutive RAPID
    # failures (a persistent startup fault -- missing dep, bad config, corrupt
    # state) supervise.sh STOPS respawning, logs why, and PARKS the container
    # Up-but-UNHEALTHY for inspection instead of flapping every 2s forever (it
    # must park, not exit: `restart: unless-stopped` would otherwise recreate
    # the container into a slow container-level loop). A run that stays up >=
    # its healthy threshold resets the counter, preserving one-off-crash
    # auto-recovery. Bind-mounted from the repo => supervisor changes need only
    # a restart, no image rebuild (same as daemon code).
    command:
      - bash
      - /workspaces/vbpub/nyxloom/nyxloomd/supervise.sh
    volumes:
      - /home/vb/mdt--mounted-folders:/home/vscode          # home: auth + .local (state)
      - /home/vb/volkb79-2/vbpub:/workspaces/vbpub          # repo + nyxloom src
      - /home/vb/volkb79-2/dstdns:/workspaces/dstdns        # repo (registered project)
      - /home/vb/volkb79-2/netcup-api-filter:/workspaces/netcup-api-filter  # repo (registered project)
      - /var/run/docker.sock:/var/run/docker.sock           # agent dispatch gates
    networks:
      nyxloomd-net:
        aliases:
          - nyxloomd                                # stable alias -- see REPORT for
                                                      # the devcontainer-side join step
    healthcheck:
      # Targets the bind address itself (0.0.0.0, set via NYXLOOM_HTTP_BIND above).
      test: ["CMD-SHELL", "timeout 3 bash -c '</dev/tcp/0.0.0.0/{{ nyxloomd.dashboard_port }}' 2>/dev/null || exit 1"]
      interval: {{ nyxloomd.health.interval }}
      timeout: {{ nyxloomd.health.timeout }}
      retries: {{ nyxloomd.health.retries }}
      start_period: {{ nyxloomd.health.start_period }}
    logging:
      driver: json-file
      options:
        max-size: "{{ nyxloomd.logging.max_size }}"
        max-file: "{{ nyxloomd.logging.max_file }}"

networks:
  nyxloomd-net:
    name: {{ nyxloomd.container_prefix }}-nyxloomd-net   # ciu bridge network (P38);
                                                           # stable name the devcontainer
                                                           # joins as external to reach
                                                           # the "nyxloomd" alias

# ==========================================================================
# nyxloom — CIU ROOT global (multi-stack). nyxloom is a ciu root; its stacks
# (ntfy, controller) live in subdirectories and inherit this global.
# ntfy never terminates TLS (tls-edge does, via ingress_public) and the
# controller is a loopback/host-network admin daemon — neither needs certs
# or an FQDN of its own.
# ==========================================================================

[deploy]
project_name = "nyxloom"
environment_tag = "prod"
network_name = "nyxloom"
log_level = "INFO"

# Hostdir ownership values (ciu S6/S7), expanded from ciu.env.
[deploy.env.shared]
CONTAINER_UID = "$CONTAINER_UID"
CONTAINER_GID = "$DOCKER_GID"
DOCKER_GID = "$DOCKER_GID"

# The stacks under this root. `ciu up` (default profile) brings up both.
[deploy.profiles.default]
stacks = ["ntfy", "nyxloomd"]

# Optional tooling, deliberately OUTSIDE the default up/down waves — the operator's
# "shared dev-tool, like a skywalking instance" property. pwmcp-instance is nyxloom's
# own browser / UI-testing service (Playwright-as-a-Service). A default `ciu up` /
# `ciu down` (default profile above) never touches it; bring it up explicitly with
# `ciu up --profile tools` or `ciu up --dir pwmcp-instance`.
[deploy.profiles.tools]
stacks = ["pwmcp-instance"]

[ciu]
# S1.2 — independent root: refuse to run if $REPO_ROOT points elsewhere
# (this devcontainer's shell auto-sources a sibling repo's ciu.env).
standalone_root = true
require_certs = false
require_fqdn = false
auto_connect_network = false

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vbpub.invalid/handoffctl/schemas/handoff.schema.json",
  "title": "handoffctl handoff",
  "description": "Draft machine metadata for a human-readable bounded task contract.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "task_id",
    "project_id",
    "title",
    "source",
    "input_revision",
    "risk_class",
    "base",
    "dependencies",
    "scope",
    "acceptance_oracles",
    "gates",
    "resources",
    "escalate_if"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "task_id": {
      "type": "string",
      "pattern": "^[A-Za-z][A-Za-z0-9._-]{1,127}$"
    },
    "project_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]{1,62}$"
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 240
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "path"],
      "properties": {
        "kind": {
          "enum": ["review", "backlog", "roadmap", "product-goal", "user", "imported"]
        },
        "path": {
          "type": "string",
          "minLength": 1
        },
        "section": {
          "type": ["string", "null"]
        },
        "parent_task_id": {
          "type": ["string", "null"]
        }
      }
    },
    "input_revision": {
      "type": "object",
      "additionalProperties": false,
      "required": ["commit", "sources_digest"],
      "properties": {
        "commit": {
          "type": "string",
          "pattern": "^[0-9a-f]{40,64}$"
        },
        "sources_digest": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        }
      }
    },
    "risk_class": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]{0,62}$"
    },
    "base": {
      "type": "object",
      "additionalProperties": false,
      "required": ["branch", "commit"],
      "properties": {
        "branch": {"type": "string", "minLength": 1},
        "commit": {"type": "string", "pattern": "^[0-9a-f]{40,64}$"}
      }
    },
    "dependencies": {
      "type": "array",
      "items": {"type": "string", "minLength": 1},
      "uniqueItems": true
    },
    "decisions": {
      "type": "array",
      "items": {"type": "string", "minLength": 1},
      "uniqueItems": true
    },
    "session_hint": {
      "enum": ["fresh", "resume-affinity"]
    },
    "required_capabilities": {
      "type": "array",
      "items": {"type": "string", "minLength": 1},
      "uniqueItems": true
    },
    "context": {
      "type": "array",
      "items": {"type": "string", "minLength": 1},
      "uniqueItems": true
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["include", "exclude"],
      "properties": {
        "include": {
          "type": "array",
          "items": {"type": "string", "minLength": 1},
          "minItems": 1,
          "uniqueItems": true
        },
        "exclude": {
          "type": "array",
          "items": {"type": "string", "minLength": 1},
          "uniqueItems": true
        }
      }
    },
    "acceptance_oracles": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "observable"],
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "observable": {"type": "string", "minLength": 1},
          "negative_case": {"type": ["string", "null"]}
        }
      },
      "minItems": 1
    },
    "gates": {
      "type": "array",
      "description": "References trusted gate IDs from project configuration.",
      "items": {"type": "string", "minLength": 1},
      "minItems": 1,
      "uniqueItems": true
    },
    "resources": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "units"],
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "units": {"type": "integer", "minimum": 1}
        }
      },
      "uniqueItems": true
    },
    "serialize_with": {
      "type": "array",
      "items": {"type": "string", "minLength": 1},
      "uniqueItems": true
    },
    "escalate_if": {
      "type": "array",
      "items": {"type": "string", "minLength": 1},
      "minItems": 1
    },
    "budget": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "max_attempts": {"type": "integer", "minimum": 1},
        "max_wall_seconds": {"type": "integer", "minimum": 1},
        "max_cost": {"type": "number", "minimum": 0},
        "currency": {"type": "string", "pattern": "^[A-Z]{3}$"}
      }
    },
    "human_contract": {
      "type": ["string", "null"],
      "description": "Repository-relative Markdown contract path."
    }
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vbpub.invalid/handoffctl/schemas/project.schema.json",
  "title": "handoffctl project configuration",
  "description": "Draft design schema for one repository registered with handoffctl.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "project_id",
    "repository",
    "instructions",
    "handoff_globs",
    "gates",
    "resources",
    "policy"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "project_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]{1,62}$"
    },
    "repository": {
      "type": "object",
      "additionalProperties": false,
      "required": ["root", "default_branch", "worktree_root"],
      "properties": {
        "root": {
          "type": "string",
          "minLength": 1
        },
        "default_branch": {
          "type": "string",
          "minLength": 1
        },
        "worktree_root": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "instructions": {
      "type": "object",
      "additionalProperties": false,
      "required": ["agent_policy", "product_sources", "decision_sources"],
      "properties": {
        "agent_policy": {
          "type": "string",
          "minLength": 1
        },
        "product_sources": {
          "type": "array",
          "items": {"type": "string", "minLength": 1},
          "minItems": 1,
          "uniqueItems": true
        },
        "decision_sources": {
          "type": "array",
          "items": {"type": "string", "minLength": 1},
          "uniqueItems": true
        },
        "tool_specific": {
          "type": "object",
          "additionalProperties": {"type": "string", "minLength": 1}
        }
      }
    },
    "handoff_globs": {
      "type": "array",
      "items": {"type": "string", "minLength": 1},
      "minItems": 1,
      "uniqueItems": true
    },
    "gates": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/gate"
      }
    },
    "resources": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/resource"
      }
    },
    "risk_routes": {
      "type": "object",
      "description": "Capability-oriented route names; concrete provider selection is recorded per attempt.",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": ["required_capabilities", "review_policy"],
        "properties": {
          "required_capabilities": {
            "type": "array",
            "items": {"type": "string", "minLength": 1},
            "uniqueItems": true
          },
          "review_policy": {
            "enum": ["independent-frontier", "independent-frontier-human-approval"]
          }
        }
      }
    },
    "policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "max_active_tasks",
        "ready_queue_target",
        "max_attempts_per_task",
        "merge_mode",
        "dashboard_bind",
        "retention_days"
      ],
      "properties": {
        "max_active_tasks": {
          "type": "integer",
          "minimum": 1
        },
        "ready_queue_target": {
          "type": "integer",
          "minimum": 0
        },
        "max_attempts_per_task": {
          "type": "integer",
          "minimum": 1
        },
        "merge_mode": {
          "enum": ["manual", "guarded-automatic"]
        },
        "dashboard_bind": {
          "type": "string",
          "default": "127.0.0.1"
        },
        "retention_days": {
          "type": "integer",
          "minimum": 1
        },
        "max_cost": {
          "type": ["number", "null"],
          "minimum": 0
        },
        "cost_currency": {
          "type": ["string", "null"],
          "pattern": "^[A-Z]{3}$"
        }
      }
    }
  },
  "$defs": {
    "gate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["adapter", "phase", "timeout_seconds", "environment"],
      "properties": {
        "adapter": {
          "type": "string",
          "minLength": 1
        },
        "phase": {
          "enum": ["implementation", "review", "pre-merge", "post-merge"]
        },
        "timeout_seconds": {
          "type": "integer",
          "minimum": 1
        },
        "environment": {
          "type": "string",
          "minLength": 1
        },
        "command_id": {
          "type": "string",
          "description": "Trusted adapter/project command identifier, not model-supplied shell text.",
          "minLength": 1
        },
        "required_artifacts": {
          "type": "array",
          "items": {"type": "string", "minLength": 1},
          "uniqueItems": true
        }
      }
    },
    "resource": {
      "type": "object",
      "additionalProperties": false,
      "required": ["scope", "capacity"],
      "properties": {
        "scope": {
          "enum": ["project", "host"]
        },
        "global_alias": {
          "type": ["string", "null"]
        },
        "capacity": {
          "type": "integer",
          "minimum": 1
        },
        "lease_seconds": {
          "type": "integer",
          "minimum": 1,
          "default": 900
        }
      }
    }
  }
}

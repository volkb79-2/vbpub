# ============================================================================
# infra/vault — compose template (rendered to docker-compose.yml, gitignored)
# ============================================================================
# CIU runs:  docker compose -f docker-compose.yml -f .ciu/docker-compose.ciu.yml up -d
# The overlay (.ciu/docker-compose.ciu.yml) is generated by CIU and declares the
# top-level `secrets:` block (root_token -> physical store-file path, S4.17).
# This template declares only CONSUMPTION: `secrets: [root_token]` + reading
# /run/secrets/root_token.

services:
  {{ vault_core.server.name }}:
    image: {{ vault_core.server.image_name }}:{{ vault_core.server.image_tag }}
    container_name: {{ deploy.project_name }}-{{ deploy.environment_tag }}-{{ vault_core.server.name }}

    # S4.18 wrapper pattern — the hashicorp/vault image reads the dev root token
    # from the env var VAULT_DEV_ROOT_TOKEN_ID, which has no *_FILE variant. So
    # we wrap the real entrypoint in `sh -c`, export the var from the mounted
    # secret file, then exec the image's own entrypoint. The secret value never
    # appears in the compose file — only the /run/secrets path does.
    # (Compose normalizes the single `$(...)` to `$$(...)`; the container shell
    # still performs the command substitution.)
    secrets:
      - root_token
    entrypoint:
      - sh
      - -c
      - >
        export VAULT_DEV_ROOT_TOKEN_ID="$(cat /run/secrets/root_token)" &&
        exec docker-entrypoint.sh server -dev -dev-listen-address=0.0.0.0:{{ vault_core.server.internal_port }}

    environment:
      {% for key, value in deploy.env.defaults.items() %}
      - {{ key }}={{ value }}
      {% endfor %}
      # VAULT_ADDR points the `vault` CLI inside the container at itself.
      - VAULT_ADDR=http://127.0.0.1:{{ vault_core.server.internal_port }}

    # Health gate (S7.7): dev-mode Vault is auto-unsealed + active, so the KV2
    # sys/health endpoint returns 200 once it is ready.
    healthcheck:
      test: ["CMD", "wget", "--quiet", "--tries=1", "--spider",
             "http://127.0.0.1:{{ vault_core.server.internal_port }}/v1/sys/health"]
      interval: {{ deploy.health.interval }}
      timeout: {{ deploy.health.timeout }}
      retries: {{ deploy.health.retries }}
      start_period: {{ deploy.health.start_period }}

    labels:
      - ciudemo.component=vault

    networks:
      - workspace

networks:
  workspace:
    external: true
    name: {{ deploy.network_name }}

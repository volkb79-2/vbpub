# CIU machine-owned artifacts (S1.6/S1.7) — humans MUST NOT edit, MUST be gitignored
**/.ciu/

# Rendered config outputs (S1.8 — gitignored, see .gitignored.ciu)
ciu.global.toml
**/ciu.toml
# CIU's own rendered compose (a hand-written docker-compose.yml for the
# --shipped path is intentionally NOT ignored — maintainers commit it)
**/ciu.compose.yml
# The monorepo root .gitignore ignores **/docker-compose.yml globally; re-include
# it under ciu/ so a hand-written shipped compose (S8.5) stays committable.
!**/docker-compose.yml

# Per-stack override template `ciu.toml.j2`: COMMITTED, OPTIONAL sparse override
# (S3.1a, CIU-8). CIU never auto-creates it; like ciu.global.toml.j2 it is
# hand-authored, sparse, and tracked. Only the *rendered* ciu.toml (above) is
# gitignored — the override template is NOT.

# Workspace environment (machine identity layer, S2)
**/ciu.env

# Python caches
__pycache__/
*.py[cod]
.pytest_cache/

# Build artifacts
build/
dist/
*.egg-info/

# setuptools-scm generated version file (written at build time)
src/ciu/_version.py

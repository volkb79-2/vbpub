# mdt host-setup configuration — ALL tunables for the dev-tier slices.
#
# install.sh copies this file to /etc/mdt/host-setup.env on first install (it
# never overwrites an existing one). Edit THAT copy, then:
#   - render-time values (slice sizes, weights, statics, timer interval):
#     re-run install.sh to re-render + reinstall the units.
#   - runtime values (BE_IO_CAP_PCT, patterns, CGROUP2_FLAGS): picked up by
#     mdt-apply-dev-caps.sh on its next run — no reinstall needed.
#
# Sizing guidance: the example values below are from a 15.6Gi mixed-use host
# that also runs a production game server (see README.md "Tiering model").
# Scale MemoryHigh/Max to what your host can spare below its production tiers.

## ── Device for IO caps ──────────────────────────────────────────────────────
# Block device NODE (path, not MAJ:MIN) backing the docker data dir.
# Empty = auto-discover via findmnt of /var/lib/docker, falling back to /.
IO_DEV_PATH=""

## ── interactive.slice — devcontainers + IDE (render-time) ───────────────────
INTERACTIVE_MEMORY_HIGH=5G
INTERACTIVE_MEMORY_MAX=7G
INTERACTIVE_MEMORY_LOW=2G
INTERACTIVE_CPU_WEIGHT=200
# KEEP IO WEIGHTS <= 100 ON A BFQ HOST. systemd's IOWeight is 1..10000 but BFQ
# schedules on io.bfq.weight (1..1000); systemd maps 1..100 through unchanged
# and compresses everything above 100 by ~11x. So 100-vs-10 below is a true
# 10:1, while "improving" this to 1000-vs-10 would silently be 181-vs-10.
# Full mapping table + verification commands: CGROUP-NOTES.md §BFQ.
INTERACTIVE_IO_WEIGHT=100
# Whether this tier's coldest pages may drain out of zswap onto disk swap.
#
#   yes (default) — zswap stays a CACHE. Its LRU evicts only the coldest-of-cold
#                   to disk, which frees pool RAM for pages that are actually
#                   warm, including other tiers'. On a memory-tight host this
#                   is what keeps the pool useful rather than full of an IDE's
#                   long-idle tail.
#   no            — the tier's cold tail is pinned in compressed RAM forever.
#                   Protects against disk swap-in stalls (an IDE freeze of a
#                   few hundred ms), at the cost of permanently occupying pool
#                   RAM with pages nobody is touching.
#
# Set "no" only if you measure IDE stalls attributable to swap-in. Note the
# pool is a fixed share of RAM (zswap max_pool_percent): pinning one tier's
# cold tail there takes that RAM away from every other tier.
INTERACTIVE_ZSWAP_WRITEBACK=yes

## ── besteffort.slice — test/build/CI stacks (render-time) ───────────────────
BESTEFFORT_MEMORY_HIGH=8G
BESTEFFORT_MEMORY_MAX=12G
BESTEFFORT_MEMORY_SWAP_MAX=24G
BESTEFFORT_CPU_WEIGHT=20
# See the IOWeight note above: 10 vs interactive's 100 is a true 10:1 on BFQ
# only because both sides stay <= 100.
BESTEFFORT_IO_WEIGHT=10
BESTEFFORT_OOM_PRESSURE_LIMIT=60%
# Static boot-window IO fallbacks (deliberately tight — the service replaces
# them with measured-baseline values as soon as it runs; without a baseline
# they stay in force, so builds will crawl until you run the benchmark).
BESTEFFORT_STATIC_RBW=31M
BESTEFFORT_STATIC_WBW=31M
BESTEFFORT_STATIC_RIOPS=100
BESTEFFORT_STATIC_WIOPS=400

## ── Runtime caps — mdt-apply-dev-caps.sh (re-read every run) ────────────────
# Both percentages are of the MEASURED device ceilings in io-baseline.env, and
# both belong in the 60-80% band. Never cap at 100%: a device driven to
# saturation queues everything, and the whole point of the caps is that the
# host's latency-sensitive work (the IDE here, a production tier elsewhere)
# never waits behind a build storm. Below ~60% you stop bounding a burst and
# start throttling ordinary work — builds crawl for no protective gain.
#
# Whole-tier ceiling for besteffort.slice — bounds ALL best-effort containers
# together. Low end of the band, because "the tier" can be 15 containers.
BE_IO_CAP_PCT=60
# Per-container ceiling for bench/buildkit/devcontainer containers. High end of
# the band: this is ONE container's share, and the ones it applies to (buildkit
# workers, the devcontainer) live OUTSIDE besteffort.slice, so this is their
# only ceiling. A matched container that IS inside besteffort.slice gets the
# stricter of the two automatically — cgroup limits nest, effective = min.
BENCH_IO_CAP_PCT=80
# Container matching for the per-container sweep (shell case patterns,
# space-separated). Image patterns match .Config.Image, name patterns match
# the container name.
BENCH_IMAGE_PATTERNS="*test-runner*"
BENCH_NAME_PATTERNS="buildx_buildkit_*"
# Devcontainers are capped (io.max) but NOT de-prioritized: unlike bench and
# buildkit containers they do not get IOWeight=1, because this tier is the IDE
# and losing every IO race to a sibling is exactly the stall we are preventing.
DEVCONTAINER_NAME_PATTERNS="*devcontainer*"
# cgroup2 mount flags (nsdelegate,memory_recursiveprot). systemd mounts both at
# boot, but a runtime remount from the init cgroup namespace can strip them —
# and without memory_recursiveprot every MemoryLow/MemoryMin on a slice
# silently stops protecting the container pages below it.
#   warn = log a warning when missing (default)   fix = remount to restore
CGROUP2_FLAGS=warn

## ── Periodic sweep timer (render-time) ──────────────────────────────────────
# How often mdt-host-slices.timer re-runs the apply script to catch containers
# created since boot (buildx_buildkit_* workers appear on demand; devcontainers
# get recreated on rebuild). Idempotent, cheap.
SWEEP_INTERVAL=5min

## ── Baseline benchmark cache ─────────────────────────────────────────────────
# Where mdt-io-baseline.py caches the measured device ceilings and where
# mdt-apply-dev-caps.sh reads them from. To reuse a baseline measured by
# another tool, point this at that file (plain KEY=VALUE: RIOPS_MAX, WIOPS_MAX,
# RBW_MAX_BPS, WBW_MAX_BPS) or copy it here.
IO_BASELINE_ENV=/var/lib/mdt/io-baseline.env
# Interop with ciu governance (it caps compose services per-container and reads
# the same file format, deriving read_iops as 2/3 of RIOPS_MAX). ciu searches
# /var/lib/ciu/io-baseline.env, NOT this path — so measure once and share it:
#   echo 'CIU_GOV_BASELINE_PATH=/var/lib/mdt/io-baseline.env' >> /etc/environment
# or set IO_BASELINE_ENV=/var/lib/ciu/io-baseline.env here and let ciu find it
# at its own default. Two independently measured baselines on one host is the
# thing to avoid: the tiers and the per-service caps then disagree.

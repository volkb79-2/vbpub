// mdt devcontainer TEMPLATE (JSONC — comments allowed).
//
// WHY this is a template you VENDOR (copy into your repo's .devcontainer/), not
// something baked into the mdt image:
//   • devcontainer.json is inherently repo-specific (name, mounts, features,
//     extensions, sibling-repo workspace mounts) — there is no one image-baked
//     version that fits every consumer.
//   • initialize_container_environment.py runs ON THE HOST (initializeCommand,
//     before the container exists) — the image filesystem isn't available to it,
//     so it cannot live in the image; it must be a file in your repo checkout.
//   • finalize_container_environment.py runs INSIDE the container, so it IS baked
//     into the mdt image — you reference it by name (see postCreateCommand below),
//     you do NOT copy it.
//
//   cp <vbpub>/modern-debian-tools-python-debug/templates/{devcontainer.json,initialize_container_environment.py} .devcontainer/
//   # then "Dev Containers: Rebuild Container"
//
// Entries are ordered by lifecycle phase:
//   1. identity → 2. host bootstrap → 3. image → 4. features → 5. container metadata
//   → 6. mounts → 7. env → 8. Docker runtime args → 9. in-container init → 10. IDE config
{
  // ─── 1. Identity ──────────────────────────────────────────────────────────────
  "name": "${localWorkspaceFolderBasename}-devcontainer-${localEnv:USER}",

  // ─── 2. Host bootstrap (PRE-container) ─────────────────────────────────────────
  // Runs ON THE HOST before the container is created, so every $HOME bind-mount
  // source below exists with correct perms (else Docker creates them as root and
  // the vscode user can't write its own state). Derives the dir list from the
  // mounts below, so the two stay in sync. Vendored into your repo (see header).
  "initializeCommand": "python3 .devcontainer/initialize_container_environment.py",

  // ─── 3. Container image ────────────────────────────────────────────────────────
  // Track the newest PHP development image. Use a dated tag only when a
  // consumer needs a reproducible compatibility lane.
  "image": "ghcr.io/volkb79-2/modern-debian-tools-python-debug-vsc-devcontainer:trixie-py3.14-php8.5-latest",

  // ─── 4. Container features ─────────────────────────────────────────────────────
  "features": {
    "ghcr.io/devcontainers/features/docker-outside-of-docker:1": {
      "moby": false,
      "dockerDashComposeVersion": "v2"
    }
  },

  // ─── 5. Container metadata ─────────────────────────────────────────────────────
  "workspaceFolder": "/workspaces/${localWorkspaceFolderBasename}",
  "remoteUser": "vscode",

  // ─── 6. Mounts ─────────────────────────────────────────────────────────────────
  // Grouped persistence — every persist-worthy dir lives under
  // ~/mdt--mounted-folders/ on the host (real dirs, created by
  // initialize_container_environment.py). A rebuild never wipes them, and one
  // `ls ~/mdt--mounted-folders/` shows the whole set.
  "mounts": [
    // ── Docker / host integration ──────────────────────────────────────────────
    "source=/var/run/docker.sock,target=/var/run/docker.sock,type=bind",
    // Host letsencrypt certs (readonly). Consider security implications.
    // "source=/etc/letsencrypt,target=/etc/letsencrypt,type=bind,consistency=cached,readonly",

    // ── Host ssh keys (readonly, dual-use: native keys + in-container), owned by host ─────────
    "source=${localEnv:HOME}/.ssh,target=/home/vscode/.ssh-host,type=bind,consistency=cached,readonly",

    // ── PERSISTENT STATE (~/mdt--mounted-folders/) — survives rebuilds, owned by container ────────
    // Directory mounts (alphabetical by subdir name)
    "source=${localEnv:HOME}/mdt--mounted-folders/.claude,target=/home/vscode/.claude,type=bind,consistency=cached",
    "source=${localEnv:HOME}/mdt--mounted-folders/.codex,target=/home/vscode/.codex,type=bind,consistency=cached",
    "source=${localEnv:HOME}/mdt--mounted-folders/.config,target=/home/vscode/.config,type=bind,consistency=cached",
    "source=${localEnv:HOME}/mdt--mounted-folders/.gnupg,target=/home/vscode/.gnupg,type=bind,consistency=cached",
    "source=${localEnv:HOME}/mdt--mounted-folders/.local,target=/home/vscode/.local,type=bind,consistency=cached",
    "source=${localEnv:HOME}/mdt--mounted-folders/.minisign,target=/home/vscode/.minisign,type=bind,consistency=cached",
    "source=${localEnv:HOME}/mdt--mounted-folders/.openclaw,target=/home/vscode/.openclaw,type=bind,consistency=cached",
    "source=${localEnv:HOME}/mdt--mounted-folders/.reasonix,target=/home/vscode/.reasonix,type=bind,consistency=cached",
    "source=${localEnv:HOME}/mdt--mounted-folders/.ssh,target=/home/vscode/.ssh,type=bind,consistency=cached",
    "source=${localEnv:HOME}/mdt--mounted-folders/opencode-data,target=/home/vscode/.local/share/opencode,type=bind,consistency=cached",
    // File-level state mounts (not inside a subdirectory)
    "source=${localEnv:HOME}/mdt--mounted-folders/.claude.json,target=/home/vscode/.claude.json,type=bind,consistency=cached",
    // "source=${localEnv:HOME}/mdt--mounted-folders/.reasonix.toml,target=/home/vscode/.reasonix.toml,type=bind,consistency=cached",

    // ── Persisted host-backed /tmp (mode 1777) ─────────────────────────────────
    "source=${localEnv:HOME}/mdt--mounted-folders/tmp,target=/tmp,type=bind,consistency=cached"
    // NOTE: caches (~/.cache, ~/.npm) are intentionally NOT persisted.

    // ── Sibling-repo workspace mounts (multi-root workspace) ───────────────────
    // "source=${localWorkspaceFolder}/../vbpub,target=/workspaces/vbpub,type=bind,consistency=cached"
  ],

  // ─── 7. Container environment ──────────────────────────────────────────────────
  "containerEnv": {
    "DOCKER_HOST": "unix:///var/run/docker.sock"
  },

  // ─── 8. Docker runtime arguments ──────────────────────────────────────────────
  "runArgs": [
    "--hostname", "${localWorkspaceFolderBasename}-devcontainer-${localEnv:USER}",
    "--name", "${localWorkspaceFolderBasename}-devcontainer-${localEnv:USER}",
    // DOCKER_GID must be exported in the host shell before launch (see repo docs).
    "--group-add", "${localEnv:DOCKER_GID}",
    // sshfs / mount(2) inside container
    "--cap-add", "SYS_ADMIN",
    "--device", "/dev/fuse",
    "--security-opt", "apparmor=unconfined",
    "--security-opt", "seccomp=unconfined",

    // Host resource governance (cgroup v2) — OPTIONAL, safe everywhere.
    // Cgroup placement is CREATE-TIME ONLY, so it must be set here.
    // HOST PREREQUISITE: /etc/systemd/system/interactive.slice unit with desired
    // limits (MemoryHigh/MemoryMax/CPUWeight/...).
    // GRACEFUL DEGRADATION: if that unit is missing, systemd creates a transient
    // UNLIMITED slice — the container still starts normally.
    "--cgroup-parent=interactive.slice"
  ],

  // ─── 9. In-container initialization (POST-create) ─────────────────────────────
  // Baked into the mdt image (NOT vendored). Runs generic ciu-agnostic setup,
  // then discovers + runs consumer hooks from .devcontainer/finalize.{pre,post}.d/*.sh.
  // Put repo-specific (and any ciu) setup in a post hook, e.g.:
  //   .devcontainer/finalize.post.d/10-myrepo.sh
  // mdt's own steps are best-effort; a non-zero exit from YOUR hook fails the build.
  "postCreateCommand": "finalize_container_environment.py",

  // ─── 10. IDE customizations (VS Code) ─────────────────────────────────────────
  "customizations": {
    "vscode": {
      "settings": {
        "python.defaultInterpreterPath": "python3"
      },
      "extensions": [
        // Python & linting
        "ms-python.python",
        "charliermarsh.ruff",
        // Docker & container tooling
        "ms-vscode.docker",
        // Config & markup languages
        "redhat.vscode-yaml",
        "tamasfe.even-better-toml",
        "hashicorp.hcl",
        "hashicorp.terraform",
        "samuelcolvin.jinjahtml",
        // Data & CSV
        "mechatroner.rainbow-csv",
        "janisdd.vscode-edit-csv",
        "mtxr.sqltools",
        // Shell / scripting
        "timonwong.shellcheck",
        "mikestead.dotenv",
        // Frontend (TypeScript/React)
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        // Git & project navigation
        "eamodio.gitlens",
        // Markdown & documentation
        "yzhang.markdown-all-in-one"
      ]
    }
  }
}

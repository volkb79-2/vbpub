# Central API key file for modern-debian-tools-python-debug
# Copy this file to `ai.env` and fill in the keys you use.
#
# Supported keys:
#   ANTHROPIC_API_KEY
#   OPENAI_API_KEY
#   OPENROUTER_API_KEY
#   DEEPSEEK_API_KEY
#
# Optional provider base URLs for OpenAI-compatible clients:
#   OPENAI_BASE_URL=https://api.openai.com/v1
#   OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
#   DEEPSEEK_BASE_URL=https://api.deepseek.com
#
# GitHub Copilot CLI (used via the `copilot` CLI, installed as @github/copilot):
# When using a third-party provider (e.g. OpenRouter, DeepSeek) instead of the
# default GitHub Copilot backend, set these to route copilot through that provider.
#   COPILOT_PROVIDER_BASE_URL=https://openrouter.ai/api/v1
#   COPILOT_PROVIDER_API_KEY=sk-or-v1-xxxxxxxxxx
#   COPILOT_MODEL=deepseek-v4-flash

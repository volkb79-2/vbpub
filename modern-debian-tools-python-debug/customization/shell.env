# Shell defaults for the debug cockpit.

export EDITOR="${EDITOR:-nano}"
export VISUAL="${VISUAL:-nano}"
export PAGER="${PAGER:-less}"
export LESSCHARSET="${LESSCHARSET:-utf-8}"
export LESS="${LESS:--R -M}"
export LESSHISTFILE="${LESSHISTFILE:-$HOME/.config/modern-debian-tools-python-debug/lesshst}"
export LESSOPEN="${LESSOPEN:-|$HOME/.config/modern-debian-tools-python-debug/lesspipe.sh %s}"
export HTOPRC="${HTOPRC:-$HOME/.config/modern-debian-tools-python-debug/htoprc}"
